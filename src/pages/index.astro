---
import Layout from '../layouts/Layout.astro';
import { closeIcon, menuIcon } from '../components/icons';
import NavLinks from '../components/NavLinks.astro';
import Button from '../components/Button.astro';
import { socialLinks } from '../components/socials';
import RepoTitle from '../components/RepoTitle.astro';
---

<Layout title="John Ogletree - Digital Artist & Designer" description="Portfolio and personal website of John Ogletree, a digital artist and designer based in Martinez, GA. Showcasing UI design, UX research, prototyping, and frontend development." keywords="John Ogletree, Digital Artist, Designer, UI Design, UX Research, Prototyping, Frontend Development, Martinez GA, Portfolio">
    <div class="readme-container">
        <header class="readme-header">
            <div class="header-right">
                <div class="nav-drawer-container" id="nav-drawer-container">
                    <nav class="main-nav" id="main-nav">
                        <div class="nav-header-mobile">
                            <Button label="Close navigation" icon={closeIcon} className="nav-close" />
                            <form class="search-form mobile-search" action="/directory" method="get">
                                <input type="search" name="q" class="search-input" placeholder="Search...">
                            </form>
                        </div>
                        <NavLinks />
                        <ul class="nav-socials">
                            {socialLinks.map(link => (
                                <li>
                                    <a href={link.href} aria-label={link.label}>
                                        <Fragment set:html={link.icon} />
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </nav>
                </div>
                                <Button label="Toggle navigation" icon={menuIcon} className="nav-toggle" id="nav-toggle" aria-expanded="false" />
            </div>
            <div class="header-left">
                <RepoTitle repoName="john-ogletree/Echo" />
            </div>
        </header>

        <main class="readme-body">
            

            

            

            <div class="content-container">
                
        </main>
    </div>
</Layout>

<script is:inline>
    // Original script for nav drawer and year
    document.addEventListener('DOMContentLoaded', function() {
        const navToggle = document.getElementById('nav-toggle');
        const navDrawer = document.getElementById('nav-drawer-container');
        const navClose = document.querySelector('.nav-close');
        const body = document.body;
        function toggleMobileNav() {
            const isOpen = navDrawer.classList.contains('is-open');
            navDrawer.classList.toggle('is-open', !isOpen);
            navToggle.setAttribute('aria-expanded', !isOpen);
            body.classList.toggle('no-scroll', !isOpen);
        }

        if (navToggle && navDrawer) {
            navToggle.addEventListener('click', toggleMobileNav);
            navClose.addEventListener('click', toggleMobileNav);
        }

        const navLinks = document.querySelectorAll('.nav-links a');
        navLinks.forEach(link => {
            link.addEventListener('click', () => {
                if (navDrawer.classList.contains('is-open')) {
                    toggleMobileNav();
                }
            });
        });
        const yearSpan = document.getElementById('year');
        if (yearSpan) {
            yearSpan.textContent = new Date().getFullYear();
        }
    });

    // New script for dynamic cards
    document.addEventListener('DOMContentLoaded', function() {
        // --- Profile Card Logic ---
        const profileCard = document.getElementById('profile-card');
        if (profileCard) {
            const animateStats = () => {
                const statValues = profileCard.querySelectorAll('.stat-value[data-value]');
                statValues.forEach(stat => {
                    const finalValue = parseInt(stat.getAttribute('data-value'), 10);
                    const duration = 2000;
                    const startTime = performance.now();
                    const animate = (currentTime) => {
                        const elapsedTime = currentTime - startTime;
                        const progress = Math.min(elapsedTime / duration, 1);
                        stat.textContent = Math.floor(progress * finalValue).toLocaleString();
                        if (progress < 1) requestAnimationFrame(animate);
                    };
                    requestAnimationFrame(animate);
                });
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        animateStats();
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.5 });
            
            observer.observe(profileCard);
            
            
        }

        // --- Animated Skills Logic ---
        const skillItems = document.querySelectorAll('.skill-item');
        const skillObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const progressBar = entry.target.querySelector('.progress-bar');
                    const targetWidth = progressBar.getAttribute('data-width');
                    progressBar.style.width = targetWidth;
                    skillObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.5 });

        skillItems.forEach(item => {
            skillObserver.observe(item);
        });
    });
</script>

<style>
    @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;700&display=swap');
    :root {
        --color-bg: #F0EAD6; /* Light cream */
        --color-surface: #D4C9A8; /* Muted beige */
        --color-text: #3B2F2A; /* Deep brown-black */
        --color-text-light: #5B4F48; /* Dark brown-grey */
        --color-heading: #E07A5F; /* Warm terracotta orange */
        --color-accent: #3D87A6; /* Retro teal */
        --color-border: #A69E8C; /* Faded grey-brown */
        --color-tag-bg: rgba(61, 135, 166, 0.15); /* Faded teal transparency */
        --font-mono: 'IBM Plex Mono', Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        --padding-x: 2rem;
    }

    /* --- Base & Typography --- */
    html {
        scroll-behavior: smooth;
        scroll-padding-top: 80px;
    }
    body {
        background-color: var(--color-bg);
        color: var(--color-text);
        font-family: var(--font-mono);
        font-size: 16px;
        line-height: 1.7;
        margin: 0;
        padding: 0;
        transition: transform 0.3s ease-in-out;
    }
    body.no-scroll {
        overflow: hidden;
    }
    body.no-scroll .readme-body {
        filter: blur(5px);
        pointer-events: none;
    }
    h1, h2, h3, h4 {
        font-family: var(--font-mono);
        font-weight: 500;
        color: var(--color-heading);
        margin: 0;
    }
    h2 { font-size: 1.5rem; border-bottom: 1px solid var(--color-border);
        padding-bottom: 0.5rem; margin: 2.5rem 0 1rem 0;
    }
    h2::before {
        content: '##';
        color: var(--color-text-light);
        font-weight: 400;
        margin-right: 0.5rem;
    }
    p { margin: 0 0 1rem 0; }
    a { color: var(--color-accent); text-decoration: none;
    }
    a:hover { text-decoration: underline; }
    hr { display: none;
    }
    ul { list-style: '- ';
    padding-left: 1.5rem;
    margin-bottom: 1rem;}
    blockquote {
        margin-left: 0;
        padding-left: 1rem;
        border-left: 3px solid var(--color-border);
        color: var(--color-text-light);
    }

    /* --- Main Layout --- */
    .readme-container {
        background-color: var(--color-surface);
    }
    .readme-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1rem var(--padding-x);
        border-bottom: 1px solid var(--color-border);
        position: sticky;
        top: 0;
        z-index: 10;
        background-color: var(--color-surface);
    }
    .header-left, .header-right {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    
    .readme-body {
        padding: 2rem var(--padding-x);
        transition: filter 0.3s ease-in-out;
    }

    /* --- Header Search --- */
    .search-form { position: relative;
    }
    .search-input {
        background-color: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: 6px;
        padding: 0.4rem 2rem 0.4rem 0.75rem;
        font-family: var(--font-mono);
        font-size: 0.9rem;
        color: var(--color-text);
        width: 180px;
    }
    .search-input:focus {
        outline: none;
        border-color: var(--color-accent);
        box-shadow: 0 0 0 3px rgba(61, 135, 166, 0.3);
    }
    .mobile-search { display: block;
    }
    .desktop-search { display: none;
    }

    /* --- Header / Nav --- */
    .nav-links {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        list-style: none;
        margin: 0;
        padding: 2rem 1.5rem;
        flex-grow: 1;
        overflow-y: auto;
    }
    .nav-links a {
        position: relative;
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 1.1rem;
        font-weight: 500;
        padding: 0.5rem 0;
        border-bottom: 1px solid var(--color-border);
        color: var(--color-text);
        transition: color 0.2s ease, transform 0.2s ease;
    }
    
    .nav-links a:hover {
        color: var(--color-accent);
        text-decoration: none;
        transform: translateX(5px);
    }
    .nav-links a.current-page {
        color: var(--color-heading);
    }
    .nav-links a.current-page::before,
    .nav-links a:hover::before {
        content: '';
        position: absolute;
        left: -1rem;
        height: 100%;
        width: 4px;
        background-color: var(--color-accent);
        border-radius: 2px;
    }
    .nav-links a:active {
        transform: scale(0.98);
    }
    .nav-links a span {
        flex-grow: 1;
    }
    .nav-links a svg {
        flex-shrink: 0;
    }
    
    
    
    .nav-close {
        display: none;
    }

    .nav-drawer-container.is-open ~ .nav-toggle {
        display: none;
    }

    .nav-drawer-container .nav-close {
        display: none;
    }
    
    .nav-drawer-container.is-open .nav-close {
        display: block;
    }

    .nav-drawer-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 300px;
        height: 100vh;
        background-color: var(--color-surface);
        border-right: 1px solid var(--color-border);
        transform: translateX(-100%);
        transition: transform 0.3s ease-in-out;
        z-index: 99;
        box-shadow: 4px 0 16px rgba(0, 0, 0, 0.5);
    }
    .nav-drawer-container.is-open {
        transform: translateX(0);
    }
    
    .main-nav {
        display: flex;
        flex-direction: column;
        height: 100%;
        padding: 0;
    }

    .nav-header-mobile {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.5rem 1.5rem 1rem 1.5rem;
        border-bottom: 1px solid var(--color-border);
        flex-shrink: 0;
    }

    .nav-header-mobile .mobile-search {
        flex-grow: 1;
    }

    .nav-socials {
        list-style: none;
        padding: 1.5rem;
        border-top: 1px solid var(--color-border);
        display: flex;
        justify-content: center;
        gap: 2rem;
        flex-shrink: 0;
    }
    .nav-socials a { color: var(--color-text-light);
    }
    .nav-socials a:hover { color: var(--color-accent);
    }
    .nav-socials svg { width: 24px; height: 24px;
    }

    /* --- Responsive --- */
    @media (max-width: 920px) {
        :root {
            --padding-x: 1.5rem;
        }
        .readme-container {
            position: relative;
        }
        .desktop-search { display: none;
        }
        .mobile-search { display: block;
        }
        
        .nav-toggle {
            display: block;
        }
        
        .nav-close {
            display: none;
        }
        
        .nav-drawer-container.is-open ~ .nav-toggle {
            display: none;
        }

        .nav-drawer-container .nav-close {
            display: none;
        }
        
        .nav-drawer-container.is-open .nav-close {
            display: block;
        }

        .nav-drawer-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 300px;
            height: 100vh;
            background-color: var(--color-surface);
            border-right: 1px solid var(--color-border);
            transform: translateX(-100%);
            transition: transform 0.3s ease-in-out;
            z-index: 99;
            box-shadow: 4px 0 16px rgba(0, 0, 0, 0.5);
        }
        .nav-drawer-container.is-open {
            transform: translateX(0);
        }
        
        .main-nav {
            display: flex;
            flex-direction: column;
            height: 100%;
            padding: 0;
        }

        .nav-header-mobile {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1.5rem 1.5rem 1rem 1.5rem;
            border-bottom: 1px solid var(--color-border);
            flex-shrink: 0;
        }

        .nav-header-mobile .mobile-search {
            flex-grow: 1;
        }

        .nav-socials {
            list-style: none;
            padding: 1.5rem;
            border-top: 1px solid var(--color-border);
            display: flex;
            justify-content: center;
            gap: 2rem;
            flex-shrink: 0;
        }
        .nav-socials a { color: var(--color-text-light);
        }
        .nav-socials a:hover { color: var(--color-accent);
        }
        .nav-socials svg { width: 24px; height: 24px;
        }
    }

    @media (max-width: 768px) {
        :root {
            --padding-x: 1rem;
        }
        .readme-header {
            padding: 1rem var(--padding-x);
        }
        .readme-body {
            padding: 1.5rem var(--padding-x);
        }
        h2 { font-size: 1.25rem;
        }
    }
</style>
