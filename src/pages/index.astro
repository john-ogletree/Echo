---
import Layout from '../layouts/Layout.astro';
---

<Layout title="John Ogletree - Home">
  <nav class="main-nav-bar">
    <div class="nav-container">
      <a href="/" class="nav-logo">John Ogletree</a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/creations">Creations</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>
  </nav>
  <div class="hero">
    <div class="hero-container">
      <h2 class="hero-title">Creative Solutions for a Digital World</h2>
      <p class="hero-subtitle">I'm a multidisciplinary digital artist and designer with over nine years of experience, ready to help you bring your ideas to life.</p>
      <a href="/creations" class="hero-cta">See My Work</a>
    </div>
  </div>
  <div class="profile-card-section">
    <div class="profile-card">
      <img src="https://placehold.co/120x120/161B22/E6EDF3?text=JO" alt="A portrait of John Ogletree" class="profile-picture">
      <h3>John Ogletree</h3>
      <blockquote>I'm a multidisciplinary digital artist and designer from Martinez, Georgia. With nearly a decade of experience, I partner with clients to turn ambitious ideas into reality. My process is built on clear communication and a commitment to craft, whether I'm designing an application or composing a soundtrack.</blockquote>
    </div>
  </div>
  <main class="content">
    <div class="services-overview">
      <div class="services-header">
        <h2 class="services-title">My Services</h2>
        <p class="services-intro">
          I offer a range of creative and technical services to help you build a strong digital presence. My goal is to work with you to understand your vision and deliver solutions that are both beautiful and functional.
        </p>
      </div>
      <div class="services-grid">
        <div class="service-card">
          <h3 class="service-title">UI/UX Design & Web Development</h3>
          <p class="service-description">
            I create intuitive and engaging user interfaces for websites and applications. From wireframing and prototyping to final design and implementation, I focus on the user's journey to ensure a seamless and enjoyable experience. My development skills bring these designs to life with clean, efficient code.
          </p>
        </div>
        <div class="service-card">
          <h3 class="service-title">Digital Illustration & Graphic Design</h3>
          <p class="service-description">
            Whether you need custom illustrations for a brand, an eye-catching logo, or a complete visual identity, I can translate complex ideas into clear and compelling visuals. I have experience working across various styles and mediums to create graphics that capture attention and communicate your message effectively.
          </p>
        </div>
        <div class="service-card">
          <h3 class="service-title">Sound Design & Music Composition</h3>
          <p class="service-description">
            Good design isn't just visual; it's also aural. I compose original music and create soundscapes for film, games, and other interactive media. My sound design work adds depth and atmosphere, enhancing the emotional impact of your project and creating a more immersive experience for your audience.
          </p>
        </div>
      </div>
    </div>
    <div class="projects-overview">
      <div class="projects-header">
        <h2 class="projects-title">Selected Projects</h2>
        <p class="projects-intro">
          Here are a few examples of my work that highlight my skills in design, development, and sound. Each project represents a unique challenge and a collaborative effort to bring a creative vision to life.
        </p>
      </div>
      <div class="projects-grid">
        <div class="project-card">
          <img src="https://placehold.co/400x250/E6EDF3/161B22?text=Project+1" alt="Placeholder image for Project 1" class="project-image">
          <div class="project-info">
            <h3 class="project-title">Ethereal Echoes Soundscapes</h3>
            <p class="project-description">
              A sound design project for a mobile game, focusing on creating immersive and atmospheric audio that changes dynamically with player actions.
            </p>
            <a href="/creations/project-1" class="project-cta">View Project</a>
          </div>
        </div>
        <div class="project-card">
          <img src="https://placehold.co/400x250/E6EDF3/161B22?text=Project+2" alt="Placeholder image for Project 2" class="project-image">
          <div class="project-info">
            <h3 class="project-title">Nexus UI Redesign</h3>
            <p class="project-description">
              A complete UI/UX overhaul for a data analytics dashboard, improving user flow and visual clarity with a modern, responsive design.
            </p>
            <a href="/creations/project-2" class="project-cta">View Project</a>
          </div>
        </div>
        <div class="project-card">
          <img src="https://placehold.co/400x250/E6EDF3/161B22?text=Project+3" alt="Placeholder image for Project 3" class="project-image">
          <div class="project-info">
            <h3 class="project-title">Starlight Cafe Branding</h3>
            <p class="project-description">
              Full brand identity package, including logo design, custom illustrations, and a style guide for a new local coffee shop.
            </p>
            <a href="/creations/project-3" class="project-cta">View Project</a>
          </div>
        </div>
      </div>
    </div>
    <div class="blog-overview">
      <div class="blog-header">
        <h2 class="blog-title">Latest Thoughts</h2>
        <p class="blog-intro">
          Dive into my latest articles and reviews on design, technology, and the creative process. Here, I share insights, tutorials, and my perspective on the ever-evolving digital world.
        </p>
      </div>
      <div class="blog-grid">
        <div class="blog-post-card">
          <img src="https://placehold.co/400x250/161B22/E6EDF3?text=Article+1" alt="Placeholder image for blog post 1" class="blog-post-image">
          <div class="blog-post-info">
            <h3 class="blog-post-title">The Art of Minimalist UI Design</h3>
            <p class="blog-post-description">
              An exploration of the principles behind minimalist user interfaces and how they can improve user experience without sacrificing functionality.
            </p>
            <a href="/blog/post-1" class="blog-post-cta">Read More</a>
          </div>
        </div>
        <div class="blog-post-card">
          <img src="https://placehold.co/400x250/161B22/E6EDF3?text=Article+2" alt="Placeholder image for blog post 2" class="blog-post-image">
          <div class="blog-post-info">
            <h3 class="blog-post-title">Review: The Latest in DAW Software</h3>
            <p class="blog-post-description">
              A hands-on review of the newest digital audio workstation software, breaking down its features, pros, and cons for sound designers and musicians.
            </p>
            <a href="/blog/post-2" class="blog-post-cta">Read More</a>
          </div>
        </div>
        <div class="blog-post-card">
          <img src="https://placehold.co/400x250/161B22/E6EDF3?text=Article+3" alt="Placeholder image for blog post 3" class="blog-post-image">
          <div class="blog-post-info">
            <h3 class="blog-post-title">Composing for Games: A Beginner's Guide</h3>
            <p class="blog-post-description">
              A step-by-step guide for aspiring composers looking to get into the world of video game music, covering everything from theory to implementation.
            </p>
            <a href="/blog/post-3" class="blog-post-cta">Read More</a>
          </div>
        </div>
      </div>
    </div>
    <div class="newsletter-signup-section">
      <div class="newsletter-content">
        <h2 class="newsletter-title">Stay up to date with my latest creations and insights.</h2>
        <p class="newsletter-subtitle">
          Sign up for my newsletter to get exclusive access to new projects, behind-the-scenes content, and articles on design and creative technology delivered directly to your inbox.
        </p>
        <form class="newsletter-form" action="/subscribe" method="post">
          <input type="email" name="email" placeholder="Enter your email address" required>
          <button type="submit">Subscribe</button>
        </form>
      </div>
    </div>
  </main>
</Layout>

<style>
  .main-nav-bar {
    background-color: #333;
    color: white;
    padding: 1rem 0;
  }
  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 2rem;
  }
  .nav-logo {
    font-size: 1.5rem;
    font-weight: bold;
    color: white;
    text-decoration: none;
  }
  .nav-links {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 1rem;
  }
  .nav-links a {
    color: white;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .nav-links a:hover {
    color: #ccc;
  }
  .hero {
    background-color: #2d3748;
    color: white;
    padding: 4rem 2rem;
    text-align: center;
  }
  .hero-container {
    max-width: 800px;
    margin: 0 auto;
  }
  .hero-title {
    font-size: 3rem;
    font-weight: bold;
    margin-bottom: 1rem;
  }
  .hero-subtitle {
    font-size: 1.25rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }
  .hero-cta {
    display: inline-block;
    background-color: #4299e1;
    color: white;
    padding: 0.75rem 2rem;
    border-radius: 9999px;
    text-decoration: none;
    font-weight: bold;
    transition: background-color 0.3s ease;
  }
  .hero-cta:hover {
    background-color: #3182ce;
  }
  .profile-card-section {
    background-color: #f0f0f0;
    padding: 4rem 2rem;
    text-align: center;
  }
  .profile-card {
    max-width: 800px;
    margin: 0 auto;
    background-color: white;
    padding: 2rem;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }
  .profile-picture {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 1rem;
  }
  .profile-card h3 {
    font-size: 2rem;
    font-weight: bold;
    margin-bottom: 1rem;
  }
  .profile-card blockquote {
    font-style: italic;
    color: #555;
    margin: 0;
  }
  .content {
    padding: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .services-overview {
    padding: 4rem 0;
    text-align: center;
  }

  .services-header {
    margin-bottom: 3rem;
  }

  .services-title {
    font-size: 2.5rem;
    font-weight: bold;
    margin-bottom: 1rem;
  }

  .services-intro {
    font-size: 1.15rem;
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .service-card {
    background-color: #f9f9f9;
    padding: 2rem;
    border-radius: 8px;
    text-align: left;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .service-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 15px rgba(0, 0, 0, 0.1);
  }

  .service-title {
    font-size: 1.5rem;
    font-weight: bold;
    margin-bottom: 0.5rem;
  }

