---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    border-radius: 8px;
    background-color: var(--color-bg);
    margin-bottom: 2rem;
  }
  .file-explorer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 2rem;
    border-bottom: 1px solid var(--color-border);
    gap: 1rem;
  }
  .explorer-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-heading);
    flex-shrink: 0;
    margin: 0;
  }
  .explorer-title::before {
    content: none;
  }
  .explorer-search-form {
    display: flex;
    align-items: center;
    flex-grow: 1;
    position: relative;
  }
  .explorer-search-form .search-input {
    width: 100%;
    padding-right: 2.5rem;
  }
  .explorer-search-form .search-button {
    position: absolute;
    right: 0.5rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: var(--color-text-light);
    cursor: pointer;
    padding: 0;
  }
  .file-explorer-content {
    padding: 2rem;
  }
  .explorer-placeholder {
    margin: 0;
    color: var(--color-text-light);
  }
  .file-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .file-list li {
    border-bottom: 1px solid var(--color-border);
  }
  .file-list li:last-child {
    border-bottom: none;
  }
  .file-list a {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0;
    color: var(--color-text);
    transition: color 0.2s ease, background-color 0.2s ease;
  }
  .file-list a:hover {
    color: var(--color-accent);
    background-color: rgba(61, 135, 166, 0.05);
    text-decoration: none;
  }
  .file-list svg {
    flex-shrink: 0;
    fill: currentColor;
  }
  .file-size-date {
    margin-left: auto;
    font-size: 0.8rem;
    color: var(--color-text-light);
  }
  .file-view-button {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-text-light);
    background-color: transparent;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.25rem 0.5rem;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    margin-left: 1rem;
  }
  .file-view-button:hover {
    background-color: var(--color-accent);
    color: var(--color-bg);
    border-color: var(--color-accent);
  }

  /* --- Dashboard Section --- */
  .dashboard-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }
  .dashboard-card {
    display: flex;
    align-items: center;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
  }
  .card-icon {
    font-size: 2.5rem;
    line-height: 1;
    margin-right: 1.5rem;
  }
  .card-value {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1;
    color: var(--color-accent);
  }
  .card-label {
    font-size: 0.9rem;
    color: var(--color-text-light);
    text-transform: uppercase;
    margin-top: 0.5rem;
  }
  .card-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  
  /* --- Unified Card Grid System --- */
  .card-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }
  .card {
    position: relative;
    display: block;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: inherit;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    overflow: hidden;
  }
  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
    border-color: var(--color-accent);
    text-decoration: none;
  }
  .card-image {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    background-color: var(--color-bg);
  }
  .card-info { padding: 1rem 1.25rem 2.5rem 1.25rem; }
  .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; }
  .card-header h4 { font-size: 1.1em; font-weight: 700; color: var(--color-heading); }
  .card-info p { font-size: 0.9em; color: var(--color-text-light); line-height: 1.6; margin: 0; }
  .post-date { font-size: 0.8em; color: var(--color-text-light); margin-top: 0.75rem; }
  .card-arrow {
    position: absolute;
    bottom: 0.75rem;
    right: 1rem;
    font-size: 1.75rem;
    color: var(--color-text-light);
    transition: transform 0.2s ease, color 0.2s ease;
    line-height: 1;
  }
  .card:hover .card-arrow {
    transform: translateX(5px);
    color: var(--color-accent);
  }
  .tag {
    background-color: var(--color-tag-bg); padding: 0.2em 0.5em;
    border-radius: 6px; font-size: 0.85em; color: var(--color-accent);
    flex-shrink: 0; margin-left: 0.5rem;
  }
  .view-all-container { text-align: center; margin-top: 2rem; }
  .view-all-button {
    display: flex;
    width: 100%;
    background-color: transparent; border: 1px solid var(--color-border);
    color: var(--color-accent);
  }
  .view-all-button:hover { background-color: var(--color-tag-bg); border-color: var(--color-accent); }
  .services-button {
    background: linear-gradient(to right, #65B5B8, #4D8B8E 50%, #65B5B8 50%); /* Retro Teal */
    background-size: 200% 100%;
    background-position: left bottom;
    color: white;
    border: 1px solid #65B5B8;
    transition: background-position 0.4s ease, color 0.4s ease;
  }
  .services-button:hover {
    background-position: right bottom;
    color: #3B2F2A; /* Dark text on hover */
  }
  .services-button svg {
    color: white;
    transition: color 0.4s ease;
  }
  .services-button:hover svg {
    color: #3B2F2A;
  }
  .projects-button {
    background: linear-gradient(to right, #F4A261, #E8A155 50%, #F4A261 50%); /* Faded Orange */
    background-size: 200% 100%;
    background-position: left bottom;
    color: white;
    border: 1px solid #F4A261;
    transition: background-position 0.4s ease, color 0.4s ease;
  }
  .projects-button:hover {
    background-position: right bottom;
    color: #3B2F2A;
  }
  .projects-button svg {
    color: white;
    transition: color 0.4s ease;
  }
  .projects-button:hover svg {
    color: #3B2F2A;
  }
  .blog-button {
    background: linear-gradient(to right, #B58866, #A07F5B 50%, #B58866 50%); /* Muted brown */
    background-size: 200% 100%;
    background-position: left bottom;
    color: white;
    border: 1px solid #B58866;
    transition: background-position 0.4s ease, color 0.4s ease;
  }
  .blog-button:hover {
    background-position: right bottom;
    color: #3B2F2A;
  }
  .blog-button svg {
    color: white;
    transition: color 0.4s ease;
  }
  .blog-button:hover svg {
    color: #3B2F2A;
  }
  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background-color: #E07A5F; /* Main CTA button color, terracotta */
    color: #F0EAD6;
    border: 1px solid #E07A5F;
    border-radius: 6px;
    padding: 0.75rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }
  .cta-button:hover {
    background-color: #D36C52;
  }

  /* --- Card Type: Service --- */
