---
import Layout from '../layouts/Layout.astro';
---

<Layout title="John Ogletree">
  <div class="viewsource-container">
    <header class="browser-header">
      <div class="browser-controls">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
      </div>
      <div class="browser-address">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="2" y1="12" x2="22" y2="12"></line>
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
        </svg>
        <div class="address-bar">
          <span class="url-text">http://johnogletree.website/index.astro</span>
        </div>
      </div>
    </header>

    <main class="viewsource-body">
      <pre><code><span class="comment">&lt;!-- 
  Welcome to my digital space!
  It's great to see you here. Take a look around.
  
  This portfolio is a single-page app, built with a component-based philosophy.
  Each section is imported and rendered below.
--&gt;</span>
<span class="tag">
  <span class="tag-name">import</span> <span class="tag-func-name">{</span> <span class="tag-var-name">Profile</span> <span class="tag-func-name">}</span> <span class="tag-name">from</span> <span class="tag-string">"astro:components";</span>
  <span class="tag-name">import</span> <span class="tag-func-name">{</span> <span class="tag-var-name">ProjectsList</span> <span class="tag-func-name">}</span> <span class="tag-name">from</span> <span class="tag-string">"astro:components";</span>
  <span class="tag-name">import</span> <span class="tag-func-name">{</span> <span class="tag-var-name">ContactForm</span> <span class="tag-func-name">}</span> <span class="tag-name">from</span> <span class="tag-string">"astro:components";</span>
</span>

<span class="tag">&lt;!DOCTYPE html&gt;</span>
<span class="tag">&lt;html <span class="attr-name">lang</span>=<span class="attr-value">"en"</span>&gt;</span>
  <span class="tag">&lt;head&gt;</span>
    <span class="tag">&lt;title&gt;</span>John Ogletree - Digital Artist & Designer<span class="tag">&lt;/title&gt;</span>
  <span class="tag">&lt;/head&gt;</span>
  <span class="tag">&lt;body&gt;</span>
    
    <span class="comment">&lt;!-- Let's render the main profile content --&gt;</span>
    <span class="tag">&lt;<span class="tag-open-name">Profile</span> 
      <span class="tag-attr">name</span>=<span class="tag-value">"John Ogletree"</span>
      <span class="tag-attr">title</span>=<span class="tag-value">"Digital Artist & Designer"</span>
      <span class="tag-attr">bio</span>=<span class="tag-value">"Hello! I'm John, a multidisciplinary creative with a passion for bringing ideas to life through design and art."</span>
    /&gt;</span>

    <span class="comment">&lt;!-- Next up, a list of projects --&gt;</span>
    <span class="tag">&lt;<span class="tag-open-name">ProjectsList</span> 
      <span class="tag-attr">projects</span>=<span class="tag-list">[</span>
        <span class="tag-object-prop">{ <span class="tag-attr">name</span>=<span class="tag-value">"Chrono Corp"</span>, <span class="tag-attr">tech</span>=<span class="tag-value">"UI/UX Design"</span> },</span>
        <span class="tag-object-prop">{ <span class="tag-attr">name</span>=<span class="tag-value">"Aether Systems"</span>, <span class="tag-attr">tech</span>=<span class="tag-value">"Brand Identity"</span> },</span>
        <span class="tag-object-prop">{ <span class="tag-attr">name</span>=<span class="tag-value">"Echo"</span>, <span class="tag-attr">tech</span>=<span class="tag-value">"Web Development"</span> },</span>
      <span class="tag-list">]</span>
    /&gt;</span>

    <span class="comment">&lt;!-- Let's connect! --&gt;</span>
    <span class="tag">&lt;<span class="tag-open-name">ContactForm</span> /&gt;</span>

  <span class="tag">&lt;/body&gt;</span>
<span class="tag">&lt;/html&gt;</span>
</code></pre>
    </main>
  </div>
</Layout>

<style>
  :root {
    --bg-color: #1e1e1e;
    --text-color: #f8f8f2;
    --primary-color: #50fa7b;
    --secondary-color: #ff79c6;
    --accent-color: #8be9fd;
    --comment-color: #6272a4;
    --tag-color: #ff5555;
    --attr-name-color: #50fa7b;
    --attr-value-color: #f1fa8c;
    --font-mono: 'Fira Code', 'Monaco', 'Consolas', monospace;
    --browser-bar-color: #282a36;
  }

  body {
    background-color: var(--bg-color);
    color: var(--text-color);
    font-family: var(--font-mono);
  }

  .viewsource-container {
    width: 100%;
    max-width: 900px;
    margin: 2rem auto;
    border: 1px solid var(--browser-bar-color);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
  }
  
  .browser-header {
    display: flex;
    align-items: center;
    padding: 0.5rem 1rem;
    background-color: var(--browser-bar-color);
    border-bottom: 1px solid var(--bg-color);
  }

  .browser-controls {
    display: flex;
    gap: 0.5rem;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot.red { background-color: #ff5f56; }
  .dot.yellow { background-color: #ffbd2e; }
  .dot.green { background-color: #27c93f; }

  .browser-address {
    display: flex;
    align-items: center;
    flex-grow: 1;
    background-color: var(--bg-color);
    border-radius: 4px;
    padding: 0.25rem 0.5rem;
    margin-left: 1rem;
  }

  .address-bar svg {
    width: 16px;
    height: 16px;
    margin-right: 0.5rem;
    color: var(--comment-color);
  }
  
  .url-text {
    color: var(--text-color);
    font-size: 0.9rem;
  }

  .viewsource-body {
    background-color: var(--bg-color);
    padding: 2rem;
    overflow-x: auto;
    white-space: pre;
  }

  pre {
    margin: 0;
    color: var(--text-color);
    font-size: 1rem;
    line-height: 1.4;
  }

  /* Syntax Highlighting with a friendly tone */
  .comment { color: var(--comment-color); font-style: italic; }
  .tag { color: var(--tag-color); }
  .tag-name { color: var(--tag-color); font-weight: bold; }
  .tag-open-name { color: var(--primary-color); font-weight: bold; }
  .tag-close-name { color: var(--primary-color); font-weight: bold; }
  .tag-attr { color: var(--attr-name-color); }
  .tag-value { color: var(--attr-value-color); }
  .tag-list { color: var(--text-color); }
  .tag-object-prop { color: var(--secondary-color); }
  .tag-string { color: var(--attr-value-color); }
</style>