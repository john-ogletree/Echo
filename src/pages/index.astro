---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <div class="readme-container">
        <header class="readme-header">
            <div class="header-right">
                <div class="nav-drawer-container" id="nav-drawer-container">
                    <nav class="main-nav" id="main-nav">
                        <div class="nav-header-mobile">
                            <button class="nav-close" aria-label="Close navigation">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="18" y1="6" x2="6" y2="18"></line>
                                    <line x1="6" y1="6" x2="18" y2="18"></line>
                                </svg>
                            </button>
                            <form class="search-form mobile-search" action="/directory" method="get">
                                <input type="search" name="q" class="search-input" placeholder="Search...">
                            </form>
                        </div>
                        <ul class="nav-links">
                            <li><a href="/"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M8.707 1.5a1 1 0 0 0-1.414 0L.646 8.146a.5.5 0 0 0 .708.708L8 2.207l6.646 6.647a.5.5 0 0 0 .708-.708L8.707 1.5Z"/><path d="M2.5 12.5a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5Z"/></svg><span>Start</span></a></li>
                            <li><a href="/bio/index"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/><path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z"/></svg><span>Profile</span></a></li>
                            <li><a href="/services/index"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-8.5-3.5a.5.5 0 0 0-1 0v3h-2a.5.5 0 0 0 0 1h3a.5.5 0 0 0 .5-.5v-4z"/></svg><span>Capabilities</span></a></li>
                            <li><a href="/projects/index"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M10.82 2.525a.75.75 0 0 1 .917.069l3.528 3.176a.75.75 0 0 1 0 1.104l-3.528 3.176a.75.75 0 0 1-.917-.07L7.828 7.375a.75.75 0 0 1 0-1.104l3-2.7zM6.82 2.525a.75.75 0 0 1 .917.069l3.528 3.176a.75.75 0 0 1 0 1.104l-3-2.7z"/></svg><span>Creations</span></a></li>
                            <li><a href="/thoughts/index"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M12.5 16h-9A1.5 1.5 0 0 1 2 14.5v-13A1.5 1.5 0 0 1 3.5 0h9A1.5 1.5 0 0 1 14 1.5v13a1.5 1.5 0 0 1-1.5 1.5zM3 14.5a.5.5 0 0 0 .5.5h9a.5.5 0 0 0 .5-.5v-13a.5.5 0 0 0-.5-.5h-9a.5.5 0 0 0-.5.5v13z"/><path d="M5.5 2.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1 0-1zM4 6h8a.5.5 0 0 1 0 1H4a.5.5 0 0 1 0-1zm0 3h8a.5.5 0 0 1 0 1H4a.5.5 0 0 1 0-1zm0 3h8a.5.5 0 0 1 0 1H4a.5.5 0 0 1 0-1z"/></svg><span>Log</span></a></li>
                            <li><a href="/resume/index"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M14.5 3a.5.5 0 0 1 .5.5v9a.5.5 0 0 1-.5.5h-13a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h13zM14 4H2v8h12V4z"/><path d="M7 6h2v2H7z"/></svg><span>Credentials</span></a></li>
                            <li><a href="/forms/index"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M14.5 3a.5.5 0 0 1 .5.5v9a.5.5 0 0 1-.5.5h-13a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h13zM14 4H2v8h12V4z"/><path d="M7 6h2v2H7z"/></svg><span>Connect</span></a></li>
                            <li><a href="/directory/index"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M.5 1a.5.5 0 0 0-.5.5v12a.5.5 0 0 0 .5.5h12a.5.5 0 0 0 .5-.5v-12a.5.5 0 0 0-.5-.5h-12zM12 1H.5a.5.5 0 0 0-.5.5v13a.5.5 0 0 0 .5.5h13a.5.5 0 0 0 .5-.5V1.5a.5.5 0 0 0-.5-.5H12z"/><path d="M4.5 12.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5zM3 10.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5zM3 8.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5zM3 6.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5zM3 4.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5z"/></svg><span>Explorer</span></a></li>
                        </ul>
                        <ul class="nav-socials">
                            <li><a href="https://github.com/john-ogletree" aria-label="GitHub Profile">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
                            </a></li>
                            <li><a href="https://www.linkedin.com/in/john-ogletree-6b8773379/" aria-label="LinkedIn Profile">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
                            </a></li>
                            <li><a href="https://dribbble.com/john-ogletree" aria-label="Dribbble Profile">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M8.56 2.75c4.37 6.03 6.02 9.42 8.03 17.72m2.54-15.38c-3.72 4.35-8.94 4.66-16.88 7.02"></path><path d="M2.75 8.56c3.12-1.64 8.7-2.73 17.72-2.26"></path></svg>
                            </a></li>
                        </ul>
                    </nav>
                </div>
                <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path class="line-1" d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>
            </div>
            <div class="header-left">
                <div class="repo-title">
                    <svg class="icon-repo" viewBox="0 0 16 16" version="1.1" width="16" height="16" aria-hidden="true"><path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 0 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Z"></path></svg>
                    <a href="/" class="font-bold">john-ogletree/Echo</a>
                </div>
            </div>
        </header>

        <main class="readme-body">
            <footer class="readme-footer retro-footer">
                <div class="footer-grid-retro">
                    <div class="footer-column-retro">
                        <h4>John Ogletree <span class="badge status">status: available for hire</span></h4>
                        <p class="footer-tagline">Digital Artist & Designer based in Martinez, GA.</p>
                    </div>
                    <hr class="retro-hr" />
                    <div class="footer-column-retro-explore">
                        <h4>Explore</h4>
                        <ul class="footer-links-retro">
                            <li><a href="/directory/index">Directory</a></li>
                            <li><a href="/bio/index">About</a></li>
                            <li><a href="/services/index">Services</a></li>
                            <li><a href="/projects/index">Projects</a></li>
                            <li><a href="/thoughts/index">Log</a></li>
                            <li><a href="/resume/index">Résumé</a></li>
                            <li><a href="/forms/index">Contact</a></li>
                        </ul>
                    </div>
                    <hr class="retro-hr" />
                    <div class="footer-column-retro-connect">
                        <h4>Connect</h4>
                        <ul class="footer-socials-retro">
                            <li><a href="https://github.com/john-ogletree" aria-label="GitHub Profile">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
                            </a></li>
                            <li><a href="https://www.linkedin.com/in/john-ogletree-6b8773379/" aria-label="LinkedIn Profile">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
                            </a></li>
                            <li><a href="https://dribbble.com/john-ogletree" aria-label="Dribbble Profile">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M8.56 2.75c4.37 6.03 6.02 9.42 8.03 17.72m2.54-15.38c-3.72 4.35-8.94 4.66-16.88 7.02"></path><path d="M2.75 8.56c3.12-1.64 8.7-2.73 17.72-2.26"></path></svg>
                            </a></li>
                        </ul>
                    </div>
                    <div class="footer-bottom-bar retro-bottom">
                        <p>© <span id="year"></span> John Ogletree</p>
                        <a href="#" class="back-to-top">Back to top ↑</a>
                    </div>
                </div>
            </footer>
        </main>
    </div>
</Layout>

<script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
        const navToggle = document.getElementById('nav-toggle');
        const navDrawer = document.getElementById('nav-drawer-container');
        const navClose = document.querySelector('.nav-close');
        const body = document.body;
        function toggleMobileNav() {
            const isOpen = navDrawer.classList.contains('is-open');
            navDrawer.classList.toggle('is-open', !isOpen);
            navToggle.setAttribute('aria-expanded', !isOpen);
            body.classList.toggle('no-scroll', !isOpen);
        }

        if (navToggle && navDrawer) {
            navToggle.addEventListener('click', toggleMobileNav);
            navClose.addEventListener('click', toggleMobileNav);
        }

        const navLinks = document.querySelectorAll('.nav-links a');
        navLinks.forEach(link => {
            link.addEventListener('click', () => {
                if (navDrawer.classList.contains('is-open')) {
                    toggleMobileNav();
                }
            });
        });
        const yearSpan = document.getElementById('year');
        if (yearSpan) {
            yearSpan.textContent = new Date().getFullYear();
        }
    });
</script>

<style>
    @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;700&display=swap');

    :root {
        --color-bg: #F0EAD6; /* Light cream */
        --color-surface: #D4C9A8; /* Muted beige */
        --color-text: #3B2F2A; /* Deep brown-black */
        --color-text-light: #5B4F48; /* Dark brown-grey */
        --color-heading: #E07A5F; /* Warm terracotta orange */
        --color-accent: #3D87A6; /* Retro teal */
        --color-border: #A69E8C; /* Faded grey-brown */
        --color-tag-bg: rgba(61, 135, 166, 0.15); /* Faded teal transparency */
        --font-mono: 'IBM Plex Mono', Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        --padding-x: 2rem;
    }

    /* --- Base & Typography --- */
    html {
        scroll-behavior: smooth;
        scroll-padding-top: 80px;
    }
    body {
        background-color: var(--color-bg);
        color: var(--color-text);
        font-family: var(--font-mono);
        font-size: 16px;
        line-height: 1.7;
        margin: 0;
        padding: 0;
        transition: transform 0.3s ease-in-out;
    }
    body.no-scroll {
        overflow: hidden;
    }
    body.no-scroll .readme-body {
        filter: blur(5px);
        pointer-events: none;
    }
    h1, h2, h3, h4 {
        font-family: var(--font-mono);
        font-weight: 500;
        color: var(--color-heading);
        margin: 0;
    }
    h2 { font-size: 1.5rem; border-bottom: 1px solid var(--color-border); padding-bottom: 0.5rem; margin: 2.5rem 0 1rem 0;
    }
    h2::before {
        content: '##';
        color: var(--color-text-light);
        font-weight: 400;
        margin-right: 0.5rem;
    }
    p { margin: 0 0 1rem 0; max-width: 80ch; }
    a { color: var(--color-accent); text-decoration: none;
    }
    a:hover { text-decoration: underline; }
    hr { display: none; }
    ul { list-style: '- ';
    padding-left: 1.5rem; margin-bottom: 1rem;}
    blockquote {
        margin-left: 0;
        padding-left: 1rem;
        border-left: 3px solid var(--color-border);
        color: var(--color-text-light);
    }

    /* --- Main Layout --- */
    .readme-container {
        background-color: var(--color-surface);
    }
    .readme-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1rem var(--padding-x);
        border-bottom: 1px solid var(--color-border);
        position: sticky;
        top: 0;
        z-index: 10;
        background-color: var(--color-surface);
    }
    .header-left, .header-right {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .repo-title {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 1.25rem;
    }
    .icon-repo {
        fill: var(--color-text-light);
    }
    .readme-body {
        padding: 2rem var(--padding-x);
        transition: filter 0.3s ease-in-out;
    }

    /* --- Header Search --- */
    .search-form { position: relative;
    }
    .search-input {
        background-color: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: 6px;
        padding: 0.4rem 2rem 0.4rem 0.75rem;
        font-family: var(--font-mono);
        font-size: 0.9rem;
        color: var(--color-text);
        width: 180px;
    }
    .search-input:focus {
        outline: none;
        border-color: var(--color-accent);
        box-shadow: 0 0 0 3px rgba(61, 135, 166, 0.3);
    }
    .mobile-search { display: block;
    }
    .desktop-search { display: none; }

    /* --- Header / Nav --- */
    .nav-links {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        list-style: none;
        margin: 0;
        padding: 2rem 1.5rem;
        flex-grow: 1;
        overflow-y: auto;
    }
    .nav-links a {
        position: relative;
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 1.1rem;
        font-weight: 500;
        padding: 0.5rem 0;
        border-bottom: 1px solid var(--color-border);
        color: var(--color-text);
        transition: color 0.2s ease, transform 0.2s ease;
    }
    
    /* Hover, Active, and Current Link States */
    .nav-links a:hover {
        color: var(--color-accent);
        text-decoration: none;
        transform: translateX(5px);
    }
    .nav-links a.current-page {
        color: var(--color-heading);
    }
    .nav-links a.current-page::before,
    .nav-links a:hover::before {
        content: '';
        position: absolute;
        left: -1rem;
        height: 100%;
        width: 4px;
        background-color: var(--color-accent);
        border-radius: 2px;
    }
    .nav-links a:active {
        transform: scale(0.98);
    }
    .nav-links a span {
        flex-grow: 1;
    }
    .nav-links a svg {
        flex-shrink: 0;
    }
    
    .nav-toggle,
    .nav-close {
        background: none;
        border: none;
        color: var(--color-text);
        padding: 0.5rem;
        cursor: pointer;
        z-index: 100;
    }
    
    .nav-close {
        display: none;
    }

    /* When nav is open, swap the icons */
    .nav-drawer-container.is-open ~ .nav-toggle {
        display: none;
    }

    .nav-drawer-container .nav-close {
        display: none;
    }
    
    .nav-drawer-container.is-open .nav-close {
        display: block;
    }

    /* The drawer slides from the left */
    .nav-drawer-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 300px;
        height: 100vh;
        background-color: var(--color-surface);
        border-right: 1px solid var(--color-border);
        transform: translateX(-100%);
        transition: transform 0.3s ease-in-out;
        z-index: 99;
        box-shadow: 4px 0 16px rgba(0, 0, 0, 0.5);
    }
    .nav-drawer-container.is-open {
        transform: translateX(0);
    }
    
    .main-nav {
        display: flex;
        flex-direction: column;
        height: 100%;
        padding: 0;
    }

    .nav-header-mobile {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.5rem 1.5rem 1rem 1.5rem;
        border-bottom: 1px solid var(--color-border);
        flex-shrink: 0;
    }

    .nav-header-mobile .mobile-search {
        flex-grow: 1;
    }

    .nav-socials {
        list-style: none;
        padding: 1.5rem;
        border-top: 1px solid var(--color-border);
        display: flex;
        justify-content: center;
        gap: 2rem;
        flex-shrink: 0;
    }
    .nav-socials a { color: var(--color-text-light); }
    .nav-socials a:hover { color: var(--color-accent);
    }
    .nav-socials svg { width: 24px; height: 24px; }
    
    /* --- Branded HR Separator --- */
    .branded-hr {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin: 4rem 0;
    }
    .branded-hr .line {
        flex-grow: 1;
        height: 1px;
        background-color: var(--color-border);
    }
    .branded-hr .icon-repo {
        fill: var(--color-text-light);
        flex-shrink: 0;
    }

    /* --- Unified Card Grid System --- */
    .card-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-top: 1.5rem;
    }
    .card {
        position: relative;
        display: block;
        background-color: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        color: inherit;
        text-decoration: none;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        overflow: hidden;
    }
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
        border-color: var(--color-accent);
        text-decoration: none;
    }
    .card-image {
        width: 100%;
        height: auto;
        aspect-ratio: 16 / 9;
        object-fit: cover;
        display: block;
        background-color: var(--color-bg);
    }
    .card-info { padding: 1rem 1.25rem 2.5rem 1.25rem;
    }
    .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; }
    .card-header h4 { font-size: 1.1em;
    font-weight: 700; color: var(--color-heading); }
    .card-info p { font-size: 0.9em; color: var(--color-text-light); line-height: 1.6; margin: 0;
    }
    .post-date { font-size: 0.8em; color: var(--color-text-light); margin-top: 0.75rem; }
    .card-arrow {
        position: absolute;
        bottom: 0.75rem;
        right: 1rem;
        font-size: 1.75rem;
        color: var(--color-text-light);
        transition: transform 0.2s ease, color 0.2s ease;
    }
    .card:hover .card-arrow { transform: translateX(5px); color: var(--color-accent); }
    .tag {
        background-color: var(--color-tag-bg);
        padding: 0.2em 0.5em;
