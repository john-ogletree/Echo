    font-size: 1rem;
    border-radius: 9999px;
    border: none;
    width: 100%;
    max-width: 400px;
  }
  
  .newsletter-form button {
    padding: 0.75rem 2rem;
    font-size: 1rem;
    border-radius: 9999px;
    border: none;
    background-color: #4299e1;
    color: white;
