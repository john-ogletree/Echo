---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  
    <div class="bg-surface min-h-screen">
    <header class="flex justify-between items-center gap-4 py-4 px-8 border-b border-border fixed top-0 w-full z-10 bg-surface">
      <div class="flex items-center gap-4">
        <div class="flex items-center gap-2 text-xl md:text-2xl font-semibold">
          <svg class="w-4 h-4 fill-text-light" viewBox="0 0 16 16" version="1.1" aria-hidden="true"><path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 0 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Z"></path></svg>
          <a href="/" class="text-text font-bold">john-ogletree/Echo</a>
        </div>
      </div>
      <div class="flex items-center gap-4">
        <div class="hidden md:flex items-center space-x-6">
          <ul class="flex flex-row space-x-6 list-none p-0 m-0">
            <li><a href="/" class="flex items-center space-x-2 text-text font-medium py-2 border-b-2 border-transparent hover:text-accent hover:border-accent">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M8.707 1.5a1 1 0 0 0-1.414 0L.646 8.146a.5.5 0 0 0 .708.708L8 2.207l6.646 6.647a.5.5 0 0 0 .708-.708L8.707 1.5Z"/><path d="M2.5 12.5a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5Z"/></svg>
              <span>Start</span>
            </a></li>
            <li><a href="/profile" class="flex items-center space-x-2 text-text font-medium py-2 border-b-2 border-transparent hover:text-accent hover:border-accent">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/><path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z"/></svg>
              <span>Profile</span>
            </a></li>
            <li><a href="/capabilities" class="flex items-center space-x-2 text-text font-medium py-2 border-b-2 border-transparent hover:text-accent hover:border-accent">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-8.5-3.5a.5.5 0 0 0-1 0v3h-2a.5.5 0 0 0 0 1h3a.5.5 0 0 0 .5-.5v-4z"/></svg>
              <span>Capabilities</span>
            </a></li>
            <li><a href="/creations" class="flex items-center space-x-2 text-text font-medium py-2 border-b-2 border-transparent hover:text-accent hover:border-accent">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M10.82 2.525a.75.75 0 0 1 .917.069l3.528 3.176a.75.75 0 0 1 0 1.104l-3.528 3.176a.75.75 0 0 1-.917-.07L7.828 7.375a.75.75 0 0 1 0-1.104l3-2.7zM6.82 2.525a.75.75 0 0 1 .917.069l3.528 3.176a.75.75 0 0 1 0 1.104l-3-2.7zM6.82 2.525a.75.75 0 0 1 .917.069l3.528 3.176a.75.75 0 0 1 0 1.104l-3.528 3.176a.75.75 0 0 1-.917-.07L3.828 7.375a.75.75 0 0 1 0-1.104l3-2.7z"/></svg>
              <span>Creations</span>
            </a></li>
            <li><a href="/log" class="flex items-center space-x-2 text-text font-medium py-2 border-b-2 border-transparent hover:text-accent hover:border-accent">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M12.5 16h-9A1.5 1.5 0 0 1 2 14.5v-13A1.5 1.5 0 0 1 3.5 0h9A1.5 1.5 0 0 1 14 1.5v13a1.5 1.5 0 0 1-1.5 1.5zM3 14.5a.5.5 0 0 0 .5.5h9a.5.5 0 0 0 .5-.5v-13a.5.5 0 0 0-.5-.5h-9a.5.5 0 0 0-.5.5v13z"/><path d="M5.5 2.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1 0-1zM4 6h8a.5.5 0 0 1 0 1H4a.5.5 0 0 1 0-1zm0 3h8a.5.5 0 0 1 0 1H4a.5.5 0 0 1 0-1zm0 3h8a.5.5 0 0 1 0 1H4a.5.5 0 0 1 0-1z"/></svg>
              <span>Log</span>
            </a></li>
            <li><a href="/credentials" class="flex items-center space-x-2 text-text font-medium py-2 border-b-2 border-transparent hover:text-accent hover:border-accent">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M14.5 3a.5.5 0 0 1 .5.5v9a.5.5 0 0 1-.5.5h-13a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h13zM14 4H2v8h12V4z"/><path d="M7 6h2v2H7z"/></svg>
              <span>Credentials</span>
            </a></li>
            <li><a href="/connect" class="flex items-center space-x-2 text-text font-medium py-2 border-b-2 border-transparent hover:text-accent hover:border-accent">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M14.5 3a.5.5 0 0 1 .5.5v9a.5.5 0 0 1-.5.5h-13a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h13zM14 4H2v8h12V4z"/><path d="M7 6h2v2H7z"/></svg>
              <span>Connect</span>
            </a></li>
            <li><a href="/explorer" class="flex items-center space-x-2 text-text font-medium py-2 border-b-2 border-transparent hover:text-accent hover:border-accent">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M.5 1a.5.5 0 0 0-.5.5v12a.5.5 0 0 0 .5.5h12a.5.5 0 0 0 .5-.5v-12a.5.5 0 0 0-.5-.5h-12zM12 1H.5a.5.5 0 0 0-.5.5v13a.5.5 0 0 0 .5.5h13a.5.5 0 0 0 .5-.5V1.5a.5.5 0 0 0-.5-.5H12z"/><path d="M4.5 12.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5zM3 10.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5zM3 8.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5zM3 6.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5zM3 4.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5z"/></svg>
              <span>Explorer</span>
            </a></li>
          </ul>
        </div>
        <button class="md:hidden p-2 rounded-md hover:bg-bg" aria-label="Toggle navigation" aria-expanded="false">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path class="line-1" d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </header>

    <main class="py-8 px-8">
      <article id="content">

        <div class="file-explorer-container mb-8">
          <div class="flex justify-between items-center px-6 py-4 border-b border-border gap-4">
            <h2 class="text-xl md:text-2xl font-semibold text-heading m-0">File Explorer</h2>
            <form class="flex items-center flex-grow relative" action="/directory" method="get">
              <input type="search" name="q" id="explorer-search-input" class="bg-bg border border-border rounded-md px-3 py-2 text-text w-full pr-10" placeholder="Search files...">
              <button class="absolute right-2 top-1/2 -translate-y-1/2 bg-none border-none text-text-light cursor-pointer p-0" type="submit">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/></svg>
              </button>
            </form>
          </div>
          <div class="p-8">
            <p id="explorer-placeholder" class="text-text-light m-0">Start typing to search files.</p>
            <ul id="file-list" class="list-none p-0 m-0 hidden">
              <li data-name="projects" class="border-b border-border last:border-b-0">
                <a href="/creations" class="flex items-center gap-4 py-3 text-text hover:text-accent hover:bg-accent/5 no-underline transition-colors duration-200">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="flex-shrink-0"><path d="M9.5 0a.5.5 0 0 1 .5.5v4a.5.5 0 0 1-.5.5h-4a.5.5 0 0 1-.5-.5v-4a.5.5 0 0 1 .5-.5h4zm-5 5v10a.5.5 0 0 1-.5.5h-4a.5.5 0 0 1-.5-.5v-10a.5.5 0 0 1 .5-.5h4zm5 0v10a.5.5 0 0 1-.5.5h-4a.5.5 0 0 1-.5-.5v-10a.5.5 0 0 1 .5-.5h4zm5 0v10a.5.5 0 0 1-.5.5h-4a.5.5 0 0 1-.5-.5v-10a.5.5 0 0 1 .5-.5h4z"/></svg>
                  <span>projects/</span>
                  <button class="ml-auto font-mono text-xs font-semibold text-text-light bg-transparent border border-border rounded-md px-2 py-1 cursor-pointer hover:bg-accent hover:text-bg hover:border-accent transition-colors duration-200">View</button>
                </a>
              </li>
              <li data-name="README.md" class="border-b border-border last:border-b-0">
                <a href="/" class="flex items-center gap-4 py-3 text-text hover:text-accent hover:bg-accent/5 no-underline transition-colors duration-200">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="flex-shrink-0"><path d="M12.5 16h-9A1.5 1.5 0 0 1 2 14.5v-13A1.5 1.5 0 0 1 3.5 0h9A1.5 1.5 0 0 1 14 1.5v13a1.5 1.5 0 0 1-1.5 1.5zM3 14.5a.5.5 0 0 0 .5.5h9a.5.5 0 0 0 .5-.5v-13a.5.5 0 0 0-.5-.5h-9a.5.5 0 0 0-.5.5v13z"/><path d="M5.5 2.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1 0-1zM4 6h8a.5.5 0 0 1 0 1H4a.5.5 0 0 1 0-1zm0 3h8a.5.5 0 0 1 0 1H4a.5.5 0 0 1 0-1zm0 3h8a.5.5 0 0 1 0 1H4a.5.5 0 0 1 0-1z"/></svg>
                  <span>README.md</span>
                  <span class="ml-auto text-xs text-text-light">8 KB / 2024-08-08</span>
                  <button class="ml-4 font-mono text-xs font-semibold text-text-light bg-transparent border border-border rounded-md px-2 py-1 cursor-pointer hover:bg-accent hover:text-bg hover:border-accent transition-colors duration-200">View</button>
                </a>
              </li>
              <li data-name="style.css" class="border-b border-border last:border-b-0">
                <a href="/style.css" class="flex items-center gap-4 py-3 text-text hover:text-accent hover:bg-accent/5 no-underline transition-colors duration-200">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="flex-shrink-0"><path d="M.5 1a.5.5 0 0 0-.5.5v12a.5.5 0 0 0 .5.5h12a.5.5 0 0 0 .5-.5v-12a.5.5 0 0 0-.5-.5h-12zM12 1H.5a.5.5 0 0 0-.5.5v13a.5.5 0 0 0 .5.5h13a.5.5 0 0 0 .5-.5V1.5a.5.5 0 0 0-.5-.5H12z"/><path d="M4.5 12.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5zM3 10.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5zM3 8.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5zM3 6.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5zM3 4.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5z"/></svg>
                  <span>style.css</span>
                  <span class="ml-auto text-xs text-text-light">2 KB / 2024-08-08</span>
                  <button class="ml-4 font-mono text-xs font-semibold text-text-light bg-transparent border border-border rounded-md px-2 py-1 cursor-pointer hover:bg-accent hover:text-bg hover:border-accent transition-colors duration-200">View</button>
                </a>
              </li>
              <li data-name="about.md" class="border-b border-border last:border-b-0">
                <a href="/profile" class="flex items-center gap-4 py-3 text-text hover:text-accent hover:bg-accent/5 no-underline transition-colors duration-200">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="flex-shrink-0"><path d="M12.5 16h-9A1.5 1.5 0 0 1 2 14.5v-13A1.5 1.5 0 0 1 3.5 0h9A1.5 1.5 0 0 1 14 1.5v13a1.5 1.5 0 0 1-1.5 1.5zM3 14.5a.5.5 0 0 0 .5.5h9a.5.5 0 0 0 .5-.5v-13a.5.5 0 0 0-.5-.5h-9a.5.5 0 0 0-.5.5v13z"/><path d="M5.5 2.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1 0-1zM4 6h8a.5.5 0 0 1 0 1H4a.5.5 0 0 1 0-1zm0 3h8a.5.5 0 0 1 0 1H4a.5.5 0 0 1 0-1zm0 3h8a.5.5 0 0 1 0 1H4a.5.5 0 0 1 0-1z"/></svg>
                  <span>about.md</span>
                  <span class="ml-auto text-xs text-text-light">1 KB / 2024-08-07</span>
                  <button class="ml-4 font-mono text-xs font-semibold text-text-light bg-transparent border border-border rounded-md px-2 py-1 cursor-pointer hover:bg-accent hover:text-bg hover:border-accent transition-colors duration-200">View</button>
                </a>
              </li>
            </ul>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
          <div class="flex items-center bg-bg border border-border rounded-lg p-6">
            <div class="text-5xl mr-6">📁</div>
            <div class="flex flex-col justify-center">
              <div class="text-5xl font-bold text-accent">2</div>
              <div class="text-xs text-text-light uppercase mt-2">Projects Completed</div>
            </div>
          </div>
          <div class="flex items-center bg-bg border border-border rounded-lg p-6">
            <div class="text-5xl mr-6">📝</div>
            <div class="flex flex-col justify-center">
              <div class="text-5xl font-bold text-accent">2</div>
              <div class="text-xs text-text-light uppercase mt-2">Latest Articles</div>
            </div>
          </div>
          <div class="flex items-center bg-bg border border-border rounded-lg p-6">
            <div class="text-5xl mr-6">💼</div>
            <div class="flex flex-col justify-center">
              <div class="text-5xl font-bold text-accent">9+</div>
              <div class="text-xs text-text-light uppercase mt-2">Years of Experience</div>
            </div>
          </div>
        </div>
        
        <h2 class="text-2xl font-medium text-heading border-b border-border pb-2 mb-4 mt-10 before:content-['##'] before:text-text-light before:font-normal before:mr-2">About</h2>
        <div class="flex items-center gap-6 mb-8">
          <img src="https://placehold.co/120x120/161B22/E6EDF3?text=JO" alt="A portrait of John Ogletree" class="w-28 h-28 rounded-full object-cover flex-shrink-0">
          <blockquote class="m-0 pl-6 border-l-2 border-border text-text-light flex-grow">I'm a multidisciplinary digital artist and designer from Martinez, Georgia. With nearly a decade of experience, I partner with clients to turn ambitious ideas into reality. My process is built on clear communication and a commitment to craft, whether I'm designing an application or composing a soundtrack.</blockquote>
        </div>

        <h2 class="text-2xl font-medium text-heading border-b border-border pb-2 mb-4 mt-10 before:content-['##'] before:text-text-light before:font-normal before:mr-2">Services</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mt-6">
          <a href="#" class="relative flex items-center gap-4 p-5 bg-bg border border-border rounded-lg text-text no-underline transition-transform duration-200 hover:translate-y-[-5px] hover:shadow-xl hover:border-accent overflow-hidden">
            <img src="https://placehold.co/60x60/0D1117/58A6FF?text=ID" alt="Brand & Identity Icon" class="w-12 h-12 flex-shrink-0 rounded-md bg-bg">
            <div>
              <strong class="text-heading">Brand & Identity:</strong> Logos, visual systems, and strategy.
            </div>
            <span class="absolute bottom-3 right-4 text-3xl text-text-light transition-transform duration-200 group-hover:translate-x-1 group-hover:text-accent">→</span>
          </a>
          <a href="#" class="relative flex items-center gap-4 p-5 bg-bg border border-border rounded-lg text-text no-underline transition-transform duration-200 hover:translate-y-[-5px] hover:shadow-xl hover:border-accent overflow-hidden">
            <img src="https://placehold.co/60x60/0D1117/58A6FF?text=UX" alt="Digital & UI/UX Design Icon" class="w-12 h-12 flex-shrink-0 rounded-md bg-bg">
            <div>
              <strong class="text-heading">Digital & UI/UX Design:</strong> Websites, applications, and interactive prototypes.
            </div>
            <span class="absolute bottom-3 right-4 text-3xl text-text-light transition-transform duration-200 group-hover:translate-x-1 group-hover:text-accent">→</span>
          </a>
        </div>
        <div class="text-center mt-8">
          <a href="/capabilities" class="inline-flex items-center justify-center gap-2 bg-heading text-bg border border-heading rounded-md px-6 py-3 font-mono font-medium cursor-pointer transition-colors duration-200 hover:bg-red-400 hover:border-red-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M4 8a.5.5 0 0 1 .5-.5h5.793L8.146 5.354a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L10.293 8.5H4.5A.5.5 0 0 1 4 8z"/></svg>
            <span>View All Services</span>
          </a>
        </div>

        <h2 class="text-2xl font-medium text-heading border-b border-border pb-2 mb-4 mt-10 before:content-['##'] before:text-text-light before:font-normal before:mr-2">Projects</h2>
        <p class="mb-4">A curated list of my work across various disciplines. For a deeper dive, please visit the full projects page.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mt-6">
          <a href="#" class="relative block bg-bg border border-border rounded-lg text-text no-underline transition-transform duration-200 hover:translate-y-[-5px] hover:shadow-xl hover:border-accent overflow-hidden">
            <img src="https://placehold.co/400x225/161B22/E6EDF3?text=Chrono+Corp" alt="Chrono Corp project screenshot" class="w-full h-auto aspect-[16/9] object-cover block bg-bg">
            <div class="p-4 md:p-5 pb-10">
              <div class="flex justify-between items-center mb-2">
                <h4 class="text-lg font-bold text-heading">Chrono Corp</h4>
                <span class="bg-tag-bg px-2 py-1 rounded-md text-xs text-accent flex-shrink-0 ml-2">UI/UX Design</span>
              </div>
              <p class="text-sm text-text-light leading-relaxed m-0">A time-tracking application for creative freelancers.</p>
              <span class="absolute bottom-3 right-4 text-3xl text-text-light transition-transform duration-200 group-hover:translate-x-1 group-hover:text-accent">→</span>
            </div>
          </a>
          <a href="#" class="relative block bg-bg border border-border rounded-lg text-text no-underline transition-transform duration-200 hover:translate-y-[-5px] hover:shadow-xl hover:border-accent overflow-hidden">
            <img src="https://placehold.co/400x225/161B22/E6EDF3?text=Aether+Systems" alt="Aether Systems branding project" class="w-full h-auto aspect-[16/9] object-cover block bg-bg">
            <div class="p-4 md:p-5 pb-10">
              <div class="flex justify-between items-center mb-2">
                <h4 class="text-lg font-bold text-heading">Aether Systems</h4>
                <span class="bg-tag-bg px-2 py-1 rounded-md text-xs text-accent flex-shrink-0 ml-2">Brand Identity</span>
              </div>
              <p class="text-sm text-text-light leading-relaxed m-0">A complete branding package for a cloud computing company.</p>
              <span class="absolute bottom-3 right-4 text-3xl text-text-light transition-transform duration-200 group-hover:translate-x-1 group-hover:text-accent">→</span>
            </div>
          </a>
        </div>
        <div class="text-center mt-8">
          <a href="/creations" class="inline-flex items-center justify-center gap-2 bg-orange-400 text-bg border border-orange-400 rounded-md px-6 py-3 font-mono font-medium cursor-pointer transition-colors duration-200 hover:bg-orange-300 hover:border-orange-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M4 8a.5.5 0 0 1 .5-.5h5.793L8.146 5.354a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L10.293 8.5H4.5A.5.5 0 0 1 4 8z"/></svg>
            <span>View All Projects</span>
          </a>
        </div>

        <h2 class="text-2xl font-medium text-heading border-b border-border pb-2 mb-4 mt-10 before:content-['##'] before:text-text-light before:font-normal before:mr-2">Latest Thoughts</h2>
