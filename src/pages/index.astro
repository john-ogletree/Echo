---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import { orange, blue, green, red, yellow, gray, black, white } from '../data/colors.js';
---

<Layout title="John Ogletree – Digital Artist & Designer" description="Portfolio and personal website of John Ogletree, a digital artist and designer based in Martinez, GA. Showcasing UI design, UX research, prototyping, and frontend development.">
			<section
				class="min-h-[70vh] flex flex-col justify-center items-center py-20"
				style={`background: linear-gradient(135deg, ${blue[50]}, ${white}, ${orange[100]})`}
			>
				<div class="w-full max-w-3xl mx-auto flex flex-col items-center text-center gap-6 px-4">
					<h1 class="text-5xl md:text-6xl font-extrabold tracking-tight mb-2" style={`color: ${gray[900]}`}>The Perfect Website</h1>
					<div class="flex flex-col md:flex-row items-center justify-center gap-2 mb-2">
						<span class="text-xs font-mono uppercase tracking-widest text-orange-700">For your business by John Ogletree</span>
						<span class="hidden md:inline-block text-gray-400 mx-2">|</span>
						<span class="inline-block px-3 py-1 rounded-full bg-blue-100 text-blue-700 text-xs font-bold uppercase shadow">Astro & TailwindCSS Partner</span>
					</div>
					<p class="text-lg md:text-xl font-mono mb-6 max-w-2xl" style={`color: ${gray[700]}`}>Every website deserves a unique solution, whether it's advanced custom functionalities, a need for a well-designed system for easy landing page creation, or special custom animated projects.</p>
					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						<Button text="Get in Touch" href="#contact" variant="primary" />
						<Button text="Projects" href="#projects" variant="secondary" />
					</div>
				</div>
			</section>
	<hr style={`border: none; border-top: 2px solid ${gray[200]}; width: 80%; margin: 2rem auto;`} />
</Layout>