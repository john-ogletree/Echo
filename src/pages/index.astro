---
import Layout from '../layouts/Layout.astro';
import Terminal from '../components/Terminal.astro';
import Profile from '../components/Profile.astro';
import Banner from '../components/Banner.astro';
import Services from '../components/Services.astro';
import Projects from '../components/Projects.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import Blog from '../components/Blog.astro';

import projectsData from '../data/projects.json';
import blogPostsData from '../data/blogPosts.json';
import reviewsData from '../data/reviews.json';

const latestProject = projectsData[projectsData.length - 1];

const allContent = [...blogPostsData, ...reviewsData];

// Sort by date in descending order (latest first)
allContent.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const latestContent = allContent[0];

// Determine the image based on content type
let latestContentImage = '';
if (latestContent.type === 'blog') {
  latestContentImage = '/astro.svg'; // Placeholder for blog post image
} else if (latestContent.type === 'review') {
  latestContentImage = '/background.svg'; // Placeholder for review image
}

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
  <main>
    <Banner
      title="Welcome to My Site"
      subtitle="This is a simple banner created with Astro."
    >
      <Button text="Learn More" link="/about" variant="primary" />
    </Banner>

    <Terminal title="example.js">
      <p><span class="terminal-prompt">$</span> node example.js</p>
      <p>Hello from the reusable terminal!</p>
    </Terminal>

    <Profile
      name="John Doe"
      bio="A passionate developer who loves creating amazing things with code."
      avatar="https://i.pravatar.cc/150"
      buttonLink="/skills"
    >
      <a href="https://github.com" target="_blank" class="social-link">GitHub</a>
      <a href="https://twitter.com" target="_blank" class="social-link">Twitter</a>
    </Profile>

    <Services title="Our Services">
      <Card
        type="service"
        title="Web Development"
        description="We build modern, responsive, and performant websites."
      />
      <Card
        type="service"
        title="Mobile Development"
        description="We create beautiful and user-friendly mobile applications."
      />
      <Card
        type="service"
        title="UI/UX Design"
        description="We design intuitive and engaging user interfaces."
      />
      <Card
        type="service"
        title="Digital Marketing"
        description="We help you grow your business and reach new customers."
      />
    </Services>

    <Projects title="Our Latest Project">
      <Card
        type={latestProject.type}
        contentType={latestProject.contentType}
        title={latestProject.title}
        description={latestProject.description}
        image={latestProject.image}
        videoSrc={latestProject.videoSrc}
        author={latestProject.author}
        audioSrc={latestProject.audioSrc}
        link={latestProject.link}
      />
    </Projects>

    <Blog title="Latest Updates">
      <Card
        type={latestContent.type}
        title={latestContent.title}
        description={latestContent.excerpt || latestContent.description}
        date={latestContent.date}
        link={latestContent.link}
        author={latestContent.author}
        rating={latestContent.rating}
        image={latestContentImage} /* Pass the determined image */
      />
    </Blog>
  </main>
</Layout>

<style>
  main {
    padding: 2rem;
  }

  .terminal-prompt {
    color: #e0e0e0; /* Light gray for prompt */
  }

  .social-link {
    margin-right: 1rem;
    color: #00e676; /* Vibrant green for links */
    text-decoration: none;
  }

  .social-link:hover {
    text-decoration: underline;
  }

  .vertical-project-column {
    display: flex;
    flex-direction: column;
    gap: 2rem; /* Same gap as the grid */
    grid-row: span 2; /* Make it span two rows */
  }
</style>