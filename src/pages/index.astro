---
import Layout from '../layouts/Layout.astro';
---

<Layout title="John Ogletree">
  <div class="portfolio-container">
    <header class="main-header">
      <div class="header-content">
        <h1 class="site-title">John Ogletree</h1>
        <p class="site-description">Digital Artist & Designer</p>
      </div>
    </header>

    <main class="content-body">
      <section id="about" class="about-section">
        <h2 class="section-title">About Me</h2>
        <div class="profile-info">
          <img src="https://via.placeholder.com/200x200" alt="Profile picture of John Ogletree" class="profile-image">
          <p class="about-text">
            I'm a multidisciplinary digital artist and designer from Martinez, Georgia. With nearly a decade of experience, I partner with clients to turn ambitious ideas into reality. My process is built on clear communication and a commitment to craft, whether I'm designing an application or composing a soundtrack.
          </p>
        </div>
      </section>

      <section id="projects" class="projects-section">
        <h2 class="section-title">Featured Work</h2>
        <div class="project-grid">
          <div class="project-card">
            <img src="https://via.placeholder.com/400x300" alt="Chrono Corp project thumbnail" class="project-image">
            <div class="project-info">
              <h3 class="project-name">Chrono Corp</h3>
              <p class="project-description">A time-tracking application for creative freelancers.</p>
              <span class="project-tag">UI/UX Design</span>
            </div>
          </div>
          <div class="project-card">
            <img src="https://via.placeholder.com/400x300" alt="Aether Systems branding project thumbnail" class="project-image">
            <div class="project-info">
              <h3 class="project-name">Aether Systems</h3>
              <p class="project-description">A complete branding package for a cloud computing company.</p>
              <span class="project-tag">Brand Identity</span>
            </div>
          </div>
        </div>
      </section>

      <section id="contact" class="contact-section">
        <h2 class="section-title">Get in Touch</h2>
        <p>I'm always open to new opportunities and collaborations. Send me an email to start the conversation.</p>
        <a href="mailto:contact@johnogletree.com" class="contact-link">Email me &rarr;</a>
      </section>
    </main>

    <footer class="main-footer">
      <p>&copy; <span id="year"></span> John Ogletree. All rights reserved.</p>
    </footer>
  </div>
</Layout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    const yearSpan = document.getElementById('year');
    if (yearSpan) {
      yearSpan.textContent = new Date().getFullYear();
    }
  });
</script>

<style>
  :root {
    --bg-color: #1a1a1a;
    --text-color: #e0e0e0;
    --primary-color: #f0f0f0;
    --secondary-color: #bb86fc;
    --card-bg: #2d2d2d;
    --border-color: #444;
    --link-color: #bb86fc;
    --link-hover-color: #a056f7;
    --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  }
  
  body {
    background-color: var(--bg-color);
    color: var(--text-color);
    font-family: var(--font-sans);
    line-height: 1.6;
    margin: 0;
    padding: 0;
  }

  .portfolio-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .main-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .site-title {
    font-size: 3rem;
    color: var(--primary-color);
    margin: 0;
    font-weight: 700;
  }

  .site-description {
    font-size: 1.2rem;
    color: var(--secondary-color);
    margin-top: 0.5rem;
  }

  .content-body {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .about-section, .projects-section, .contact-section {
    background-color: var(--card-bg);
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.2);
    padding: 2.5rem;
    border: 1px solid var(--border-color);
  }
  
  .section-title {
    font-size: 2.5rem;
    color: var(--primary-color);
    border-bottom: 2px solid var(--secondary-color);
    padding-bottom: 0.75rem;
    margin-top: 0;
    margin-bottom: 2rem;
  }
  
  .profile-info {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .profile-image {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--secondary-color);
  }

  .about-text {
    margin: 0;
  }
  
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .project-card {
    background-color: #383838;
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .project-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 8px 15px rgba(0, 0, 0, 0.4);
  }

  .project-image {
    width: 100%;
    height: auto;
    display: block;
  }

  .project-info {
    padding: 1.5rem;
  }

  .project-name {
    font-size: 1.5rem;
    margin: 0 0 0.5rem;
    color: var(--secondary-color);
  }

  .project-description {
    font-size: 1rem;
    color: #c0c0c0;
    margin: 0;
  }

  .project-tag {
    display: inline-block;
    background-color: var(--secondary-color);
    color: var(--card-bg);
    font-size: 0.8rem;
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    margin-top: 1rem;
    font-weight: bold;
  }

  .contact-link {
    display: inline-block;
    margin-top: 1rem;
    color: var(--link-color);
    text-decoration: none;
    font-weight: 500;
  }

  .contact-link:hover {
    text-decoration: underline;
    color: var(--link-hover-color);
  }

  .main-footer {
    text-align: center;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
    font-size: 0.9rem;
    color: #888;
  }

  @media (max-width: 768px) {
    .profile-info {
      flex-direction: column;
      text-align: center;
    }
  }
</style>