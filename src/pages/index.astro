---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import { orange, blue, green, red, yellow, gray, black, white } from '../data/colors.js';
---
<section class="min-h-[60vh] flex flex-col justify-center items-center bg-gradient-to-br from-blue-50 via-white to-orange-100 py-16">
	<div class="w-full max-w-4xl flex flex-col md:flex-row items-center justify-center gap-10 px-4">
		<!-- Left cell: Heading above tagline -->
		<div class="flex flex-col items-start flex-1 max-w-xl">
			<h1 class="text-4xl md:text-5xl font-extrabold font-mono text-gray-900 mb-4">John Ogletree</h1>
			<p class="text-lg md:text-xl text-gray-700 font-mono mb-0">Digital Artist & Designer based in Martinez, GA. I craft beautiful, functional digital experiences.</p>
		</div>
		<!-- Right cell: Buttons -->
		<div class="flex flex-col gap-4 flex-shrink-0 w-full md:w-auto items-center md:items-start">
			<a href="#portfolio" class="inline-block px-8 py-3 bg-orange-500 text-white font-bold rounded shadow hover:bg-orange-600 transition">View Portfolio</a>
			<a href="#contact" class="inline-block px-8 py-3 bg-white text-orange-500 border-2 border-orange-500 font-bold rounded shadow hover:bg-orange-50 hover:text-orange-600 hover:border-orange-600 transition">Contact Me</a>
		</div>
	</div>
</section>
</Layout>
</Layout>