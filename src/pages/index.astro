---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';

---

<Layout title="John Ogletree - Digital Artist & Designer" description="Portfolio and personal website of John Ogletree, a digital artist and designer based in Martinez, GA. Showcasing UI design, UX research, prototyping, and frontend development." keywords="John Ogletree, Digital Artist, Designer, UI Design, UX Research, Prototyping, Frontend Development, Martinez GA, Portfolio">
        <div class="readme-container">
                <main class="readme-body">
                                                                                                                                                <div class="rounded-lg mb-8 px-8 py-4 text-center bg-blue-500 text-white">
                                                                                                                                                        <p class="m-0 font-mono font-medium text-[1.1rem]">This is a banner! ✨</p>
                                                                                                                                                </div>

                                                                                                                                                                                                                                                                                                <section class="hero-section relative flex flex-col items-center justify-center text-center mb-16 py-16 bg-gradient-to-br from-blue-50 via-white to-yellow-100 overflow-hidden">
                                                                                                                                                                                                                                                                                                        <div class="absolute inset-0 pointer-events-none select-none">
                                                                                                                                                                                                                                                                                                                <svg class="absolute top-0 left-0 w-40 h-40 text-blue-200 opacity-60 animate-spin-slow" fill="none" viewBox="0 0 200 200"><circle cx="100" cy="100" r="80" stroke="currentColor" stroke-width="20" /></svg>
                                                                                                                                                                                                                                                                                                                <svg class="absolute bottom-0 right-0 w-32 h-32 text-yellow-200 opacity-50 animate-pulse" fill="none" viewBox="0 0 200 200"><rect x="30" y="30" width="140" height="140" rx="40" stroke="currentColor" stroke-width="20" /></svg>
                                                                                                                                                                                                                                                                                                        </div>
                                                                                                                                                                                                                                                                                                        <div class="relative z-10 flex flex-col items-center">
                                                                                                                                                                                                                                                                                                                <span class="inline-block px-4 py-1 mb-4 rounded-full bg-blue-100 text-blue-700 font-mono text-xs tracking-widest uppercase shadow">Hello, I'm</span>
                                                                                                                                                                                                                                                                                                                <h1 class="text-5xl md:text-6xl font-extrabold font-mono text-gray-900 mb-3 drop-shadow-lg">John Ogletree</h1>
                                                                                                                                                                                                                                                                                                                <h2 class="text-2xl md:text-3xl font-mono text-orange-500 mb-6 animate-fade-in">Digital Artist & Designer</h2>
                                                                                                                                                                                                                                                                                                                <p class="max-w-2xl text-lg md:text-xl text-gray-700 font-mono mb-8 animate-fade-in-slow">
                                                                                                                                                                                                                                                                                                                        Crafting <span class="text-blue-500 font-bold">beautiful</span> and <span class="text-orange-500 font-bold">functional</span> digital experiences.<br/>
                                                                                                                                                                                                                                                                                                                        UI/UX, prototyping, and frontend magic from Martinez, GA.
                                                                                                                                                                                                                                                                                                                </p>
                                                                                                                                                                                                                                                                                                                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                                                                                                                                                                                                                                                                                                                        <Button text="View Portfolio" href="#portfolio" variant="primary" />
                                                                                                                                                                                                                                                                                                                        <Button text="Contact Me" href="#contact" variant="secondary" />
                                                                                                                                                                                                                                                                                                                </div>
                                                                                                                                                                                                                                                                                                        </div>
                                                                                                                                                                                                                                                                                                </section>
                </main>
        </div>
</Layout>