---
import Layout from '../layouts/Layout.astro';
---

<Layout title="John Ogletree - Home">
	<main class="landing-page">
		<h1 class="main-heading">John Ogletree</h1>
		<p class="sub-heading">A digital artist and designer, creating beautiful things on the web.</p>
		<div class="cta-container">
			<a href="/creations" class="cta-button primary-cta">
				View Creations
			</a>
			<a href="/connect" class="cta-button secondary-cta">
				Connect
			</a>
		</div>
	</main>
</Layout>

<style>
	.landing-page {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-height: 100vh;
		padding: 2rem;
		text-align: center;
		background-color: #1a202c; /* bg-gray-900 */
		color: #e2e8f0; /* text-gray-100 */
	}

	.main-heading {
		font-size: 3rem; /* text-4xl */
		font-weight: 700; /* font-bold */
		letter-spacing: -0.025em; /* tracking-tight */
		color: #63b3ed; /* text-blue-400 */
	}

	@media (min-width: 640px) {
		.main-heading {
			font-size: 3.75rem; /* sm:text-6xl */
		}
	}

	.sub-heading {
		margin-top: 1rem;
		max-width: 42rem; /* max-w-xl */
		font-size: 1.125rem; /* text-lg */
		color: #cbd5e0; /* text-gray-300 */
	}

	.cta-container {
		margin-top: 2rem;
		display: flex;
		gap: 1rem;
	}

	.cta-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.75rem 1.5rem;
		border-width: 1px;
		border-style: solid;
		border-color: transparent;
		font-size: 1rem;
		font-weight: 500;
		border-radius: 0.375rem;
		transition-property: background-color, border-color, color;
		transition-duration: 200ms;
		transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
		color: white;
	}

	.primary-cta {
		background-color: #4299e1; /* bg-blue-500 */
		border-color: #4299e1;
	}

	.primary-cta:hover {
		background-color: #3182ce; /* hover:bg-blue-600 */
	}
	
	.secondary-cta {
		background-color: transparent;
		color: #cbd5e0; /* text-gray-300 */
		border-color: #4a5568; /* border-gray-500 */
	}

	.secondary-cta:hover {
		color: white;
		background-color: #2d3748; /* hover:bg-gray-700 */
	}
</style>