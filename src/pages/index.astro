                        <div class="language-item"><span class="lang-color" style="--lang-color: #3178c6;"></span> TypeScript</div>
                        <div class="language-item"><span class="lang-color" style="--lang-color: #b07219;"></span> Java</div>
                    </div>
                </div>
                <div class="skills-column">
                    <div class="skills-card">
                        <div class="skill-item">
                            <div class="skill-info">
