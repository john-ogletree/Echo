---
import Layout from '../layouts/Layout.astro';
---

<Layout title="John Ogletree - Home">
  <nav class="main-nav-bar">
    <div class="nav-container">
      <a href="/" class="nav-logo">John Ogletree</a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/creations">Creations</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>
  </nav>
  <div class="hero">
    <div class="hero-container">
      <h2 class="hero-title">Creative Solutions for a Digital World</h2>
      <p class="hero-subtitle">I'm a multidisciplinary digital artist and designer with over nine years of experience, ready to help you bring your ideas to life.</p>
      <a href="/creations" class="hero-cta">See My Work</a>
    </div>
  </div>
  <div class="profile-card-section">
    <div class="profile-card">
      <img src="https://placehold.co/120x120/161B22/E6EDF3?text=JO" alt="A portrait of John Ogletree" class="profile-picture">
      <h3>John Ogletree</h3>
      <blockquote>I'm a multidisciplinary digital artist and designer from Martinez, Georgia. With nearly a decade of experience, I partner with clients to turn ambitious ideas into reality. My process is built on clear communication and a commitment to craft, whether I'm designing an application or composing a soundtrack.</blockquote>
    </div>
  </div>
  <main class="content">
    <h1>Welcome</h1>
    <p>This is the content area.</p>
    
    <div class="services-overview">
      <div class="services-header">
        <h2 class="services-title">My Services</h2>
        <p class="services-intro">
          I offer a range of creative and technical services to help you build a strong digital presence. My goal is to work with you to understand your vision and deliver solutions that are both beautiful and functional.
        </p>
      </div>
      <div class="services-grid">
        <div class="service-card">
          <h3 class="service-title">UI/UX Design & Web Development</h3>
          <p class="service-description">
            I create intuitive and engaging user interfaces for websites and applications. From wireframing and prototyping to final design and implementation, I focus on the user's journey to ensure a seamless and enjoyable experience. My development skills bring these designs to life with clean, efficient code.
          </p>
        </div>
        <div class="service-card">
          <h3 class="service-title">Digital Illustration & Graphic Design</h3>
          <p class="service-description">
            Whether you need custom illustrations for a brand, an eye-catching logo, or a complete visual identity, I can translate complex ideas into clear and compelling visuals. I have experience working across various styles and mediums to create graphics that capture attention and communicate your message effectively.
          </p>
        </div>
        <div class="service-card">
          <h3 class="service-title">Sound Design & Music Composition</h3>
          <p class="service-description">
            Good design isn't just visual; it's also aural. I compose original music and create soundscapes for film, games, and other interactive media. My sound design work adds depth and atmosphere, enhancing the emotional impact of your project and creating a more immersive experience for your audience.
          </p>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .main-nav-bar {
    background-color: #333;
    color: white;
    padding: 1rem 0;
  }
  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 2rem;
  }
  .nav-logo {
    font-size: 1.5rem;
    font-weight: bold;
    color: white;
    text-decoration: none;
  }
  .nav-links {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 1rem;
  }
  .nav-links a {
    color: white;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .nav-links a:hover {
    color: #ccc;
  }
  .hero {
    background-color: #2d3748;
    color: white;
    padding: 4rem 2rem;
    text-align: center;
  }
  .hero-container {
    max-width: 800px;
    margin: 0 auto;
  }
  .hero-title {
    font-size: 3rem;
    font-weight: bold;
    margin-bottom: 1rem;
  }
  .hero-subtitle {
    font-size: 1.25rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }
  .hero-cta {
    display: inline-block;
    background-color: #4299e1;
    color: white;
    padding: 0.75rem 2rem;
    border-radius: 9999px;
    text-decoration: none;
    font-weight: bold;
    transition: background-color 0.3s ease;
  }
  .hero-cta:hover {
    background-color: #3182ce;
  }
  .profile-card-section {
    background-color: #f0f0f0;
    padding: 4rem 2rem;
    text-align: center;
  }
  .profile-card {
    max-width: 800px;
    margin: 0 auto;
    background-color: white;
    padding: 2rem;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }
  .profile-picture {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 1rem;
  }
  .profile-card h3 {
    font-size: 2rem;
    font-weight: bold;
    margin-bottom: 1rem;
  }
  .profile-card blockquote {
    font-style: italic;
    color: #555;
    margin: 0;
  }
  .content {
    padding: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .services-overview {
    padding: 4rem 0;
    text-align: center;
  }

  .services-header {
    margin-bottom: 3rem;
  }

  .services-title {
    font-size: 2.5rem;
    font-weight: bold;
    margin-bottom: 1rem;
  }

  .services-intro {
    font-size: 1.15rem;
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .service-card {
    background-color: #f9f9f9;
    padding: 2rem;
    border-radius: 8px;
    text-align: left;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .service-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 15px rgba(0, 0, 0, 0.1);
  }

  .service-title {
    font-size: 1.5rem;
    font-weight: bold;
    margin-bottom: 0.5rem;
  }

  .service-description {
    font-size: 1rem;
    line-height: 1.6;
    color: #555;
  }
</style>