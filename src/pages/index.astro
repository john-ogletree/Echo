---
import Layout from '../layouts/Layout.astro';
---
<Layout title="John Ogletree - Home">
<nav class="main-nav-bar">
<div class="nav-container">
<a href="/" class="nav-logo">John Ogletree</a>
<ul class="nav-links">
<li><a href="/">Home</a></li>
<li><a href="/about">About</a></li>
<li><a href="/creations">Creations</a></li>
<li><a href="/contact">Contact</a></li>
</ul>
</div>
</nav>
<main class="content">
<h1>Welcome</h1>
<p>This is the content area.</p>
</main>
</Layout>

<style>
.main-nav-bar {
background-color: #333;
color: white;
padding: 1rem 0;
}
.nav-container {
max-width: 1200px;
margin: 0 auto;
display: flex;
justify-content: space-between;
align-items: center;
padding: 0 2rem;
}
.nav-logo {
font-size: 1.5rem;
font-weight: bold;
color: white;
text-decoration: none;
}
.nav-links {
display: flex;
list-style: none;
margin: 0;
padding: 0;
gap: 1rem;
}
.nav-links a {
color: white;
text-decoration: none;
transition: color 0.3s ease;
}
.nav-links a:hover {
color: #ccc;
}
.content {
padding: 2rem;
max-width: 1200px;
margin: 0 auto;
}
</style>