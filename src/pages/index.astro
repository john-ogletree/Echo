<style is:inline>
  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;700&display=swap');
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    // Mobile navigation toggle
    const navToggle = document.getElementById('nav-toggle');
    const mainNav = document.getElementById('main-nav');
    if (navToggle && mainNav) {
      navToggle.addEventListener('click', () => {
        const isOpen = navToggle.getAttribute('aria-expanded') === 'true';
        navToggle.setAttribute('aria-expanded', !isOpen);
        mainNav.classList.toggle('is-open');
        navToggle.classList.toggle('is-open');
        // Tailwind classes for menu animation
        if (mainNav.classList.contains('is-open')) {
          mainNav.classList.add('fixed', 'inset-0', 'bg-surface', 'z-40', 'p-8', 'flex-col', 'gap-8');
          mainNav.classList.remove('hidden', 'lg:flex');
          document.body.style.overflow = 'hidden';
          navToggle.querySelectorAll('span')[0].classList.replace('top-[7px]', 'rotate-45');
          navToggle.querySelectorAll('span')[1].classList.add('opacity-0');
          navToggle.querySelectorAll('span')[2].classList.replace('bottom-[7px]', '-rotate-45');
        } else {
          mainNav.classList.remove('fixed', 'inset-0', 'bg-surface', 'z-40', 'p-8', 'flex-col', 'gap-8');
          mainNav.classList.add('hidden', 'lg:flex');
          document.body.style.overflow = '';
          navToggle.querySelectorAll('span')[0].classList.replace('rotate-45', 'top-[7px]');
          navToggle.querySelectorAll('span')[1].classList.remove('opacity-0');
          navToggle.querySelectorAll('span')[2].classList.replace('-rotate-45', 'bottom-[7px]');
        }
      });
    }

    // Set copyright year
    const yearSpan = document.getElementById('year');
    if (yearSpan) {
      yearSpan.textContent = new Date().getFullYear();
    }
  });
</script>