---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
---

<Layout title="John Ogletree - Digital Artist & Designer" description="Portfolio and personal website of John Ogletree, a digital artist and designer based in Martinez, GA. Showcasing UI design, UX research, prototyping, and frontend development." keywords="John Ogletree, Digital Artist, Designer, UI Design, UX Research, Prototyping, Frontend Development, Martinez GA, Portfolio">
    <div class="readme-container">
        <main class="readme-body">
            <div class="banner-container">
                <p class="banner-text m-0 font-medium text-[1.1rem]">This is a banner! ✨</p>
            </div>
        </main>
    </div>
</Layout>



<style>
    @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;700&display=swap');
    :root {
        --color-bg: #F0EAD6; /* Light cream */
        --color-surface: #D4C9A8; /* Muted beige */
        --color-text: #3B2F2A; /* Deep brown-black */
        --color-text-light: #5B4F48; /* Dark brown-grey */
        --color-heading: #E07A5F; /* Warm terracotta orange */
        --color-accent: #3D87A6; /* Retro teal */
        --color-border: #A69E8C; /* Faded grey-brown */
        --color-tag-bg: rgba(61, 135, 166, 0.15); /* Faded teal transparency */
        --font-mono: 'IBM Plex Mono', Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        --padding-x: 2rem;
    }

    /* --- Base & Typography --- */
    html {
        scroll-behavior: smooth;
        scroll-padding-top: 80px;
    }
    body {
        background-color: var(--color-bg);
        color: var(--color-text);
        font-family: var(--font-mono);
        font-size: 16px;
        line-height: 1.7;
        margin: 0;
        padding: 0;
        transition: transform 0.3s ease-in-out;
    }
    body.no-scroll {
        overflow: hidden;
    }
    body.no-scroll .readme-body {
        filter: blur(5px);
        pointer-events: none;
    }
    h1, h2, h3, h4 {
        font-family: var(--font-mono);
        font-weight: 500;
        color: var(--color-heading);
        margin: 0;
    }
    h2 { font-size: 1.5rem; border-bottom: 1px solid var(--color-border);
        padding-bottom: 0.5rem; margin: 2.5rem 0 1rem 0;
    }
    h2::before {
        content: '##';
        color: var(--color-text-light);
        font-weight: 400;
        margin-right: 0.5rem;
    }
    p { margin: 0 0 1rem 0; }
    a { color: var(--color-accent); text-decoration: none;
    }
    a:hover { text-decoration: underline; }
    hr { display: none;
    }
    ul { list-style: '- ';
    padding-left: 1.5rem;
    margin-bottom: 1rem;}
    blockquote {
        margin-left: 0;
        padding-left: 1rem;
        border-left: 3px solid var(--color-border);
        color: var(--color-text-light);
    }

    /* --- Main Layout --- */
    .readme-container {
        background-color: var(--color-surface);
    }
    .readme-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1rem var(--padding-x);
        border-bottom: 1px solid var(--color-border);
        position: sticky;
        top: 0;
        z-index: 10;
        background-color: var(--color-surface);
    }
    .header-left, .header-right {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .repo-title {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 1.25rem;
    }
    .icon-repo {
        fill: var(--color-text-light);
    }
    .readme-body {
        padding: 2rem var(--padding-x);
        transition: filter 0.3s ease-in-out;
    }

    /* --- Banner --- */
    .banner-container {
        background-color: var(--color-accent);
        color: var(--color-bg);
        padding: 1rem 2rem;
        text-align: center;
        border-radius: 8px;
        margin-bottom: 2rem;
    }
    .banner-text {
        margin: 0;
        font-weight: 500;
        font-size: 1.1rem;
    }

    /* --- Hero Section --- */
    .hero-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        margin-bottom: 2rem;
    }
    .hero-content {
        max-width: 80ch;
    }

    /* --- Header Search --- */
    .search-form { position: relative;
    }
    .search-input {
        background-color: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: 6px;
        padding: 0.4rem 2rem 0.4rem 0.75rem;
        font-family: var(--font-mono);
        font-size: 0.9rem;
        color: var(--color-text);
        width: 180px;
    }
    .search-input:focus {
        outline: none;
        border-color: var(--color-accent);
        box-shadow: 0 0 0 3px rgba(61, 135, 166, 0.3);
    }
    .mobile-search { display: block;
    }
    .desktop-search { display: none;
    }

    /* --- Header / Nav --- */
    
    
    .nav-toggle,
    .nav-close {
        background: none;
        border: none;
        color: var(--color-text);
        padding: 0.5rem;
        cursor: pointer;
        z-index: 100;
    }
    
    .nav-close {
        display: none;
    }

    .nav-drawer-container.is-open ~ .nav-toggle {
        display: none;
    }

    .nav-drawer-container .nav-close {
        display: none;
    }
    
    .nav-drawer-container.is-open .nav-close {
        display: block;
    }

    .nav-drawer-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 300px;
        height: 100vh;
        background-color: var(--color-surface);
        border-right: 1px solid var(--color-border);
        transform: translateX(-100%);
        transition: transform 0.3s ease-in-out;
        z-index: 99;
        box-shadow: 4px 0 16px rgba(0, 0, 0, 0.5);
    }
    .nav-drawer-container.is-open {
        transform: translateX(0);
    }
    
    .main-nav {
        display: flex;
        flex-direction: column;
        height: 100%;
        padding: 0;
    }

    .nav-header-mobile {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.5rem 1.5rem 1rem 1.5rem;
        border-bottom: 1px solid var(--color-border);
        flex-shrink: 0;
    }

    .nav-header-mobile .mobile-search {
        flex-grow: 1;
    }

    .nav-socials {
        list-style: none;
        padding: 1.5rem;
        border-top: 1px solid var(--color-border);
        display: flex;
        justify-content: center;
        gap: 2rem;
        flex-shrink: 0;
    }
    .nav-socials a { color: var(--color-text-light);
    }
    .nav-socials a:hover { color: var(--color-accent);
    }
    .nav-socials svg { width: 24px; height: 24px;
    }
    
    .branded-hr {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin: 4rem 0;
    }
    .branded-hr .line {
        flex-grow: 1;
        height: 1px;
        background-color: var(--color-border);
    }
    .branded-hr .icon-repo {
        fill: var(--color-text-light);
        flex-shrink: 0;
    }

    .card-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-top: 1.5rem;
    }
    
    
    
    .footer {
        padding: 2.5rem var(--padding-x) 1.5rem var(--padding-x);
        margin: 2rem auto 0 auto;
        border-top: 1px solid var(--color-border);
    }
    .footer-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 2rem;
        margin-bottom: 2.5rem;
    }
    .footer-column h4 { color: var(--color-accent);
        margin-bottom: 1rem; font-size: 1.1rem;
    }
    .footer-tagline { color: var(--color-text-light); font-size: 0.9rem; max-width: 35ch;
    }
    .footer-column .badge { margin-top: 0.5rem; background-color: #E07A5F;
    color: white; border: none;
    }
    .footer-links {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.75rem 1rem;
    }
    .footer-links li { margin: 0;
    }
    .footer-links a { color: var(--color-text-light);
    text-decoration: none; font-size: 0.9rem;
    }
    .footer-links a:hover { color: var(--color-heading); text-decoration: underline;
    }
    .footer-socials {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        gap: 1.5rem;
    }
    .footer-socials a { color: var(--color-text-light);
    transition: color 0.2s ease; }
    .footer-socials a:hover { color: var(--color-accent);
    }
    .footer-socials svg { width: 24px; height: 24px;
    }
    .footer-bottom-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--color-border);
        font-size: 0.9rem;
        color: var(--color-text-light);
    }
    .footer-bottom-bar p { margin: 0;
    }
    .back-to-top { color: var(--color-text-light); text-decoration: none; transition: color 0.2s ease;
    }
    .back-to-top:hover { color: var(--color-accent); text-decoration: none;
    }
    
    /* --- About Me Section --- */
    .about-me-section {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-top: 4rem;
        align-items: stretch;
    }

    /* --- REVAMPED PROFILE CARD --- */
    .profile-card {
        background-color: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }
    .profile-main-info {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid var(--color-border);
    }
    .profile-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex: 1;
    }
    .profile-picture {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid var(--color-border);
    }
    .profile-header-info {
        display: flex;
        flex-direction: column;
    }
    .profile-header-info h3 {
        font-size: 1.5rem;
        margin: 0;
        line-height: 1.2;
    }
    .profile-username {
        color: var(--color-text-light);
        font-size: 1rem;
        margin: 0 0 0.5rem 0;
    }
    .profile-card .social-links {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }
    .profile-card .social-links a {
        color: var(--color-text-light);
        transition: color 0.2s, transform 0.2s;
    }
    .profile-card .social-links a:hover {
        color: var(--color-accent);
        transform: scale(1.1);
    }
    .profile-card .social-links svg {
        width: 20px;
        height: 20px;
    }
    .profile-stats {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        min-width: 150px;
    }
    .stat-item {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        width: 100%;
    }
    .stat-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--color-heading);
    }
    .stat-label {
        font-size: 0.8rem;
        color: var(--color-text-light);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .contribution-graph {
        display: grid;
        grid-template-columns: repeat(20, 1fr);
        grid-auto-flow: column;
        grid-auto-rows: 1fr;
        gap: 3px;
    }
    .graph-day {
        aspect-ratio: 1 / 1;
        background-color: var(--color-surface);
        border-radius: 2px;
    }
    .graph-day[data-level="1"] { background-color: #9be9a8; }
    .graph-day[data-level="2"] { background-color: #40c463; }
    .graph-day[data-level="3"] { background-color: #30a14e; }
    .graph-day[data-level="4"] { background-color: #216e39; }
    .graph-loading {
        grid-column: 1 / -1;
        text-align: center;
        font-size: 0.9rem;
        color: var(--color-text-light);
    }
    .profile-stats.languages {
        border-top: 1px solid var(--color-border);
        padding-top: 1.25rem;
    }
    .languages .stat-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .languages .stat-value {
        font-size: 1.2rem;
        font-weight: 500;
    }
    .lang-color {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background-color: var(--lang-color, var(--color-border));
    }
    
    .skills-column {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }
    .skills-card {
        padding: 1.5rem;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        background-color: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        flex-grow: 1;
    }
    .skill-item {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        align-items: center;
    }
    .skill-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .skill-icon {
        color: var(--color-accent);
    }
    .skill-progress {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background-color: var(--color-surface);
        border-radius: 4px;
        overflow: hidden;
    }
    .progress-bar {
        height: 10px;
        background-color: var(--color-accent);
        border-radius: 4px;
        width: 0;
        transition: width 1.5s cubic-bezier(0.25, 1, 0.5, 1);
    }
    .skill-progress span {
        font-size: 0.9rem;
        padding-right: 0.5rem;
    }
    
    
    

    
</style>