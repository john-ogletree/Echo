---
import Layout from '../layouts/Layout.astro';
---

<Layout title="john-ogletree/portfolio">
  <div class="terminal-container">
    <div class="terminal-window">
      <div class="terminal-header">
        <div class="terminal-buttons">
          <span class="dot red"></span>
          <span class="dot yellow"></span>
          <span class="dot green"></span>
        </div>
        <div class="terminal-title">john-ogletree@portfolio</div>
      </div>
      <div class="terminal-body">
        <pre>
<span class="prompt">john-ogletree:~ $</span> whoami
<span class="output-block">
  <span class="output-line">Name: John Ogletree</span>
  <span class="output-line">Role: Digital Artist & Designer</span>
  <span class="output-line">Location: Martinez, GA</span>
  <span class="output-line">Experience: 9+ years</span>
  <span class="output-line">Status: <span class="badge available">Available for hire</span></span>
</span>
<span class="prompt">john-ogletree:~ $</span> ls -a projects
<span class="output-block">
  <span class="output-list">
  <span class="output-list-item"><span class="project-name">Chrono Corp</span> - <span class="project-description">A time-tracking application for creative freelancers.</span></span>
  <span class="output-list-item"><span class="project-name">Aether Systems</span> - <span class="project-description">A complete branding package for a cloud computing company.</span></span>
  </span>
</span>
<span class="prompt">john-ogletree:~ $</span> cat skills.txt
<span class="output-block">
  <span class="output-list">
  <span class="output-list-item">Design: UI/UX & Prototyping, Brand & Identity, Art Direction, Iconography, Illustration</span>
  <span class="output-list-item">Tech: Figma, Adobe Creative Suite, HTML, CSS, JavaScript, Astro, Node.js, Blender</span>
  </span>
</span>
<span class="prompt">john-ogletree:~ $</span> email contact
<span class="output-block">
  <span class="output-line">Opening mail client to <a href="mailto:contact@johnogletree.com" class="output-link">contact@johnogletree.com</a>...</span>
</span>
<span class="prompt">john-ogletree:~ $</span> 
        </pre>
      </div>
    </div>
  </div>
</Layout>

<style>
  :root {
    --bg-color: #1a1a1a;
    --terminal-bg: #222;
    --terminal-fg: #f0f0f0;
    --terminal-prompt-color: #92d95c;
    --terminal-title-color: #aaa;
    --terminal-output-color: #e0e0e0;
    --terminal-border: #444;
    --font-mono: 'Fira Code', 'Monaco', 'Consolas', monospace;
    --dot-red: #ff5f56;
    --dot-yellow: #ffbd2e;
    --dot-green: #27c93f;
    --badge-available-bg: #2d6a47;
    --badge-available-text: #b7efc5;
    --project-name-color: #4ec9b0;
    --project-description-color: #a1a1aa;
    --link-color: #61afef;
  }

  body {
    background-color: var(--bg-color);
    color: var(--terminal-fg);
    font-family: var(--font-mono);
    line-height: 1.5;
    padding: 0;
    margin: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
  }

  .terminal-container {
    width: 100%;
    max-width: 900px;
    padding: 1rem;
  }

  .terminal-window {
    background-color: var(--terminal-bg);
    border: 1px solid var(--terminal-border);
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
    overflow: hidden;
  }

  .terminal-header {
    display: flex;
    align-items: center;
    padding: 0.5rem 1rem;
    background-color: #333;
    border-bottom: 1px solid var(--terminal-border);
  }

  .terminal-buttons {
    display: flex;
    gap: 0.5rem;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot.red { background-color: var(--dot-red); }
  .dot.yellow { background-color: var(--dot-yellow); }
  .dot.green { background-color: var(--dot-green); }

  .terminal-title {
    flex-grow: 1;
    text-align: center;
    color: var(--terminal-title-color);
    font-size: 0.9rem;
  }

  .terminal-body {
    padding: 1rem;
  }

  pre {
    margin: 0;
    white-space: pre-wrap;
    word-wrap: break-word;
  }
  
  .prompt {
    color: var(--terminal-prompt-color);
  }

  .output-block {
    display: block;
    margin: 0.5rem 0 1rem;
  }

  .output-line {
    display: block;
    color: var(--terminal-output-color);
  }

  .output-list {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 1rem;
  }
  
  .output-list-item {
    display: block;
    margin-bottom: 0.25rem;
    color: var(--terminal-output-color);
  }

  .badge {
    padding: 0.2em 0.5em;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: bold;
    display: inline-block;
  }

  .badge.available {
    background-color: var(--badge-available-bg);
    color: var(--badge-available-text);
  }

  .project-name {
    color: var(--project-name-color);
  }
  
  .project-description {
    color: var(--project-description-color);
  }
  
  .output-link {
    color: var(--link-color);
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .terminal-container {
      padding: 0.5rem;
    }
  }
</style>