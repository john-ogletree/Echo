---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="min-h-screen bg-surface text-text font-mono antialiased scroll-smooth selection:bg-accent selection:text-bg">
    <header class="sticky top-0 z-50 flex items-center justify-between gap-4 border-b border-border bg-surface px-4 py-4 md:px-8">
      <div class="flex items-center gap-4">
        <div class="flex items-center gap-2 text-xl font-bold md:text-2xl">
          <svg class="h-6 w-6 fill-text-light" viewBox="0 0 16 16" version="1.1" width="16" height="16" aria-hidden="true">
            <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 0 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Z"></path>
          </svg>
          <a href="/" class="text-heading hover:text-accent transition-colors duration-200">ECHO</a>
        </div>
      </div>
      <div class="flex items-center gap-4">
        <form class="relative hidden lg:block" action="/directory" method="get">
          <input type="search" name="q" class="w-48 rounded-lg border border-border bg-bg px-3 py-1 text-sm text-text placeholder-text-light focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30" placeholder="Search..." />
          <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 text-text-light hover:text-accent" aria-label="Search">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
              <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"></path>
            </svg>
          </button>
        </form>
        <nav id="main-nav" class="main-nav">
          <ul class="flex-col gap-4 lg:flex lg:flex-row lg:gap-6 lg:items-center">
            <li class="lg:hidden">
              <form class="relative" action="/directory" method="get">
                <input type="search" name="q" class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text placeholder-text-light focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30" placeholder="Search..." />
                <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 text-text-light hover:text-accent" aria-label="Search">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"></path>
                  </svg>
                </button>
              </form>
            </li>
            <li><a href="#about" class="text-text hover:text-accent transition-colors duration-200">About</a></li>
            <li><a href="#services" class="text-text hover:text-accent transition-colors duration-200">Services</a></li>
            <li><a href="#projects" class="text-text hover:text-accent transition-colors duration-200">Projects</a></li>
            <li><a href="#resume" class="text-text hover:text-accent transition-colors duration-200">R&eacute;sum&eacute;</a></li>
            <li><a href="#contact" class="text-text hover:text-accent transition-colors duration-200">Contact</a></li>
            <li><a href="/directory" class="text-text hover:text-accent transition-colors duration-200">Directory</a></li>
          </ul>
        </nav>
        <button class="relative z-50 block h-8 w-8 lg:hidden" id="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
            <span class="absolute block h-0.5 w-6 transform bg-text transition-transform duration-200 ease-in-out top-[7px]"></span>
            <span class="absolute block h-0.5 w-6 transform bg-text transition-opacity duration-200 ease-in-out top-1/2 -translate-y-1/2"></span>
            <span class="absolute block h-0.5 w-6 transform bg-text transition-transform duration-200 ease-in-out bottom-[7px]"></span>
        </button>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 py-8 md:px-8 md:py-16">
      <section id="dashboard" class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 xl:gap-8 [&>a]:transition-transform [&>a]:duration-200 [&>a]:ease-in-out [&>a]:hover:-translate-y-1 [&>a]:hover:shadow-lg [&>a]:hover:shadow-bg/40">
        <a href="#about" class="group relative flex flex-col justify-between rounded-lg border border-border bg-bg p-6 lg:col-span-2 lg:row-span-1">
          <div class="flex items-center gap-4">
            <img src="https://placehold.co/80x80/161B22/E6EDF3?text=JO" alt="A portrait of John Ogletree" class="h-16 w-16 rounded-full border-2 border-border object-cover" />
            <div>
              <h3 class="text-xl font-bold leading-tight text-heading lg:text-2xl">John Ogletree</h3>
              <p class="mt-1 text-sm text-text-light">Digital Artist & Designer</p>
            </div>
          </div>
          <div class="mt-6 flex items-center justify-between">
            <span class="rounded-full bg-tag-bg px-3 py-1 text-xs font-medium text-accent">Available for Hire</span>
            <span class="text-4xl leading-none text-text-light transition-transform duration-200 ease-in-out group-hover:translate-x-1 group-hover:text-accent">&rarr;</span>
          </div>
        </a>
        <a href="#resume" class="group relative flex flex-col justify-between rounded-lg border border-border bg-bg p-6 lg:row-span-1">
          <div>
            <h4 class="text-xl font-bold text-accent">R&eacute;sum&eacute;</h4>
            <p class="mt-1 text-sm text-text-light">View skills, experience, and download PDF.</p>
          </div>
          <span class="absolute bottom-6 right-6 text-4xl leading-none text-text-light transition-transform duration-200 ease-in-out group-hover:translate-x-1 group-hover:text-accent">&rarr;</span>
        </a>
        <a href="#services" class="group relative flex flex-col justify-between rounded-lg border border-border bg-bg p-6 lg:row-span-1">
          <div>
            <h4 class="text-xl font-bold text-accent">Services</h4>
            <ul class="mt-2 list-inside list-disc text-sm text-text-light">
              <li>UI/UX Design</li>
              <li>Branding</li>
              <li>Motion Graphics</li>
            </ul>
          </div>
          <span class="absolute bottom-6 right-6 text-4xl leading-none text-text-light transition-transform duration-200 ease-in-out group-hover:translate-x-1 group-hover:text-accent">&rarr;</span>
        </a>
        <a href="#projects" class="group relative flex flex-col justify-between rounded-lg border border-border bg-cover bg-center p-6 lg:col-span-2 lg:row-span-1" style="background-image: linear-gradient(rgba(13,17,23,0.8), rgba(13,17,23,0.8)), url(https://placehold.co/400x225/161B22/E6EDF3?text=Project);">
          <div>
            <h4 class="text-xl font-bold text-accent">Featured Project</h4>
            <p class="mt-1 text-sm text-text-light">Chrono Corp - UI/UX Design</p>
          </div>
          <span class="absolute bottom-6 right-6 text-4xl leading-none text-text-light transition-transform duration-200 ease-in-out group-hover:translate-x-1 group-hover:text-accent">&rarr;</span>
        </a>
        <a href="#blog" class="group relative flex flex-col justify-between rounded-lg border border-border bg-bg p-6 lg:row-span-1">
          <div>
            <h4 class="text-xl font-bold text-accent">Latest Thoughts</h4>
            <p class="mt-1 text-sm text-text-light">Reducing Cognitive Load in UI Design</p>
          </div>
          <span class="absolute bottom-6 right-6 text-4xl leading-none text-text-light transition-transform duration-200 ease-in-out group-hover:translate-x-1 group-hover:text-accent">&rarr;</span>
        </a>
        <a href="#newsletter" class="group relative flex flex-col justify-between rounded-lg border border-border bg-tag-bg p-6 lg:row-span-1">
          <div>
            <h4 class="text-xl font-bold text-accent">Newsletter</h4>
            <p class="mt-1 text-sm text-text-light">Get occasional updates and articles.</p>
          </div>
          <span class="absolute bottom-6 right-6 text-4xl leading-none text-text-light transition-transform duration-200 ease-in-out group-hover:translate-x-1 group-hover:text-accent">&rarr;</span>
        </a>
        <a href="#contact" class="group relative flex flex-col justify-between rounded-lg border border-border bg-bg p-6 lg:row-span-1">
          <div>
            <h4 class="text-xl font-bold text-accent">Contact</h4>
            <p class="mt-1 text-sm text-text-light">Let's start a conversation.</p>
          </div>
          <span class="absolute bottom-6 right-6 text-4xl leading-none text-text-light transition-transform duration-200 ease-in-out group-hover:translate-x-1 group-hover:text-accent">&rarr;</span>
        </a>
      </section>

      <div class="my-16 flex items-center gap-4">
        <div class="h-px flex-grow bg-border"></div>
        <svg class="h-4 w-4 shrink-0 fill-text-light" viewBox="0 0 16 16" version="1.1" width="16" height="16" aria-hidden="true">
          <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 0 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Z"></path>
        </svg>
        <div class="h-px flex-grow bg-border"></div>
      </div>

      <article id="content" class="space-y-16">
        <section id="about">
          <h2 class="group relative mb-4 border-b border-border pb-2 text-2xl font-medium text-heading before:absolute before:left-0 before:top-0 before:text-base before:font-normal before:text-text-light before:content-['##'] before:mr-2 before:inline-block pl-6">About</h2>
          <div class="flex items-start gap-8">
            <blockquote class="border-l-2 border-border pl-4 text-text-light">
              I'm a multidisciplinary digital artist and designer from Martinez, Georgia. With nearly a decade of experience, I partner with clients to turn ambitious ideas into reality. My process is built on clear communication and a commitment to craft, whether I'm designing an application or composing a soundtrack.
            </blockquote>
          </div>
        </section>

        <section id="services">
          <h2 class="group relative mb-4 border-b border-border pb-2 text-2xl font-medium text-heading before:absolute before:left-0 before:top-0 before:text-base before:font-normal before:text-text-light before:content-['##'] before:mr-2 before:inline-block pl-6">Services</h2>
          <div class="grid gap-6 md:grid-cols-2">
            <a href="#" class="group relative flex items-center gap-4 overflow-hidden rounded-lg border border-border bg-bg p-4 transition-transform duration-200 ease-in-out hover:-translate-y-1 hover:border-accent hover:shadow-lg hover:shadow-bg/40">
              <img src="https://placehold.co/60x60/0D1117/58A6FF?text=ID" alt="Brand & Identity Icon" class="h-12 w-12 shrink-0 rounded-md" />
              <div>
                <strong class="text-heading">Brand & Identity:</strong> Logos, visual systems, and strategy.
              </div>
              <span class="absolute bottom-4 right-4 text-4xl leading-none text-text-light transition-transform duration-200 ease-in-out group-hover:translate-x-1 group-hover:text-accent">&rarr;</span>
            </a>
            <a href="#" class="group relative flex items-center gap-4 overflow-hidden rounded-lg border border-border bg-bg p-4 transition-transform duration-200 ease-in-out hover:-translate-y-1 hover:border-accent hover:shadow-lg hover:shadow-bg/40">
              <img src="https://placehold.co/60x60/0D1117/58A6FF?text=UX" alt="Digital & UI/UX Design Icon" class="h-12 w-12 shrink-0 rounded-md" />
              <div>
                <strong class="text-heading">Digital & UI/UX Design:</strong> Websites, applications, and interactive prototypes.
              </div>
              <span class="absolute bottom-4 right-4 text-4xl leading-none text-text-light transition-transform duration-200 ease-in-out group-hover:translate-x-1 group-hover:text-accent">&rarr;</span>
            </a>
          </div>
        </section>

        <section id="projects">
          <h2 class="group relative mb-4 border-b border-border pb-2 text-2xl font-medium text-heading before:absolute before:left-0 before:top-0 before:text-base before:font-normal before:text-text-light before:content-['##'] before:mr-2 before:inline-block pl-6">Projects</h2>
          <p class="text-text-light">A curated list of my work across various disciplines. For a deeper dive, please visit the full projects page.</p>
          <div class="mt-6 grid gap-6 md:grid-cols-2">
            <a href="#" class="group relative block overflow-hidden rounded-lg border border-border bg-bg transition-transform duration-200 ease-in-out hover:-translate-y-1 hover:border-accent hover:shadow-lg hover:shadow-bg/40">
              <img src="https://placehold.co/400x225/161B22/E6EDF3?text=Chrono+Corp" alt="Chrono Corp project screenshot" class="aspect-video w-full object-cover" />
              <div class="p-4 md:p-6">
                <div class="flex items-center justify-between">
                  <h4 class="text-xl font-bold text-heading">Chrono Corp</h4>
                  <span class="rounded-full bg-tag-bg px-2 py-1 text-sm text-accent">UI/UX Design</span>
                </div>
                <p class="mt-2 text-sm text-text-light">A time-tracking application for creative freelancers.</p>
                <span class="absolute bottom-4 right-4 text-4xl leading-none text-text-light transition-transform duration-200 ease-in-out group-hover:translate-x-1 group-hover:text-accent">&rarr;</span>
              </div>
            </a>
            <a href="#" class="group relative block overflow-hidden rounded-lg border border-border bg-bg transition-transform duration-200 ease-in-out hover:-translate-y-1 hover:border-accent hover:shadow-lg hover:shadow-bg/40">
              <img src="https://placehold.co/400x225/161B22/E6EDF3?text=Aether+Systems" alt="Aether Systems branding project" class="aspect-video w-full object-cover" />
              <div class="p-4 md:p-6">
                <div class="flex items-center justify-between">
                  <h4 class="text-xl font-bold text-heading">Aether Systems</h4>
                  <span class="rounded-full bg-tag-bg px-2 py-1 text-sm text-accent">Brand Identity</span>
                </div>
                <p class="mt-2 text-sm text-text-light">A complete branding package for a cloud computing company.</p>
                <span class="absolute bottom-4 right-4 text-4xl leading-none text-text-light transition-transform duration-200 ease-in-out group-hover:translate-x-1 group-hover:text-accent">&rarr;</span>
              </div>
            </a>
          </div>
        </section>

        <section id="blog">
          <h2 class="group relative mb-4 border-b border-border pb-2 text-2xl font-medium text-heading before:absolute before:left-0 before:top-0 before:text-base before:font-normal before:text-text-light before:content-['##'] before:mr-2 before:inline-block pl-6">Latest Thoughts</h2>
          <div class="mt-6 grid gap-6 md:grid-cols-2">
            <a href="#" class="group relative block overflow-hidden rounded-lg border border-border bg-bg transition-transform duration-200 ease-in-out hover:-translate-y-1 hover:border-accent hover:shadow-lg hover:shadow-bg/40">
              <img src="https://placehold.co/400x225/161B22/58A6FF?text=UI+Design" alt="Thumbnail for UI Design article" class="aspect-video w-full object-cover" />
              <div class="p-4 md:p-6">
                <div class="flex items-center justify-between">
                  <h4 class="text-xl font-bold text-heading">Reducing Cognitive Load in UI Design</h4>
                  <span class="rounded-full bg-tag-bg px-2 py-1 text-sm text-accent">Article</span>
                </div>
                <p class="mt-2 text-sm text-text-light">July 30, 2025</p>
                <span class="absolute bottom-4 right-4 text-4xl leading-none text-text-light transition-transform duration-200 ease-in-out group-hover:translate-x-1 group-hover:text-accent">&rarr;</span>
              </div>
            </a>
            <a href="#" class="group relative block overflow-hidden rounded-lg border border-border bg-bg transition-transform duration-200 ease-in-out hover:-translate-y-1 hover:border-accent hover:shadow-lg hover:shadow-bg/40">
              <img src="https://placehold.co/400x225/161B22/58A6FF?text=Fintech" alt="Thumbnail for Nova Fintech review" class="aspect-video w-full object-cover" />
              <div class="p-4 md:p-6">
                <div class="flex items-center justify-between">
                  <h4 class="text-xl font-bold text-heading">Working with the team at Nova Fintech</h4>
                  <span class="rounded-full bg-tag-bg px-2 py-1 text-sm text-accent">Review</span>
                </div>
                <p class="mt-2 text-sm text-text-light">June 22, 2025</p>
                <span class="absolute bottom-4 right-4 text-4xl leading-none text-text-light transition-transform duration-200 ease-in-out group-hover:translate-x-1 group-hover:text-accent">&rarr;</span>
              </div>
            </a>
          </div>
        </section>

        <section id="newsletter">
          <h2 class="group relative mb-4 border-b border-border pb-2 text-2xl font-medium text-heading before:absolute before:left-0 before:top-0 before:text-base before:font-normal before:text-text-light before:content-['##'] before:mr-2 before:inline-block pl-6">Subscribe</h2>
          <p class="text-text-light">Receive occasional updates about new projects and articles. No spam.</p>
          <form class="mt-4 flex flex-col gap-2 md:flex-row" action="#">
            <input class="w-full rounded-lg border border-border bg-bg px-4 py-2 text-text placeholder-text-light focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30" type="email" placeholder="your-email@domain.com" required />
            <button type="submit" class="cta-button w-full shrink-0 md:w-auto">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M4 8a.5.5 0 0 1 .5-.5h5.793L8.146 5.354a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L10.293 8.5H4.5A.5.5 0 0 1 4 8z"></path>
              </svg>
              <span class="font-medium">Subscribe</span>
            </button>
          </form>
        </section>

        <section id="resume">
          <h2 class="group relative mb-4 border-b border-border pb-2 text-2xl font-medium text-heading before:absolute before:left-0 before:top-0 before:text-base before:font-normal before:text-text-light before:content-['##'] before:mr-2 before:inline-block pl-6">R&eacute;sum&eacute;</h2>
          <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
            <div class="rounded-lg border border-border bg-bg p-6">
              <h4 class="mb-4 border-b border-border pb-3 text-lg font-bold text-accent">Design</h4>
              <ul class="list-inside list-[url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2216%22 height=%2216%22 fill=%22%2358A6FF%22 viewBox=%220 0 16 16%22><path d=%22M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z%22/></svg>')] space-y-3 pl-3 text-text-light">
                <li>UI/UX & Prototyping</li>
                <li>Branding & Art Direction</li>
                <li>Iconography & Illustration</li>
              </ul>
            </div>
            <div class="rounded-lg border border-border bg-bg p-6">
              <h4 class="mb-4 border-b border-border pb-3 text-lg font-bold text-accent">Tools & Tech</h4>
              <ul class="list-inside list-[url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2216%22 height=%2216%22 fill=%22%2358A6FF%22 viewBox=%220 0 16 16%22><path d=%22M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z%22/></svg>')] space-y-3 pl-3 text-text-light">
                <li>Figma & Adobe Creative Suite</li>
                <li>HTML, CSS & JavaScript</li>
                <li>Astro, Node.js & Blender</li>
              </ul>
            </div>
            <div class="rounded-lg border border-border bg-bg p-6 lg:col-span-2">
              <h4 class="mb-4 border-b border-border pb-3 text-lg font-bold text-accent">Experience</h4>
              <p class="text-text-light"><strong class="text-heading">Freelance Digital Designer</strong></p>
              <p class="text-sm italic text-text-light">(2015 - Present)</p>
              <p class="mt-2 text-text-light">Partnered with over 50 clients, from startups to established companies, to deliver high-quality work.</p>
            </div>
            <div class="group flex flex-col items-center justify-center rounded-lg border border-border bg-tag-bg p-6 text-center transition-colors duration-200 hover:border-accent hover:bg-tag-bg/80">
              <h4 class="text-xl font-bold text-accent">Download Full R&eacute;sum&eacute;</h4>
              <p class="mt-2 text-sm text-text-light">Get the complete details on my skills and experience.</p>
              <a href="/resume.pdf" target="_blank" class="cta-button mt-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                  <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z" />
                  <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z" />
                </svg>
                <span class="font-medium">Download PDF</span>
              </a>
            </div>
          </div>
        </section>

        <section id="contact">
          <h2 class="group relative mb-4 border-b border-border pb-2 text-2xl font-medium text-heading before:absolute before:left-0 before:top-0 before:text-base before:font-normal before:text-text-light before:content-['##'] before:mr-2 before:inline-block pl-6">Contact</h2>
          <p class="text-text-light">I'm always open to new opportunities and collaborations. Send a message to start the conversation.</p>
          <form class="contact-form mt-6 space-y-4" action="#">
            <div>
              <label for="name" class="block text-text">Your Name:</label>
              <input class="mt-1 w-full rounded-lg border border-border bg-bg px-4 py-2 text-text placeholder-text-light focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30" type="text" id="name" name="name" required />
            </div>
            <div>
              <label for="email" class="block text-text">Your Email:</label>
              <input class="mt-1 w-full rounded-lg border border-border bg-bg px-4 py-2 text-text placeholder-text-light focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30" type="email" id="email" name="email" required />
            </div>
            <div>
              <label for="message" class="block text-text">Your Message:</label>
              <textarea class="mt-1 w-full rounded-lg border border-border bg-bg px-4 py-2 text-text placeholder-text-light focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30" id="message" name="message" rows="6" required></textarea>
            </div>
            <button type="submit" class="cta-button">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
