---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import { orange, blue, green, red, yellow, gray, black, white } from '../data/colors.js';
---

<Layout title="John Ogletree – Digital Artist & Designer" description="Portfolio and personal website of John Ogletree, a digital artist and designer based in Martinez, GA. Showcasing UI design, UX research, prototyping, and frontend development.">
		<section
			class="min-h-[60vh] flex flex-col justify-center items-center py-16"
			style={`background: linear-gradient(135deg, ${blue[50]}, ${white}, ${orange[100]})`}
		>
			<div class="w-full max-w-5xl flex flex-col md:flex-row items-center justify-center gap-8 md:gap-12 px-4">
				{/* Left cell: Avatar/graphic */}
				<div class="flex flex-col items-center flex-shrink-0 w-full md:w-1/4 mb-8 md:mb-0">
					<div class="rounded-full border-4 shadow-lg" style={`border-color: ${orange[400]}; background: linear-gradient(135deg, ${orange[100]}, ${yellow[100]})`}>
						<svg width="120" height="120" viewBox="0 0 120 120" fill="none">
							<circle cx="60" cy="60" r="56" fill={orange[200]} stroke={orange[400]} stroke-width="8" />
							<ellipse cx="60" cy="70" rx="32" ry="28" fill={yellow[100]} />
							<circle cx="60" cy="54" r="24" fill={orange[300]} />
							<ellipse cx="50" cy="50" rx="4" ry="6" fill={gray[900]} />
							<ellipse cx="70" cy="50" rx="4" ry="6" fill={gray[900]} />
							<path d="M50 72 Q60 80 70 72" stroke={gray[700]} stroke-width="3" fill="none" />
						</svg>
					</div>
					<span class="mt-4 text-sm font-mono text-orange-700">Your Creative Guide</span>
				</div>
				{/* Center cell: Heading/tagline */}
				<div class="flex flex-col items-center flex-1 text-center">
					<h1 class="text-4xl md:text-5xl font-extrabold font-mono mb-2" style={`color: ${orange[600]}`}>John Ogletree</h1>
					<p class="text-lg md:text-xl font-mono mb-4" style={`color: ${gray[700]}`}>Designing & building delightful digital experiences.<br/><span style={`color: ${blue[600]}`}>UI/UX, Animation, Frontend</span></p>
					<span class="inline-block px-4 py-1 rounded-full bg-orange-100 text-orange-700 text-xs tracking-widest uppercase shadow">Portfolio 2025</span>
				</div>
				{/* Right cell: Buttons */}
				<div class="flex flex-col gap-4 flex-shrink-0 w-full md:w-1/4 items-center md:items-end">
					<Button text="View Portfolio" href="#portfolio" variant="primary" />
					<Button text="Contact Me" href="#contact" variant="secondary" />
					<a href="https://github.com/john-ogletree" target="_blank" rel="noopener" class="mt-2 text-xs text-gray-500 hover:text-blue-600 font-mono underline">GitHub</a>
				</div>
			</div>
		</section>
	<hr style={`border: none; border-top: 2px solid ${gray[200]}; width: 80%; margin: 2rem auto;`} />
</Layout>