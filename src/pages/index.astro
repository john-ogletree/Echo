                                <div class="progress-bar" data-width="75%"></div>
                                <span>75%</span>
                            </div>
                        </div>
                        <div class="skill-item">
                            <div class="skill-info">
                                <svg class="skill-icon" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6l6 6l1.4-1.4zm5.2 0l4.6-4.6l-4.6-4.6L16 6l6 6l-6 6l-1.4-1.4z"/></svg>
