---
import Layout from '../layouts/Layout.astro';
---

<Layout title="John Ogletree">
  <div class="viewsource-container">
    <header class="browser-header">
      <div class="browser-controls">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
      </div>
      <div class="browser-address">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="2" y1="12" x2="22" y2="12"></line>
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
        </svg>
        <div class="address-bar">
          <span class="url-text">http://johnogletree.website/index.html</span>
        </div>
      </div>
    </header>

    <main class="viewsource-body">
      <pre><code><span class="comment">&lt;!-- 
  Welcome to my digital space!
  This is a simplified view of the site's structure.
  
  You'll find content organized in a way that feels familiar to developers.
--&gt;</span>
<span class="tag">&lt;!DOCTYPE html&gt;</span>
<span class="tag">&lt;html&gt;</span>
  <span class="tag">&lt;head&gt;</span>
    <span class="tag">&lt;title&gt;</span>John Ogletree<span class="tag">&lt;/title&gt;</span>
    <span class="tag">&lt;meta <span class="attr-name">charset</span>=<span class="attr-value">"UTF-8"</span>&gt;</span>
    <span class="tag">&lt;meta <span class="attr-name">name</span>=<span class="attr-value">"viewport"</span> <span class="attr-name">content</span>=<span class="attr-value">"width=device-width, initial-scale=1.0"</span>&gt;</span>
    <span class="tag">&lt;link <span class="attr-name">rel</span>=<span class="attr-value">"stylesheet"</span> <span class="attr-name">href</span>=<span class="attr-value">"/style.css"</span>&gt;</span>
  <span class="tag">&lt;/head&gt;</span>
  <span class="tag">&lt;body&gt;</span>

    <span class="tag">&lt;header <span class="attr-name">class</span>=<span class="attr-value">"site-header"</span>&gt;</span>
      <span class="tag">&lt;h1 <span class="attr-name">class</span>=<span class="attr-value">"logo"</span>&gt;</span>John Ogletree<span class="tag">&lt;/h1&gt;</span>
      <span class="tag">&lt;p <span class="attr-name">class</span>=<span class="attr-value">"tagline"</span>&gt;</span>Digital Artist & Designer<span class="tag">&lt;/p&gt;</span>
    <span class="tag">&lt;/header&gt;</span>

    <span class="tag">&lt;nav <span class="attr-name">class</span>=<span class="attr-value">"main-nav"</span>&gt;</span>
      <span class="tag">&lt;ul&gt;</span>
        <span class="tag">&lt;li&gt;&lt;a <span class="attr-name">href</span>=<span class="attr-value">"#about"</span>&gt;</span>About<span class="tag">&lt;/a&gt;&lt;/li&gt;</span>
        <span class="tag">&lt;li&gt;&lt;a <span class="attr-name">href</span>=<span class="attr-value">"#projects"</span>&gt;</span>Projects<span class="tag">&lt;/a&gt;&lt;/li&gt;</span>
        <span class="tag">&lt;li&gt;&lt;a <span class="attr-name">href</span>=<span class="attr-value">"#contact"</span>&gt;</span>Contact<span class="tag">&lt;/a&gt;&lt;/li&gt;</span>
      <span class="tag">&lt;/ul&gt;</span>
    <span class="tag">&lt;/nav&gt;</span>

    <span class="tag">&lt;main <span class="attr-name">class</span>=<span class="attr-value">"content-sections"</span>&gt;</span>
      <span class="tag">&lt;section <span class="attr-name">id</span>=<span class="attr-value">"about"</span>&gt;</span>
        <span class="tag">&lt;h2&gt;</span>About Me<span class="tag">&lt;/h2&gt;</span>
        <span class="tag">&lt;p&gt;</span>Hello, I'm John, a multidisciplinary digital artist and designer.<span class="tag">&lt;/p&gt;</span>
        <span class="tag">&lt;p&gt;</span>I have over 9 years of experience turning ideas into reality.<span class="tag">&lt;/p&gt;</span>
      <span class="tag">&lt;/section&gt;</span>

      <span class="tag">&lt;section <span class="attr-name">id</span>=<span class="attr-value">"projects"</span>&gt;</span>
        <span class="tag">&lt;h2&gt;</span>My Work<span class="tag">&lt;/h2&gt;</span>
        <span class="tag">&lt;div <span class="attr-name">class</span>=<span class="attr-value">"project-card"</span>&gt;</span>
          <span class="tag">&lt;h3&gt;</span>Project 1<span class="tag">&lt;/h3&gt;</span>
          <span class="tag">&lt;p&gt;</span>A time-tracking application.<span class="tag">&lt;/p&gt;</span>
        <span class="tag">&lt;/div&gt;</span>
        <span class="tag">&lt;div <span class="attr-name">class</span>=<span class="attr-value">"project-card"</span>&gt;</span>
          <span class="tag">&lt;h3&gt;</span>Project 2<span class="tag">&lt;/h3&gt;</span>
          <span class="tag">&lt;p&gt;</span>A complete branding package.<span class="tag">&lt;/p&gt;</span>
        <span class="tag">&lt;/div&gt;</span>
      <span class="tag">&lt;/section&gt;</span>
    <span class="tag">&lt;/main&gt;</span>

    <span class="tag">&lt;footer <span class="attr-name">class</span>=<span class="attr-value">"site-footer"</span>&gt;</span>
      <span class="tag">&lt;p&gt;</span>© <span class="tag">&lt;span <span class="attr-name">id</span>=<span class="attr-value">"year"</span>&gt;&lt;/span&gt;</span> John Ogletree<span class="tag">&lt;/p&gt;</span>
    <span class="tag">&lt;/footer&gt;</span>

  <span class="tag">&lt;/body&gt;</span>
<span class="tag">&lt;/html&gt;</span>
</code></pre>
      </div>
    </main>
  </div>
</Layout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    const yearSpan = document.getElementById('year');
    if (yearSpan) {
      yearSpan.textContent = new Date().getFullYear();
    }
  });
</script>

<style>
  :root {
    --bg-color: #2b2b2b;
    --text-color: #f1f1f1;
    --accent-color: #5d9bcf;
    --tag-color: #9cdcfe;
    --attr-name-color: #b5cea8;
    --attr-value-color: #ce9178;
    --comment-color: #6a9955;
    --line-number-color: #555555;
    --browser-bar-color: #3e3e3e;
    --browser-dot-red: #ff5f56;
    --browser-dot-yellow: #ffbd2e;
    --browser-dot-green: #27c93f;
    --font-mono: "Monaco", "Consolas", "Courier New", monospace;
  }

  body {
    background-color: var(--bg-color);
    color: var(--text-color);
    font-family: var(--font-mono);
  }

  .viewsource-container {
    width: 100%;
    max-width: 1000px;
    margin: 2rem auto;
    border: 1px solid var(--browser-bar-color);
    border-radius: 8px;
    overflow: hidden;
  }
  
  .browser-header {
    display: flex;
    align-items: center;
    padding: 0.5rem 1rem;
    background-color: var(--browser-bar-color);
    border-bottom: 1px solid var(--bg-color);
  }

  .browser-controls {
    display: flex;
    gap: 0.5rem;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot.red { background-color: var(--browser-dot-red); }
  .dot.yellow { background-color: var(--browser-dot-yellow); }
  .dot.green { background-color: var(--browser-dot-green); }

  .browser-address {
    display: flex;
    align-items: center;
    flex-grow: 1;
    background-color: var(--bg-color);
    border-radius: 4px;
    padding: 0.25rem 0.5rem;
    margin-left: 1rem;
  }

  .address-bar svg {
    width: 16px;
    height: 16px;
    margin-right: 0.5rem;
    color: var(--line-number-color);
  }
  
  .url-text {
    color: var(--text-color);
    font-size: 0.9rem;
  }

  .viewsource-body {
    background-color: var(--bg-color);
    padding: 1rem;
    overflow-x: auto;
    white-space: pre;
  }

  pre {
    margin: 0;
    color: var(--text-color);
    font-size: 0.9rem;
    line-height: 1.4;
  }

  /* Syntax Highlighting */
  .comment { color: var(--comment-color); }
  .tag { color: var(--tag-color); }
  .attr-name { color: var(--attr-name-color); }
  .attr-value { color: var(--attr-value-color); }
  .keyword { color: var(--accent-color); }
</style>