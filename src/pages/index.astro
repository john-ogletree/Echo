---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import Navigation from '../components/Navigation.astro';
---

<Layout>
    <div class="readme-container">
        <Navigation />
        <main class="readme-body">
            <slot />
        </main>
    </div>
    <Footer />
</Layout>

<script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
        const navToggle = document.getElementById('nav-toggle');
        const navDrawer = document.getElementById('nav-drawer-container');
        const navClose = document.querySelector('.nav-close');
        const body = document.body;
        function toggleMobileNav() {
            const isOpen = navDrawer.classList.contains('is-open');
            navDrawer.classList.toggle('is-open', !isOpen);
            navToggle.setAttribute('aria-expanded', !isOpen);
            body.classList.toggle('no-scroll', !isOpen);
        }

        if (navToggle && navDrawer) {
            navToggle.addEventListener('click', toggleMobileNav);
            navClose.addEventListener('click', toggleMobileNav);
        }

        const navLinks = document.querySelectorAll('.nav-links a');
        navLinks.forEach(link => {
            link.addEventListener('click', () => {
                if (navDrawer.classList.contains('is-open')) {
                    toggleMobileNav();
                }
            });
        });
        const yearSpan = document.getElementById('year');
        if (yearSpan) {
            yearSpan.textContent = new Date().getFullYear();
        }
    });
</script>

<style>
    @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;700&display=swap');

    :root {
        --color-bg: #F0EAD6; /* Light cream */
        --color-surface: #D4C9A8; /* Muted beige */
        --color-text: #3B2F2A; /* Deep brown-black */
        --color-text-light: #5B4F48; /* Dark brown-grey */
        --color-heading: #E07A5F; /* Warm terracotta orange */
        --color-accent: #3D87A6; /* Retro teal */
        --color-border: #A69E8C; /* Faded grey-brown */
        --color-tag-bg: rgba(61, 135, 166, 0.15); /* Faded teal transparency */
        --font-mono: 'IBM Plex Mono', Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        --padding-x: 2rem;
    }

    /* --- Base & Typography --- */
    html {
        scroll-behavior: smooth;
        scroll-padding-top: 80px;
    }
    body {
        background-color: var(--color-bg);
        color: var(--color-text);
        font-family: var(--font-mono);
        font-size: 16px;
        line-height: 1.7;
        margin: 0;
        padding: 0;
        transition: transform 0.3s ease-in-out;
    }
    body.no-scroll {
        overflow: hidden;
    }
    body.no-scroll .readme-body {
        filter: blur(5px);
        pointer-events: none;
    }
    h1, h2, h3, h4 {
        font-family: var(--font-mono);
        font-weight: 500;
        color: var(--color-heading);
        margin: 0;
    }
    h2 { font-size: 1.5rem; border-bottom: 1px solid var(--color-border); padding-bottom: 0.5rem; margin: 2.5rem 0 1rem 0;
    }
    h2::before {
        content: '##';
        color: var(--color-text-light);
        font-weight: 400;
        margin-right: 0.5rem;
    }
    p { margin: 0 0 1rem 0; max-width: 80ch; }
    a { color: var(--color-accent); text-decoration: none;
    }
    a:hover { text-decoration: underline; }
    hr { display: none; }
    ul { list-style: '- ';
    padding-left: 1.5rem; margin-bottom: 1rem;}
    blockquote {
        margin-left: 0;
        padding-left: 1rem;
        border-left: 3px solid var(--color-border);
        color: var(--color-text-light);
    }

    /* --- Main Layout --- */
    .readme-container {
        background-color: var(--color-surface);
    }
    .readme-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1rem var(--padding-x);
        border-bottom: 1px solid var(--color-border);
        position: sticky;
        top: 0;
        z-index: 10;
        background-color: var(--color-surface);
    }
    .header-left, .header-right {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .repo-title {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 1.25rem;
    }
    .icon-repo {
        fill: var(--color-text-light);
    }
    .readme-body {
        padding: 2rem var(--padding-x);
        transition: filter 0.3s ease-in-out;
    }

    /* --- Unified Card Grid System --- */
    .card-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-top: 1.5rem;
    }
    .card {
        position: relative;
        display: block;
        background-color: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        color: inherit;
        text-decoration: none;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        overflow: hidden;
    }
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
        border-color: var(--color-accent);
        text-decoration: none;
    }
    .card-image {
        width: 100%;
        height: auto;
        aspect-ratio: 16 / 9;
        object-fit: cover;
        display: block;
        background-color: var(--color-bg);
    }
    .card-info { padding: 1rem 1.25rem 2.5rem 1.25rem;
    }
    .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; }
    .card-header h4 { font-size: 1.1em;
    font-weight: 700; color: var(--color-heading); }
    .card-info p { font-size: 0.9em; color: var(--color-text-light); line-height: 1.6; margin: 0;
    }
    .post-date { font-size: 0.8em; color: var(--color-text-light); margin-top: 0.75rem; }
    .card-arrow {
        position: absolute;
        bottom: 0.75rem;
        right: 1rem;
        font-size: 1.75rem;
        color: var(--color-text-light);
        transition: transform 0.2s ease, color 0.2s ease;
    }
    .card:hover .card-arrow { transform: translateX(5px); color: var(--color-accent); }
    .tag {
        background-color: var(--color-tag-bg);
        padding: 0.2em 0.5em;
        border-radius: 6px; font-size: 0.85em; color: var(--color-accent);
        flex-shrink: 0; margin-left: 0.5rem;
    }
    .view-all-container {
        display: none;
    }

    .cta-button {
        background-color: var(--color-heading);
        color: var(--color-bg);
        border: 1px solid var(--color-heading);
        transition: background-color 0.2s ease, border-color 0.2s ease;
        font-weight: 700;
        padding: 0.75rem 1.5rem;
        text-decoration: none;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        justify-content: center;
        width: 100%;
        font-family: var(--font-mono);
    }
    .cta-button:hover {
        background-color: #D36C52;
        border-color: #D36C52;
    }

    /* --- Card Type: Service --- */
    .service-card { display: flex; align-items: center; gap: 1rem; padding: 1.25rem;
    overflow: hidden; }
    .service-icon { width: 50px; height: 50px; flex-shrink: 0; border-radius: 6px; background-color: var(--color-bg);
    }
    .service-card .card-arrow { bottom: auto; right: 1.25rem; }
    .service-card strong { color: var(--color-heading);
    }

    /* --- Card Type: Résumé --- */
    .resume-card { padding: 1.5rem; overflow: visible;
    }
    .resume-card h4 {
        color: var(--color-accent); margin-bottom: 1rem;
        border-bottom: 1px solid var(--color-border); padding-bottom: 0.75rem; font-size: 1.2em;
    }
    .resume-card ul { list-style: '✓  '; color: var(--color-text-light); padding-left: 1.25rem; margin: 0;
    }
    .resume-card li { margin-bottom: 0.75rem; padding-left: 0.5rem; }
    .resume-card p { color: var(--color-text-light); line-height: 1.6;
    margin: 0 0 0.5rem 0; }
    .resume-card p:last-child { margin-bottom: 0; }
    .resume-card p strong { color: var(--color-text);
    font-weight: 500; }
    .text-light-small { font-size: 0.9em; color: var(--color-text-light); }
    .resume-card.cta-card {
        background-color: var(--color-tag-bg);
    display: flex; flex-direction: column;
        justify-content: center; align-items: center; text-align: center;
    }
    .resume-card.cta-card:hover { background-color: rgba(61, 135, 166, 0.2);
    }

    /* --- Forms --- */
    .form-group { margin-bottom: 1.5rem;
    }
    .form-input {
        background-color: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: 6px;
        padding: 0.75rem 1rem;
        font-family: var(--font-mono);
        font-size: 1rem;
        color: var(--color-text);
        width: 100%;
        box-sizing: border-box;
    }
    .form-input:focus {
        outline: none;
        border-color: var(--color-accent);
        box-shadow: 0 0 0 3px rgba(61, 135, 166, 0.3);
    }
    .newsletter-form { display: flex; gap: 0.5rem;
    }

    /* --- Responsive --- */
    @media (max-width: 920px) {
        :root {
            --padding-x: 1.5rem;
        }
        .hero-header {
            flex-direction: column;
            text-align: center;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }
        .hero-info h1 {
            font-size: 1.75rem;
        }
        .hero-profile-picture {
            display: none;
        }
        .branded-hr {
            margin: 3rem 0;
        }
        .readme-container {
            position: relative;
        }
        .desktop-search { display: none; }
        .mobile-search { display: block;
        }
        
        .nav-toggle {
            display: block;
        }
        
        .nav-close {
            display: none;
        }

        .nav-drawer-container.is-open ~ .nav-toggle {
            display: none;
        }

        .nav-drawer-container .nav-close {
            display: none;
        }
        
        .nav-drawer-container.is-open .nav-close {
            display: block;
        }

        .nav-drawer-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 300px;
            height: 100vh;
            background-color: var(--color-surface);
            border-right: 1px solid var(--color-border);
            transform: translateX(-100%);
            transition: transform 0.3s ease-in-out;
            z-index: 99;
            box-shadow: 4px 0 16px rgba(0, 0, 0, 0.5);
        }
        .nav-drawer-container.is-open {
            transform: translateX(0);
        }
        
        .main-nav {
            display: flex;
            flex-direction: column;
            height: 100%;
            padding: 0;
        }

        .nav-header-mobile {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1.5rem 1.5rem 1rem 1.5rem;
            border-bottom: 1px solid var(--color-border);
            flex-shrink: 0;
        }

        .nav-header-mobile .mobile-search {
            flex-grow: 1;
        }

        .nav-socials {
            list-style: none;
            padding: 1.5rem;
            border-top: 1px solid var(--color-border);
            display: flex;
            justify-content: center;
            gap: 2rem;
            flex-shrink: 0;
        }
        .nav-socials a { color: var(--color-text-light);
        }
        .nav-socials a:hover { color: var(--color-accent); }
        .nav-socials svg { width: 24px; height: 24px;
        }
        
        .dashboard-grid {
            grid-template-columns: 1fr 1fr;
            grid-template-areas:
                "about about"
                "services resume"
                "projects projects"
                "blog newsletter"
                "contact contact";
        }
        .about-container { display: block; }
        .profile-picture {
            float: left;
            margin-right: 1.5rem;
            margin-bottom: 1rem;
        }
    }

    @media (max-width: 768px) {
        :root {
            --padding-x: 1rem;
        }
        .readme-header {
            padding: 1rem var(--padding-x);
        }
        .readme-body {
            padding: 1.5rem var(--padding-x);
        }
        .dashboard-grid {
            grid-template-columns: 1fr;
            grid-template-areas: "about" "services" "projects" "blog" "resume" "newsletter" "contact";
        }
        h2 { font-size: 1.25rem;
        }
        .hero-header {
            flex-direction: column;
            text-align: center;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }
        .hero-info h1 {
            font-size: 1.75rem;
        }
        .hero-profile-picture {
            display: none;
        }
        .branded-hr {
            margin: 3rem 0;
        }
        .about-container {
            flex-direction: column;
            align-items: center;
            text-align: center;
        }
        .about-container .profile-picture {
            margin-right: 0;
            margin-bottom: 1rem;
        }
        .about-container blockquote {
            text-align: center;
        }
        .newsletter-form { flex-direction: column; }
        .card-grid { grid-template-columns: 1fr;
        }
    }
</style>