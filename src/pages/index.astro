<style>
    /* ... (Root and base styles remain unchanged) ... */
    
    /* --- About Me Section --- */
    .about-me-section {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-top: 4rem;
        align-items: start;
    }

    /* --- REVAMPED PROFILE CARD --- */
    .profile-card {
        background-color: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }
    .profile-main-info {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid var(--color-border);
    }
    .profile-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex: 1;
    }
    .profile-picture {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid var(--color-border);
    }
    .profile-header-info {
        display: flex;
        flex-direction: column;
    }
    .profile-header-info h3 {
        font-size: 1.5rem;
        margin: 0;
        line-height: 1.2;
    }
    .profile-username {
        color: var(--color-text-light);
        font-size: 1rem;
        margin: 0 0 0.5rem 0;
    }
    .profile-card .social-links {
        display: flex;
        gap: 1rem;
    }
    .profile-card .social-links a {
        color: var(--color-text-light);
        transition: color 0.2s, transform 0.2s;
    }
    .profile-card .social-links a:hover {
        color: var(--color-accent);
        transform: scale(1.1);
    }
    .profile-card .social-links svg {
        width: 20px;
        height: 20px;
    }
    .profile-stats {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        min-width: 150px;
    }
    .stat-item {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        width: 100%;
    }
    .stat-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--color-heading);
    }
    .stat-label {
        font-size: 0.8rem;
        color: var(--color-text-light);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    /* ... (Rest of profile card styles remain the same) ... */
    
    /* ... (Skills, About Button, and other styles remain the same) ... */

    /* --- Responsive --- */
    /* ... (Responsive styles remain the same) ... */
