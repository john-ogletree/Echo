---
import Layout from '../layouts/Layout.astro';
import Terminal from '../components/Terminal.astro';
import Profile from '../components/Profile.astro';
import Banner from '../components/Banner.astro';
import Services from '../components/Services.astro';
import Projects from '../components/Projects.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import Blog from '../components/Blog.astro';
import BlogPostCard from '../components/BlogPostCard.astro';


// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
  <main>
    <Banner
      title="Welcome to My Site"
      subtitle="This is a simple banner created with Astro."
    >
      <Button text="Learn More" link="/about" variant="primary" />
    </Banner>

    <Terminal title="example.js">
      <p><span class="terminal-prompt">$</span> node example.js</p>
      <p>Hello from the reusable terminal!</p>
    </Terminal>

    <Profile
      name="John Doe"
      bio="A passionate developer who loves creating amazing things with code."
      avatar="https://i.pravatar.cc/150"
      buttonLink="/skills"
    >
      <a href="https://github.com" target="_blank" class="social-link">GitHub</a>
      <a href="https://twitter.com" target="_blank" class="social-link">Twitter</a>
    </Profile>

    <Services title="Our Services">
      <Card
        type="service"
        title="Web Development"
        description="We build modern, responsive, and performant websites."
      />
      <Card
        type="service"
        title="Mobile Development"
        description="We create beautiful and user-friendly mobile applications."
      />
      <Card
        type="service"
        title="UI/UX Design"
        description="We design intuitive and engaging user interfaces."
      />
      <Card
        type="service"
        title="Digital Marketing"
        description="We help you grow your business and reach new customers."
      />
    </Services>

    <Projects title="Our Projects">
      <Card
        type="project"
        contentType="video"
        title="Video Project"
        description="A project featuring an embedded video."
        videoSrc="https://www.youtube.com/embed/dQw4w9WgXcQ" /* Rick Astley - Never Gonna Give You Up */
        link="#"
      />
      <div class="vertical-project-column">
        <Card
          type="project"
          contentType="image"
          title="Image Project"
          description="A project showcasing beautiful images."
          image="/astro.svg"
          link="#"
        />
        <Card
          type="project"
          contentType="book"
          title="Book Project"
          description="A project about a fascinating book."
          image="/background.svg"
          author="Jane Doe"
          link="#"
        />
      </div>
      <Card
        type="project"
        contentType="audio"
        title="Audio Project"
        description="A project with an embedded audio track."
        audioSrc="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3"
        link="#"
      />
    </Projects>

    <Blog title="Latest Blog Posts">
      <BlogPostCard
        title="My First Blog Post"
        date="September 10, 2025"
        excerpt="This is a short excerpt from my first blog post. Read more to learn about my journey."
        link="/blog/first-post"
      />
      <BlogPostCard
        title="Astro vs. Next.js"
        date="September 05, 2025"
        excerpt="A comparison of two popular frameworks for building modern websites."
        link="/blog/astro-vs-nextjs"
      />
      <BlogPostCard
        title="Tips for Clean Code"
        date="August 28, 2025"
        excerpt="Learn some essential tips and tricks to write cleaner and more maintainable code."
        link="/blog/clean-code-tips"
      />
    </Blog>
  </main>
</Layout>

<style>
  main {
    padding: 2rem;
  }

  .terminal-prompt {
    color: #e0e0e0; /* Light gray for prompt */
  }

  .social-link {
    margin-right: 1rem;
    color: #00e676; /* Vibrant green for links */
    text-decoration: none;
  }

  .social-link:hover {
    text-decoration: underline;
  }

  .vertical-project-column {
    display: flex;
    flex-direction: column;
    gap: 2rem; /* Same gap as the grid */
    grid-row: span 2; /* Make it span two rows */
  }
</style>
