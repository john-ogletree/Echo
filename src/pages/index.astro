---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';

---

<Layout title="John Ogletree - Digital Artist & Designer" description="Portfolio and personal website of John Ogletree, a digital artist and designer based in Martinez, GA. Showcasing UI design, UX research, prototyping, and frontend development." keywords="John Ogletree, Digital Artist, Designer, UI Design, UX Research, Prototyping, Frontend Development, Martinez GA, Portfolio">
        <div class="readme-container">
                <main class="readme-body">
                                                                                                                                                <div class="rounded-lg mb-8 px-8 py-4 text-center bg-blue-500 text-white">
                                                                                                                                                        <p class="m-0 font-mono font-medium text-[1.1rem]">This is a banner! ✨</p>
                                                                                                                                                </div>

                                                                                                                                                                                                                        <section class="hero-section flex flex-col items-center text-center mb-12">
                                                                                                                                                                                                                                <h1 class="text-4xl md:text-5xl font-extrabold font-mono text-gray-900 mb-4">John Ogletree</h1>
                                                                                                                                                                                                                                <h2 class="text-xl md:text-2xl font-mono text-blue-500 mb-6">Digital Artist & Designer</h2>
                                                                                                                                                                                                                                <div class="w-full flex flex-col md:flex-row md:items-center md:justify-center gap-4 md:gap-8 mb-8">
                                                                                                                                                                                                                                        <p class="max-w-2xl text-lg md:text-xl text-gray-700 font-mono mb-0 text-center md:text-left">
                                                                                                                                                                                                                                                Welcome to my portfolio! I specialize in UI design, UX research, prototyping, and frontend development. Based in Martinez, GA, I create beautiful, functional digital experiences.
                                                                                                                                                                                                                                        </p>
                                                                                                                                                                                                                                        <div class="flex-shrink-0 flex justify-center md:justify-start">
                                                                                                                                                                                                                                                <Button text="View Portfolio" href="#portfolio" variant="primary" />
                                                                                                                                                                                                                                        </div>
                                                                                                                                                                                                                                </div>
                                                                                                                                                                                                                        </section>
                </main>
        </div>
</Layout>