---
import Layout from '../layouts/Layout.astro';
---

<Layout title="John Ogletree - Home">
  <nav class="main-nav-bar">
    <div class="nav-container">
      <a href="/" class="nav-logo">John Ogletree</a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/creations">Creations</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>
  </nav>
  <div class="hero">
    <div class="hero-container">
      <h2 class="hero-title">Creative Solutions for a Digital World</h2>
      <p class="hero-subtitle">I'm a multidisciplinary digital artist and designer with over nine years of experience, ready to help you bring your ideas to life.</p>
      <a href="/creations" class="hero-cta">See My Work</a>
    </div>
  </div>
  <div class="profile-card-section">
    <div class="profile-card">
      <img src="https://placehold.co/120x120/161B22/E6EDF3?text=JO" alt="A portrait of John Ogletree" class="profile-picture">
      <h3>John Ogletree</h3>
      <blockquote>I'm a multidisciplinary digital artist and designer from Martinez, Georgia. With nearly a decade of experience, I partner with clients to turn ambitious ideas into reality. My process is built on clear communication and a commitment to craft, whether I'm designing an application or composing a soundtrack.</blockquote>
    </div>
  </div>
</Layout>

<style>
  /* Base styles for a full-width layout */
  body {
    margin: 0;
    padding: 0;
  }
  
  .main-nav-bar {
    background-color: #333;
    color: white;
    padding: 1rem 0;
    width: 100%;
  }
  
  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 2rem;
  }
  
  .nav-logo {
    font-size: 1.5rem;
    font-weight: bold;
    color: white;
    text-decoration: none;
  }
  
  .nav-links {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 1rem;
  }
  
  .nav-links a {
    color: white;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  
  .nav-links a:hover {
    color: #ccc;
  }
  
  .hero {
    background-color: #2d3748;
    color: white;
    padding: 4rem 2rem;
    text-align: center;
    width: 100%;
  }
  
  .hero-container {
    max-width: 800px;
    margin: 0 auto;
  }
  
  .hero-title {
    font-size: 3rem;
    font-weight: bold;
    margin-bottom: 1rem;
  }
  
  .hero-subtitle {
    font-size: 1.25rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }
  
  .hero-cta {
    display: inline-block;
    background-color: #4299e1;
    color: white;
    padding: 0.75rem 2rem;
    border-radius: 9999px;
    text-decoration: none;
    font-weight: bold;
    transition: background-color 0.3s ease;
  }
  
  .hero-cta:hover {
    background-color: #3182ce;
  }
  
  .profile-card-section {
    background-color: #f0f0f0;
    padding: 4rem 2rem;
    text-align: center;
    width: 100%;
    /* Remove max-width on the section to make it full-width */
    max-width: none;
  }
  
  .profile-card {
    max-width: 800px;
    margin: 0 auto;
    background-color: white;
    padding: 2rem;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }
  
  .profile-picture {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 1rem;
  }
  
  .profile-card h3 {
    font-size: 2rem;
    font-weight: bold;
    margin-bottom: 1rem;
  }
  
  .profile-card blockquote {
    font-style: italic;
    color: #555;
    margin: 0;
  }
  
  .content {
    padding: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }
  
  .services-overview,
  .projects-overview,
  .blog-overview {
    padding: 4rem 2rem;
    text-align: center;
    max-width: none;
  }
  
  .services-header,
  .projects-header,
  .blog-header {
    margin-bottom: 3rem;
    max-width: 1200px;
    margin: 0 auto 3rem auto;
  }

  .services-grid,
  .projects-grid,
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .services-title,
  .projects-title,
  .blog-title {
    font-size: 2.5rem;
    font-weight: bold;
    margin-bottom: 1rem;
  }
  
  .services-intro,
  .projects-intro,
  .blog-intro {
    font-size: 1.15rem;
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
  }
  
  .service-card {
    background-color: #f9f9f9;
    padding: 2rem;
    border-radius: 8px;
    text-align: left;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .service-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 15px rgba(0, 0, 0, 0.1);
  }
  
  .service-title {
    font-size: 1.5rem;
    font-weight: bold;
    margin-bottom: 0.5rem;
  }
  
  .service-description {
    font-size: 1rem;
    line-height: 1.6;
    color: #555;
  }
  
  .project-card {
    background-color: #f9f9f9;
    border-radius: 8px;
    text-align: left;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    overflow: hidden;
  }
  
  .project-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 15px rgba(0, 0, 0, 0.1);
  }
  
  .project-image {
    width: 100%;
    height: 250px;
    object-fit: cover;
  }
  
  .project-info {
    padding: 1.5rem;
  }
  
  .project-title {
    font-size: 1.5rem;
    font-weight: bold;
    margin-bottom: 0.5rem;
  }
  
  .project-description {
    font-size: 1rem;
    line-height: 1.6;
    color: #555;
    margin-bottom: 1rem;
  }
  
  .project-cta {
    display: inline-block;
    background-color: #4299e1;
    color: white;
    padding: 0.5rem 1.5rem;
    border-radius: 9999px;
    text-decoration: none;
    font-weight: bold;
    transition: background-color 0.3s ease;
  }
  
  .project-cta:hover {
    background-color: #3182ce;
  }
  
  .blog-post-card {
    background-color: #f9f9f9;
    border-radius: 8px;
    text-align: left;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    overflow: hidden;
  }
  
  .blog-post-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 15px rgba(0, 0, 0, 0.1);
  }
  
  .blog-post-image {
    width: 100%;
    height: 250px;
    object-fit: cover;
  }
  
  .blog-post-info {
    padding: 1.5rem;
  }
  
  .blog-post-title {
    font-size: 1.5rem;
    font-weight: bold;
    margin-bottom: 0.5rem;
  }
  
  .blog-post-description {
    font-size: 1rem;
    line-height: 1.6;
    color: #555;
    margin-bottom: 1rem;
  }
  
  .blog-post-cta {
    display: inline-block;
    background-color: #333;
    color: white;
    padding: 0.5rem 1.5rem;
    border-radius: 9999px;
    text-decoration: none;
    font-weight: bold;
    transition: background-color 0.3s ease;
  }
  
  .blog-post-cta:hover {
    background-color: #555;
  }
  
  .newsletter-signup-section {
    padding: 4rem 2rem;
    text-align: center;
    background-color: #2d3748;
    color: white;
    width: 100%;
    max-width: none;
  }
  
  .newsletter-content {
    max-width: 700px;
    margin: 0 auto;
  }
  
  .newsletter-title {
    font-size: 2rem;
    font-weight: bold;
    margin-bottom: 1rem;
  }
  
  .newsletter-subtitle {
    font-size: 1.15rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }
  
  .newsletter-form {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }
  
  .newsletter-form input {
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
    border-radius: 9999px;
    border: none;
    width: 100%;
    max-width: 400px;
  }
  
  .newsletter-form button {
    padding: 0.75rem 2rem;
    font-size: 1rem;
    border-radius: 9999px;
    border: none;
    background-color: #4299e1;
    color: white;
    font-weight: bold;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }
  
  .newsletter-form button:hover {
    background-color: #3182ce;
  }

  .resume-overview-section {
    padding: 4rem 2rem;
    text-align: center;
    background-color: #f0f0f0;
    width: 100%;
    max-width: none;
  }
  
  .resume-content {
    max-width: 700px;
    margin: 0 auto;
  }
  
  .resume-title {
    font-size: 2.5rem;
    font-weight: bold;
    margin-bottom: 1rem;
  }
  
  .resume-subtitle {
    font-size: 1.15rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    color: #555;
  }
  
  .resume-cta {
    display: inline-block;
    background-color: #333;
    color: white;
    padding: 0.75rem 2rem;
    border-radius: 9999px;
    text-decoration: none;
    font-weight: bold;
    transition: background-color 0.3s ease;
  }
  
  .resume-cta:hover {
    background-color: #555;
  }
  
  .contact-section {
    padding: 4rem 2rem;
    text-align: center;
    width: 100%;
    max-width: none;
  }
  
  .contact-content {
    max-width: 700px;
    margin: 0 auto;
  }
  
  .contact-title {
    font-size: 2.5rem;
    font-weight: bold;
    margin-bottom: 1rem;
  }
  
  .contact-subtitle {
    font-size: 1.15rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    color: #555;
  }
  
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    text-align: left;
    max-width: 500px;
    margin: 0 auto;
  }
  
  .form-group {
    display: flex;
    flex-direction: column;
  }
  
  .form-group label {
    font-size: 1rem;
    font-weight: bold;
    margin-bottom: 0.5rem;
    color: #333;
  }
  
  .form-group input,
  .form-group textarea {
    padding: 0.75rem;
    font-size: 1rem;
    border-radius: 8px;
    border: 1px solid #ccc;
    background-color: #f9f9f9;
  }
  
  .contact-form button {
    padding: 0.75rem 2rem;
    font-size: 1rem;
    border-radius: 9999px;
    border: none;
    background-color: #4299e1;
    color: white;
    font-weight: bold;
    cursor: pointer;
    transition: background-color 0.3s ease;
    align-self: center;
  }
  
  .contact-form button:hover {
    background-color: #3182ce;
  }

  .main-footer {
    background-color: #333;
    color: white;
    padding: 4rem 2rem;
    width: 100%;
  }
  
  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    text-align: left;
  }
  
  .footer-brand .footer-logo {
    font-size: 1.5rem;
    font-weight: bold;
    color: white;
    text-decoration: none;
    display: block;
    margin-bottom: 0.5rem;
  }
  
  .footer-brand .footer-tagline {
    font-size: 0.9rem;
    color: #ccc;
  }
  
  .footer-links h4,
  .footer-social h4,
  .footer-contact-info h4 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
    font-weight: bold;
  }
  
  .footer-links ul,
  .footer-social ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .footer-links li,
  .footer-social li {
    margin-bottom: 0.5rem;
  }
  
  .footer-links a,
  .footer-social a,
  .footer-contact-info a {
    color: #ccc;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  
  .footer-links a:hover,
  .footer-social a:hover,
  .footer-contact-info a:hover {
    color: #4299e1;
  }
  
  .footer-social i {
    margin-right: 0.5rem;
  }
  
  .footer-contact-info p {
    margin: 0.5rem 0;
  }
  
  .footer-bottom {
    border-top: 1px solid #555;
    margin-top: 2rem;
    padding-top: 2rem;
    text-align: center;
  }
  
  .footer-bottom p {
    margin: 0;
    font-size: 0.9rem;
    color: #ccc;
  }
</style>