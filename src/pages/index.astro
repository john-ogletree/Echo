---
import Layout from '../layouts/Layout.astro';
import Terminal from '../components/Terminal.astro';
import Profile from '../components/Profile.astro';
import Banner from '../components/Banner.astro';
import Services from '../components/Services.astro';
import Projects from '../components/Projects.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import Blog from '../components/Blog.astro';

import projectsData from '../data/projects.json';
import blogPostsData from '../data/blogPosts.json';
import reviewsData from '../data/reviews.json';

const latestProject = projectsData[projectsData.length - 1];
const latestBlogPost = blogPostsData[blogPostsData.length - 1];
const latestReview = reviewsData[reviewsData.length - 1];

const latestProjectsByType = {};

// Assuming projectsData is ordered by date, latest first.
// If not, a more robust sorting would be needed.
projectsData.forEach(project => {
  if (!latestProjectsByType[project.contentType]) {
    latestProjectsByType[project.contentType] = project;
  }
});

const latestVideoProject = latestProjectsByType.video;
const latestImageProject = latestProjectsByType.image;
const latestBookProject = latestProjectsByType.book;
const latestAudioProject = latestProjectsByType.audio;

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
  <main>
    <Banner
      title="Welcome to My Site"
      subtitle="This is a simple banner created with Astro."
    >
      <Button text="Learn More" link="/about" variant="primary" />
    </Banner>

    <Terminal title="example.js">
      <p><span class="terminal-prompt">$</span> node example.js</p>
      <p>Hello from the reusable terminal!</p>
    </Terminal>

    <Profile
      name="John Doe"
      bio="A passionate developer who loves creating amazing things with code."
      avatar="https://i.pravatar.cc/150"
      buttonLink="/skills"
    >
      <a href="https://github.com" target="_blank" class="social-link">GitHub</a>
      <a href="https://twitter.com" target="_blank" class="social-link">Twitter</a>
    </Profile>

    <Services title="Our Services">
      <Card
        type="service"
        title="Web Development"
        description="We build modern, responsive, and performant websites."
      />
      <Card
        type="service"
        title="Mobile Development"
        description="We create beautiful and user-friendly mobile applications."
      />
      <Card
        type="service"
        title="UI/UX Design"
        description="We design intuitive and engaging user interfaces."
      />
      <Card
        type="service"
        title="Digital Marketing"
        description="We help you grow your business and reach new customers."
      />
    </Services>

    <Projects title="Our Latest Projects">
      {latestVideoProject &&
        <Card
          type={latestVideoProject.type}
          contentType={latestVideoProject.contentType}
          title={latestVideoProject.title}
          description={latestVideoProject.description}
          image={latestVideoProject.image}
          videoSrc={latestVideoProject.videoSrc}
          author={latestVideoProject.author}
          audioSrc={latestVideoProject.audioSrc}
          link={latestVideoProject.link}
        />
      }
      {latestImageProject &&
        <Card
          type={latestImageProject.type}
          contentType={latestImageProject.contentType}
          title={latestImageProject.title}
          description={latestImageProject.description}
          image={latestImageProject.image}
          videoSrc={latestImageProject.videoSrc}
          author={latestImageProject.author}
          audioSrc={latestImageProject.audioSrc}
          link={latestImageProject.link}
        />
      }
      {latestBookProject &&
        <Card
          type={latestBookProject.type}
          contentType={latestBookProject.contentType}
          title={latestBookProject.title}
          description={latestBookProject.description}
          image={latestBookProject.image}
          videoSrc={latestBookProject.videoSrc}
          author={latestBookProject.author}
          audioSrc={latestBookProject.audioSrc}
          link={latestBookProject.link}
        />
      }
      {latestAudioProject &&
        <Card
          type={latestAudioProject.type}
          contentType={latestAudioProject.contentType}
          title={latestAudioProject.title}
          description={latestAudioProject.description}
          image={latestAudioProject.image}
          videoSrc={latestAudioProject.videoSrc}
          author={latestAudioProject.author}
          audioSrc={latestAudioProject.audioSrc}
          link={latestAudioProject.link}
        />
      }
    </Projects>

    <Blog title="Latest Blog Posts">
      <Card
        type="blog"
        title={latestBlogPost.title}
        description={latestBlogPost.excerpt}
        date={latestBlogPost.date}
        link={latestBlogPost.link}
      />
    </Blog>

    <Blog title="Latest Review">
      <Card
        type="review"
        title={latestReview.title}
        description={latestReview.description}
        author={latestReview.author}
        rating={latestReview.rating}
      />
    </Blog>
  </main>
</Layout>

<style>
  main {
    padding: 2rem;
  }

  .terminal-prompt {
    color: #e0e0e0; /* Light gray for prompt */
  }

  .social-link {
    margin-right: 1rem;
    color: #00e676; /* Vibrant green for links */
    text-decoration: none;
  }

  .social-link:hover {
    text-decoration: underline;
  }

  .vertical-project-column {
    display: flex;
    flex-direction: column;
    gap: 2rem; /* Same gap as the grid */
    grid-row: span 2; /* Make it span two rows */
  }
</style>