---
import Layout from '../layouts/Layout.astro';
---

<Layout title="John Ogletree // Portfolio">
  <div class="ide-container">
    <header class="ide-header">
      <div class="window-controls">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
      </div>
      <div class="file-tabs">
        <a href="#about" class="tab active">About.js</a>
        <a href="#projects" class="tab">Projects.jsx</a>
        <a href="#contact" class="tab">Contact.md</a>
      </div>
    </header>

    <main class="ide-body">
      <section id="about" class="editor-pane">
        <div class="line-numbers">
          <span>1</span><span>2</span><span>3</span><span>4</span><span>5</span><span>6</span><span>7</span><span>8</span><span>9</span><span>10</span><span>11</span><span>12</span><span>13</span><span>14</span><span>15</span>
        </div>
        <div class="code-content">
          <pre><code><span class="comment">/**
 * @author  John Ogletree
 * @title   Digital Artist & Designer
 * @location Martinez, GA
 */</span>

<span class="keyword">const</span> <span class="variable">bio</span> <span class="operator">=</span> {
  <span class="property">summary</span> <span class="string">`I'm a multidisciplinary digital artist 
    with nearly a decade of experience. I partner 
    with clients to turn ambitious ideas into reality.`</span>,
  
  <span class="property">process</span> <span class="string">`Built on clear communication and a 
    commitment to craft, whether I'm designing an
    application or composing a soundtrack.`</span>
};</code></pre>
        </div>
      </section>

      <section id="projects" class="output-pane">
        <h2 class="pane-title"><span class="comment">// Featured Work</span></h2>
        <div class="project-grid">
          
          <div class="project-card">
            <div class="card-header">ChronoCorp.jsx</div>
            <div class="card-body">
              <h3 class="project-name">Chrono Corp</h3>
              <p class="project-description">A time-tracking application for creative freelancers.</p>
              <div class="tags">
                <span class="tag blue">UI/UX Design</span>
                <span class="tag green">React</span>
              </div>
            </div>
          </div>

          <div class="project-card">
            <div class="card-header">AetherSystems.css</div>
            <div class="card-body">
              <h3 class="project-name">Aether Systems</h3>
              <p class="project-description">A complete branding package for a cloud computing company.</p>
              <div class="tags">
                <span class="tag purple">Brand Identity</span>
                <span class="tag orange">Figma</span>
              </div>
            </div>
          </div>
          
          <div class="project-card">
            <div class="card-header">ProjectNova.mp3</div>
            <div class="card-body">
              <h3 class="project-name">Project Nova</h3>
              <p class="project-description">Soundtrack and SFX for an indie space exploration game.</p>
               <div class="tags">
                <span class="tag pink">Sound Design</span>
                <span class="tag yellow">Ableton</span>
              </div>
            </div>
          </div>
          
          <div class="project-card">
            <div class="card-header">CityscapeLogistics.html</div>
            <div class="card-body">
              <h3 class="project-name">Cityscape Logistics</h3>
              <p class="project-description">Website and mobile app for an urban delivery service.</p>
              <div class="tags">
                 <span class="tag blue">Web Design</span>
                 <span class="tag green">Astro</span>
              </div>
            </div>
          </div>

        </div>
      </section>

      <footer id="contact" class="terminal-pane">
        <h2 class="pane-title"><span class="prompt-arrow">&gt;</span><span class="prompt-text"> Get in Touch</span></h2>
        <p class="terminal-line">I'm always open to new opportunities and collaborations.</p>
        <div class="terminal-line command">
          <a href="mailto:contact@johnogletree.com" class="contact-button">
            contact@johnogletree.com<span class="cursor"></span>
          </a>
        </div>
      </footer>
    </main>
  </div>
</Layout>

<style>
  :root {
    --bg-primary: #282a36;
    --bg-secondary: #21222c;
    --bg-header: #191a21;
    --border-color: #44475a;
    --text-primary: #f8f8f2;
    --text-secondary: #bd93f9;
    --comment: #6272a4;
    --keyword: #ff79c6;
    --string: #f1fa8c;
    --variable: #50fa7b;
    --property: #8be9fd;
    --operator: #ff79c6;
    
    --tag-blue: rgba(139, 233, 253, 0.2);
    --tag-blue-text: #8be9fd;
    --tag-green: rgba(80, 250, 123, 0.2);
    --tag-green-text: #50fa7b;
    --tag-purple: rgba(189, 147, 249, 0.2);
    --tag-purple-text: #bd93f9;
    --tag-pink: rgba(255, 121, 198, 0.2);
    --tag-pink-text: #ff79c6;
    --tag-orange: rgba(255, 184, 108, 0.2);
    --tag-orange-text: #ffb86c;
    --tag-yellow: rgba(241, 250, 140, 0.2);
    --tag-yellow-text: #f1fa8c;

    --font-sans: 'Inter', -apple-system, sans-serif;
    --font-mono: 'Fira Code', 'JetBrains Mono', monospace;
  }

  html {
    scroll-behavior: smooth;
  }
  
  body {
    background-color: var(--bg-secondary);
    color: var(--text-primary);
    font-family: var(--font-sans);
    margin: 0;
    padding: 2rem;
  }

  .ide-container {
    max-width: 1100px;
    margin: 0 auto;
    background-color: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    overflow: hidden;
  }

  .ide-header {
    background-color: var(--bg-header);
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--border-color);
    padding: 0 0.75rem;
  }

  .window-controls {
    display: flex;
    gap: 0.5rem;
    padding: 1rem 0.5rem;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .dot.red { background-color: #ff5f56; }
  .dot.yellow { background-color: #ffbd2e; }
  .dot.green { background-color: #27c93f; }

  .file-tabs {
    display: flex;
    flex-grow: 1;
  }

  .tab {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--comment);
    text-decoration: none;
    padding: 0.75rem 1rem;
    border-right: 1px solid var(--border-color);
    position: relative;
    transition: color 0.2s, background-color 0.2s;
  }
  .tab:hover {
    color: var(--text-primary);
    background-color: var(--bg-primary);
  }
  .tab.active {
    color: var(--text-primary);
    background-color: var(--bg-primary);
    border-bottom: 2px solid var(--keyword);
  }

  .editor-pane {
    display: flex;
    padding: 1.5rem 0;
  }

  .line-numbers {
    font-family: var(--font-mono);
    color: var(--comment);
    text-align: right;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-top: 0.25rem;
  }

  .code-content {
    flex-grow: 1;
  }
  .code-content pre {
    margin: 0;
    font-family: var(--font-mono);
    line-height: 1.7;
  }

  .comment { color: var(--comment); font-style: italic; }
  .keyword { color: var(--keyword); }
  .variable { color: var(--variable); }
  .string { color: var(--string); }
  .property { color: var(--property); }
  .operator { color: var(--keyword); }

  .output-pane, .terminal-pane {
    padding: 2rem 2.5rem;
    border-top: 1px dashed var(--border-color);
  }
  .pane-title {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    margin-top: 0;
    margin-bottom: 2rem;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .project-card {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .project-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.25);
  }

  .card-header {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.5rem 1rem;
    background-color: var(--bg-header);
    color: var(--comment);
  }
  .card-body {
    padding: 1rem 1.5rem 1.5rem;
  }
  .project-name {
    color: var(--text-secondary);
    margin: 0.5rem 0;
  }
  .project-description {
    color: var(--text-primary);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
  }

  .tag.blue { background-color: var(--tag-blue); color: var(--tag-blue-text); }
  .tag.green { background-color: var(--tag-green); color: var(--tag-green-text); }
  .tag.purple { background-color: var(--tag-purple); color: var(--tag-purple-text); }
  .tag.pink { background-color: var(--tag-pink); color: var(--tag-pink-text); }
  .tag.orange { background-color: var(--tag-orange); color: var(--tag-orange-text); }
  .tag.yellow { background-color: var(--tag-yellow); color: var(--tag-yellow-text); }

  .terminal-pane {
    background-color: var(--bg-header);
  }
  .prompt-arrow { color: var(--keyword); }
  .prompt-text { color: var(--text-primary); margin-left: 0.5rem; }
  .terminal-line {
    font-family: var(--font-mono);
    color: var(--text-primary);
    margin: 0.5rem 0 1rem;
  }
  .command {
    margin-left: 1rem;
  }
  .contact-button {
    color: var(--string);
    text-decoration: none;
    font-family: var(--font-mono);
    display: inline-block;
    padding: 0.5rem 1rem;
    border: 1px solid var(--string);
    border-radius: 4px;
    transition: background-color 0.2s;
  }
  .contact-button:hover {
    background-color: rgba(241, 250, 140, 0.1);
  }
  .cursor {
    display: inline-block;
    width: 10px;
    height: 1.2rem;
    background-color: var(--string);
    animation: blink 1s step-end infinite;
    vertical-align: bottom;
    margin-left: 0.5rem;
  }

  @keyframes blink {
    from, to { background-color: transparent; }
    50% { background-color: var(--string); }
  }

  @media (max-width: 768px) {
    body { padding: 0; }
    .ide-container { border-radius: 0; border-left: none; border-right: none; }
    .file-tabs { display: none; } /* Hide tabs on mobile for simplicity */
    .editor-pane { padding: 1.5rem 0; }
    .line-numbers { padding: 0 1rem; }
    .output-pane, .terminal-pane { padding: 2rem 1.5rem; }
  }
</style>