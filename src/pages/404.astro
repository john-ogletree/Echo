---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404: Page Not Found">
    <div class="readme-container">
        <main class="readme-body">
            <div class="error-page-container">
                <div class="terminal-window">
                    <div class="terminal-header">
                        <div class="dots">
                            <span class="dot" style="background:#ff5f56;"></span>
                            <span class="dot" style="background:#ffbd2e;"></span>
                            <span class="dot" style="background:#27c93f;"></span>
                        </div>
                        <span>bash</span>
                    </div>
                    <div class="terminal-body">
                        <p class="terminal-prompt">
                            <span class="prompt-user">user@echo</span><span class="prompt-char">:</span><span class="prompt-dir">~</span><span class="prompt-char">$</span>
                            <span>cd /pages/this-exact-page-you-wanted</span>
                        </p>
                        <div class="terminal-output">
                            <p class="error-message">Error: No such file or directory.</p>
                        </div>
                         <p class="terminal-prompt">
                            <span class="prompt-user">user@echo</span><span class="prompt-char">:</span><span class="prompt-dir">~</span><span class="prompt-char">$</span>
                            <span>ls -l /available-pages</span>
                        </p>
                        <div class="terminal-output permissions">
                            <p>drw-r--r-- 1 user staff 256 Aug 16 01:06 <a href="/">/start</a></p>
                            <p>drw-r--r-- 1 user staff 256 Aug 16 01:06 <a href="/bio/index">/profile</a></p>
                            <p>drw-r--r-- 1 user staff 256 Aug 16 01:06 <a href="/projects/index">/creations</a></p>
                        </div>
                    </div>
                </div>

                <div class="error-text-content">
                    <h2>404 - Lost in the Echo</h2>
                    <p>The page you requested couldn't be found. It might have been moved, deleted, or maybe it's just hiding. You can try searching or head back to the start.</p>
                    <div class="error-actions">
                        <a href="/" class="view-all-button">Return to Start</a>
                    </div>
                </div>
            </div>
        </main>
    </div>
</Layout>

<style>
    /* --- Base & Reused Styles --- */
    :root {
        --color-bg: #F0EAD6;
        --color-surface: #D4C9A8;
        --color-text: #3B2F2A;
        --color-text-light: #5B4F48;
        --color-heading: #E07A5F;
        --color-accent: #3D87A6;
        --color-border: #A69E8C;
        --font-mono: 'IBM Plex Mono', Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        --padding-x: 2rem;
    }
    h2 { 
        font-size: clamp(1.25rem, 3vw, 1.5rem);
        border-bottom: 1px solid var(--color-border);
        padding-bottom: 0.5rem; 
        margin: 0 0 1.5rem 0;
    }
    h2::before {
        content: '##';
        color: var(--color-text-light);
        font-weight: 400;
        margin-right: 0.5rem;
    }
    p { 
        margin: 0 0 1.5rem 0; 
        color: var(--color-text-light);
        font-size: 1.1rem;
        line-height: 1.7;
    }
    
    /* --- Main Page Layout --- */
    .readme-body {
        padding: 2rem var(--padding-x);
        max-width: 1400px;
        margin: 0 auto;
    }
    .error-page-container {
        max-width: 800px;
        margin: 2rem auto;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
    }

    /* --- Terminal Styles --- */
    .terminal-window {
        background-color: #2E282A;
        color: #F0EAD6;
        border-radius: 8px;
        border: 1px solid var(--color-border);
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        overflow: hidden;
        width: 100%;
        text-align: left;
    }
    .terminal-header {
        background-color: #5B4F48;
        padding: 0.5rem 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.8rem;
    }
    .terminal-header .dots {
        display: flex;
        gap: 0.5rem;
        margin-right: auto;
    }
    .terminal-header .dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
    }
    .terminal-body {
        padding: 1.5rem;
        font-size: 1rem;
    }
    .terminal-prompt {
        margin: 0 0 0.5rem 0;
        color: #F0EAD6;
    }
    .prompt-user { color: #81a2be; }
    .prompt-char { color: #b48ead; }
    .prompt-dir { color: #a3be8c; }
    .terminal-output {
        margin: 0 0 1.5rem 0;
    }
    .error-message {
        color: #E07A5F;
        margin: 0;
    }
    .permissions p {
        margin: 0.25rem 0;
        color: #F0EAD6;
        font-size: 1rem;
    }
    .permissions a {
        color: var(--color-accent);
        text-decoration: underline;
    }

    /* --- Content & Actions --- */
    .error-text-content {
        max-width: 60ch;
    }
    .view-all-button {
        background-color: var(--color-heading);
        color: var(--color-bg);
        border: 1px solid var(--color-heading);
        transition: background-color 0.2s ease, border-color 0.2s ease;
        font-weight: 700;
        padding: 0.75rem 2rem;
        text-decoration: none;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-mono);
    }
    .view-all-button:hover {
        background-color: #D36C52;
        border-color: #D36C52;
        color: var(--color-bg);
        text-decoration: none;
    }
    
    /* --- Responsive --- */
    @media (max-width: 768px) {
       :root {
            --padding-x: 1rem;
        }
        .readme-body {
            padding: 1.5rem var(--padding-x);
        }
        .terminal-body {
            padding: 1rem;
            font-size: 0.9rem;
        }
        .permissions p {
            font-size: 0.9rem;
        }
    }
</style>