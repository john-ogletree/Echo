---
// Get the HTTP status code from the request.
const statusCode = Astro.response.status;

// Define a map of error codes to their titles and messages.
// This list is comprehensive but can be extended with any other HTTP status code.
const errorMessages = {
    400: { title: 'Bad Request', message: 'The server could not understand the request.' },
    401: { title: 'Unauthorized', message: 'The request requires user authentication.' },
    402: { title: 'Payment Required', message: 'This is an experimental code for future use.' },
    403: { title: 'Forbidden', message: 'You do not have permission to access this resource.' },
    404: { title: 'Not Found', message: 'The page you are looking for does not exist.' },
    405: { title: 'Method Not Allowed', message: 'The request method is not supported for this resource.' },
    406: { title: 'Not Acceptable', message: 'The server cannot produce a response that matches the request headers.' },
    407: { title: 'Proxy Authentication Required', message: 'You must authenticate with the proxy server.' },
    408: { title: 'Request Timeout', message: 'The server timed out waiting for the request.' },
    409: { title: 'Conflict', message: 'The request could not be completed due to a conflict.' },
    410: { title: 'Gone', message: 'The requested resource is no longer available.' },
    411: { title: 'Length Required', message: 'The server refuses to accept the request without a defined content length.' },
    412: { title: 'Precondition Failed', message: 'One or more conditions in the request headers were not met.' },
    413: { title: 'Payload Too Large', message: 'The request is larger than the server is willing to process.' },
    414: { title: 'URI Too Long', message: 'The URI provided was too long for the server to process.' },
    415: { title: 'Unsupported Media Type', message: 'The request entity has a media type that the server does not support.' },
    416: { title: 'Range Not Satisfiable', message: 'The client has requested a portion of the resource that cannot be supplied.' },
    417: { title: 'Expectation Failed', message: 'The expectation given in the request headers could not be met.' },
    421: { title: 'Misdirected Request', message: 'The request was directed at a server that is unable to produce a response.' },
    422: { title: 'Unprocessable Entity', message: 'The request was well-formed but could not be processed due to semantic errors.' },
    423: { title: 'Locked', message: 'The resource that is being accessed is locked.' },
    424: { title: 'Failed Dependency', message: 'The request failed because it was dependent on another failed request.' },
    425: { title: 'Too Early', message: 'The server is unwilling to risk processing a request that might be replayed.' },
    426: { title: 'Upgrade Required', message: 'The server requires the client to upgrade to a different protocol.' },
    428: { title: 'Precondition Required', message: 'The origin server requires the request to be conditional.' },
    429: { title: 'Too Many Requests', message: 'You have sent too many requests in a given amount of time.' },
    431: { title: 'Request Header Fields Too Large', message: 'The server is unwilling to process the request because its header fields are too large.' },
    451: { title: 'Unavailable For Legal Reasons', message: 'Access to this resource has been legally denied.' },
    500: { title: 'Internal Server Error', message: 'Something went wrong on our end. Please try again later.' },
    501: { title: 'Not Implemented', message: 'The server does not support the functionality required to fulfill the request.' },
    502: { title: 'Bad Gateway', message: 'The server received an invalid response from an upstream server.' },
    503: { title: 'Service Unavailable', message: 'The server is currently unavailable due to maintenance or overload.' },
    504: { title: 'Gateway Timeout', message: 'The server did not get a response in time from an upstream server.' },
    505: { title: 'HTTP Version Not Supported', message: 'The server does not support the HTTP protocol version used in the request.' },
    506: { title: 'Variant Also Negotiates', message: 'The server has an internal configuration error.' },
    507: { title: 'Insufficient Storage', message: 'The server is unable to store the representation needed to complete the request.' },
    508: { title: 'Loop Detected', message: 'The server detected an infinite loop while processing the request.' },
    510: { title: 'Not Extended', message: 'Further extensions to the request are required for the server to fulfill it.' },
    511: { title: 'Network Authentication Required', message: 'The client needs to authenticate to gain network access.' },
};

// Use the message for the specific status code, or a default one if not found.
const { title, message } = errorMessages[statusCode] || {
    title: 'An Error Occurred',
    message: 'We apologize for the inconvenience. Please try again later.',
};
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            color: #333;
            background-color: #f4f7f6;
            text-align: center;
            padding: 50px;
        }

        .container {
            max-width: 600px;
            margin: auto;
            background: #fff;
            padding: 40px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        h1 {
            font-size: 8rem;
            margin-bottom: 0.5rem;
            color: #d9534f;
        }

        h2 {
            font-size: 1.5rem;
            margin-top: 0;
            color: #555;
        }

        p {
            font-size: 1rem;
            line-height: 1.6;
        }

        .link-home {
            display: inline-block;
            margin-top: 20px;
            padding: 10px 20px;
            background-color: #007bff;
            color: #fff;
            text-decoration: none;
            border-radius: 5px;
            transition: background-color 0.3s ease;
        }

        .link-home:hover {
            background-color: #0056b3;
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>{statusCode}</h1>
        <h2>{title}</h2>
        <p>{message}</p>
        <a href="/" class="link-home">Go to Homepage</a>
    </div>

</body>
</html>