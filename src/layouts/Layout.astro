---
import { setupI18n } from '../i18n';
import en from '../locales/en.json';
import es from '../locales/es.json';
import fr from '../locales/fr.json';

interface Props {
	title: string;
	description: string;
	keywords?: string;
	lang?: string;
}

const { title, description, keywords, lang = 'en' } = Astro.props;

const resources = {
  en: { translation: en },
  es: { translation: es },
  fr: { translation: fr },
};

const i18n = await setupI18n(resources, lang);

const translatedTitle = i18n.t(title);
const translatedDescription = i18n.t(description);
const translatedKeywords = keywords ? i18n.t(keywords) : undefined;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={translatedDescription} />
		{translatedKeywords && <meta name="keywords" content={translatedKeywords} />}
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{translatedTitle}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
<style>
	html,
	body {
		width: 100%;
		height: 100%;
	}
</style>
