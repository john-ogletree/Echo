---
import i18n from '../i18n';

interface Props {
	title: string;
	description: string;
	keywords?: string;
	lang?: string;
}

const { title, description, keywords, lang = 'en' } = Astro.props;

i18n.changeLanguage(lang);

const translatedTitle = i18n.t(title);
const translatedDescription = i18n.t(description);
const translatedKeywords = keywords ? i18n.t(keywords) : undefined;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={translatedDescription} />
		{translatedKeywords && <meta name="keywords" content={translatedKeywords} />}
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{translatedTitle}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
<style>
	html,
	body {
		width: 100%;
		height: 100%;
	}
</style>
