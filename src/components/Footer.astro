---
// You can remove the frontmatter if you don't need any Astro component scripts here
---

<footer class="readme-footer retro-footer">
    <div class="footer-grid-retro">
        <div class="footer-column-retro">
            <h4>John Ogletree <span class="badge status">status: available for hire</span></h4>
            <p class="footer-tagline">Digital Artist & Designer based in Martinez, GA.</p>
        </div>
        <hr class="retro-hr" />
        <div class="footer-column-retro-explore">
            <h4>Explore</h4>
            <ul class="footer-links-retro">
                <li><a href="/directory/index">Directory</a></li>
                <li><a href="/bio/index">About</a></li>
                <li><a href="/services/index">Services</a></li>
                <li><a href="/projects/index">Projects</a></li>
                <li><a href="/thoughts/index">Log</a></li>
                <li><a href="/resume/index">Résumé</a></li>
                <li><a href="/forms/index">Contact</a></li>
            </ul>
        </div>
        <hr class="retro-hr" />
        <div class="footer-column-retro-connect">
            <h4>Connect</h4>
            <ul class="footer-socials-retro">
                <li><a href="#" aria-label="GitHub Profile">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
                </a></li>
                <li><a href="#" aria-label="LinkedIn Profile">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
                </a></li>
                <li><a href="#" aria-label="Dribbble Profile">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M8.56 2.75c4.37 6.03 6.02 9.42 8.03 17.72m2.54-15.38c-3.72 4.35-8.94 4.66-16.88 7.02"></path><path d="M2.75 8.56c3.12-1.64 8.7-2.73 17.72-2.26"></path></svg>
                </a></li>
            </ul>
        </div>
        <div class="footer-bottom-bar retro-bottom">
            <p>© <span id="year"></span> John Ogletree</p>
            <a href="#" class="back-to-top">Back to top ↑</a>
        </div>
    </div>
</footer>

<style>
    .readme-footer {
        padding: 2.5rem var(--padding-x) 1.5rem var(--padding-x);
        margin: 2rem auto 0 auto;
        border-top: 1px solid var(--color-border);
    }
    
    /* New styles for Retro Footer */
    .footer-grid-retro {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .footer-column-retro h4 {
        color: var(--color-accent);
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .retro-hr {
        display: block;
        height: 1px;
        background-color: var(--color-border);
        border: none;
        margin: 0.5rem 0;
    }

    .footer-column-retro-explore,
    .footer-column-retro-connect {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .footer-links-retro {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1.5rem;
    }

    .footer-links-retro a {
        color: var(--color-text-light);
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .footer-links-retro a:hover {
        color: var(--color-heading);
    }

    .footer-socials-retro {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        gap: 1.5rem;
    }

    .footer-socials-retro a {
        color: var(--color-text-light);
        transition: color 0.2s ease;
    }

    .footer-socials-retro a:hover {
        color: var(--color-heading);
    }

    .retro-bottom {
        padding-top: 1rem;
    }

    .footer-bottom-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--color-border);
        font-size: 0.9rem;
        color: var(--color-text-light);
    }

    .footer-bottom-bar p {
        margin: 0;
    }

    .back-to-top {
        color: var(--color-text-light);
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .back-to-top:hover {
        color: var(--color-accent);
        text-decoration: none;
    }

    /* --- Responsive --- */
    @media (max-width: 920px) {
        .hero-header {
            flex-direction: column;
            text-align: center;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }
        .hero-info h1 {
            font-size: 1.75rem;
        }
        .hero-profile-picture {
            display: none;
        }
        .branded-hr {
            margin: 3rem 0;
        }
        .readme-container {
            position: relative;
        }
        .desktop-search {
            display: none;
        }
        .mobile-search {
            display: block;
        }
        
        .nav-toggle {
            display: block;
        }
        
        .nav-close {
            display: none;
        }
        
        .nav-drawer-container.is-open ~ .nav-toggle {
            display: none;
        }

        .nav-drawer-container .nav-close {
            display: none;
        }
        
        .nav-drawer-container.is-open .nav-close {
            display: block;
        }

        .nav-drawer-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 300px;
            height: 100vh;
            background-color: var(--color-surface);
            border-right: 1px solid var(--color-border);
            transform: translateX(-100%);
            transition: transform 0.3s ease-in-out;
            z-index: 99;
            box-shadow: 4px 0 16px rgba(0, 0, 0, 0.5);
        }

        .nav-drawer-container.is-open {
            transform: translateX(0);
        }
        
        .main-nav {
            display: flex;
            flex-direction: column;
            height: 100%;
            padding: 0;
        }

        .nav-header-mobile {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1.5rem 1.5rem 1rem 1.5rem;
            border-bottom: 1px solid var(--color-border);
            flex-shrink: 0;
        }

        .nav-header-mobile .mobile-search {
            flex-grow: 1;
        }

        .nav-socials {
            list-style: none;
            padding: 1.5rem;
            border-top: 1px solid var(--color-border);
            display: flex;
            justify-content: center;
            gap: 2rem;
            flex-shrink: 0;
        }

        .nav-socials a {
            color: var(--color-text-light);
        }

        .nav-socials a:hover {
            color: var(--color-accent);
        }

        .nav-socials svg {
            width: 24px;
            height: 24px;
        }
        
        .dashboard-grid {
            grid-template-columns: 1fr 1fr;
            grid-template-areas:
                "about about"
                "services resume"
                "projects projects"
                "blog newsletter"
                "contact contact";
        }

        .about-container {
            display: block;
        }

        .profile-picture {
            float: left;
            margin-right: 1.5rem;
            margin-bottom: 1rem;
        }
    }

    @media (max-width: 768px) {
        .readme-header {
            padding: 1rem var(--padding-x);
        }
        .readme-body {
            padding: 1.5rem var(--padding-x);
        }
        .dashboard-grid {
            grid-template-columns: 1fr;
            grid-template-areas: "about" "services" "projects" "blog" "resume" "newsletter" "contact";
        }
        h2 {
            font-size: 1.25rem;
        }
        .hero-header {
            flex-direction: column;
            text-align: center;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }
        .hero-info h1 {
            font-size: 1.75rem;
        }
        .hero-profile-picture {
            display: none;
        }
        .branded-hr {
            margin: 3rem 0;
        }
        .about-container {
            flex-direction: column;
            align-items: center;
            text-align: center;
        }
        .about-container .profile-picture {
            margin-right: 0;
            margin-bottom: 1rem;
        }
        .about-container blockquote {
            text-align: center;
        }
        .newsletter-form {
            flex-direction: column;
        }
        .card-grid {
            grid-template-columns: 1fr;
        }
        .footer-links-retro {
            justify-content: center;
        }
        .footer-socials-retro {
            justify-content: center;
        }
        .footer-column-retro h4 {
            justify-content: center;
        }
        .footer-column-retro-explore,
        .footer-column-retro-connect {
            flex-direction: column;
            align-items: center;
        }
    }
</style>