---
const { title, description, image, link } = Astro.props;
---
<div class="project-card">
  <a href={link} target="_blank">
    <img src={image} alt={title} class="project-image" />
    <div class="project-info">
      <h3>{title}</h3>
      <p>{description}</p>
    </div>
  </a>
</div>

<style>
  .project-card {
    background-color: #f9f9f9;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease;
  }

  .project-card:hover {
    transform: translateY(-5px);
  }

  .project-card a {
    text-decoration: none;
    color: inherit;
  }

  .project-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .project-info {
    padding: 1.5rem;
  }

  .project-info h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .project-info p {
    font-size: 1.1rem;
    color: #555;
  }
</style>
