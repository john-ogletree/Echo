---
const { title } = Astro.props;
import Button from '../components/Button.astro';
---
<div class="projects">
  <h2>{title}</h2>
  <div class="projects-grid">
    <slot />
  </div>
  <div class="view-all-container">
    <Button text="View All Projects" link="#" variant="full" />
  </div>
</div>

<style>
  .projects {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid #333333; /* Darker border */
  }

  .projects h2 {
    font-size: 1.5rem;
    text-align: center;
    margin-bottom: 2rem;
    color: #00e676; /* Vibrant green for heading */
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .view-all-container {
    text-align: center;
  }
</style>