---
const { type, title, description, image, link, contentType, videoSrc, author, audioSrc } = Astro.props;
import Button from './Button.astro';

let cardClass = 'card';
if (type === 'project') {
  cardClass += ' project-card';
} else if (type === 'service') {
  cardClass += ' service-card';
}

if (contentType) {
  cardClass += ` content-${contentType}`;
}
---
<div class={cardClass}>
  {type === 'project' && (contentType === 'image' || contentType === 'book') ? (
    <div class="card-content-horizontal">
      {image &&
        <a href={link} target="_blank">
          <img src={image} alt={title} class="card-image-small" />
        </a>
      }
      <div class="card-info">
        <div class="card-text-and-button">
          <div>
            <h3>{title}</h3>
            <p>{description}</p>
          </div>
          {link &&
            <Button text="View Details" link={link} variant="secondary" />
          }
        </div>
        {contentType === 'book' && author &&
          <p class="book-author">{author}</p>
        }
      </div>
    </div>
  ) : (
    <>
      {type === 'project' && contentType === 'video' && videoSrc &&
        <div class="video-container">
          <iframe src={videoSrc} frameborder="0" allowfullscreen></iframe>
        </div>
      }
      {type === 'project' && contentType === 'audio' && audioSrc &&
        <div class="audio-container">
          <audio controls src={audioSrc}></audio>
        </div>
      }
      <div class="card-info">
        <div class="card-text-and-button">
          <div>
            <h3>{title}</h3>
            <p>{description}</p>
          </div>
          {type === 'project' && link &&
            <Button text="View Details" link={link} variant="secondary" />
          }
        </div>
      </div>
    </>
  )}
</div>

<style>
  .card {
    background-color: #1a1a1a; /* Dark background */
    border: 1px solid #333333; /* Darker border */
    overflow: hidden;
    color: #e0e0e0; /* Light text */
    transition: transform 0.3s ease;
  }

  .card.project-card {
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  }

  .card.project-card:hover {
    transform: translateY(-5px);
  }

  .card.service-card {
    padding: 1.5rem;
    text-align: center;
  }

  .card-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .card-image-small {
    width: 100px; /* Smaller width for horizontal layout */
    height: auto;
    object-fit: cover;
    margin-right: 1rem;
  }

  .card-info {
    padding: 1rem;
    flex-grow: 1; /* Allow info to take remaining space */
  }

  .card-text-and-button {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem; /* Space between text and button */
  }

  .card-info h3 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
    color: #00e676; /* Vibrant green for heading */
  }

  .card-info p {
    font-size: 0.9rem;
    color: #e0e0e0; /* Light text */
    margin-bottom: 0; /* Remove margin-bottom as flex handles spacing */
  }

  /* Specific styles for content types */
  .video-container,
  .audio-container {
    width: 100%;
    height: 200px;
    background-color: #000;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .video-container iframe,
  .audio-container audio {
    width: 100%;
    height: 100%;
  }

  .book-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1rem;
  }

  .book-cover {
    width: 120px;
    height: auto;
    margin-bottom: 0.5rem;
  }

  .book-author {
    font-size: 0.8rem;
    color: #00e676;
  }

  .card-content-horizontal {
    display: flex;
    align-items: center;
    padding: 1rem; /* Add padding to the container */
  }
</style>
