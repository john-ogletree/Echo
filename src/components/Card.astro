---
const { type, title, description, image, link } = Astro.props;

let cardClass = 'card';
if (type === 'project') {
  cardClass += ' project-card';
} else if (type === 'service') {
  cardClass += ' service-card';
}
---
<div class={cardClass}>
  {type === 'project' && image &&
    <a href={link} target="_blank">
      <img src={image} alt={title} class="card-image" />
    </a>
  }
  <div class="card-info">
    <h3>{title}</h3>
    <p>{description}</p>
    {type === 'project' && link &&
      <a href={link} target="_blank" class="card-link">View Project</a>
    }
  </div>
</div>

<style>
  .card {
    background-color: #1a1a1a; /* Dark background */
    border: 1px solid #333333; /* Darker border */
    overflow: hidden;
    color: #e0e0e0; /* Light text */
    transition: transform 0.3s ease;
  }

  .card.project-card {
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  }

  .card.project-card:hover {
    transform: translateY(-5px);
  }

  .card.service-card {
    padding: 1.5rem;
    text-align: center;
  }

  .card-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .card-info {
    padding: 1rem;
  }

  .card-info h3 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
    color: #00e676; /* Vibrant green for heading */
  }

  .card-info p {
    font-size: 0.9rem;
    color: #e0e0e0; /* Light text */
  }

  .card-link {
    display: inline-block;
    margin-top: 1rem;
    color: #00e676;
    text-decoration: none;
    font-weight: bold;
  }

  .card-link:hover {
    text-decoration: underline;
  }
</style>
