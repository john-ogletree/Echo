---
const { type, title, description, image, link, contentType, videoSrc, author, audioSrc, date, rating } = Astro.props;
import Button from './Button.astro';

let cardClass = 'card';
if (type === 'project') {
  cardClass += ' project-card';
} else if (type === 'service') {
  cardClass += ' service-card';
} else if (type === 'blog') {
  cardClass += ' blog-card';
} else if (type === 'review') {
  cardClass += ' review-card';
} else if (type === 'newsletter') {
  cardClass += ' newsletter-card';
}

if (contentType) {
  cardClass += ` content-${contentType}`;
}
---
<div class={cardClass}>
  {type === 'project' && (contentType === 'image' || contentType === 'book') ? (
    <div class="card-content-horizontal">
      {image &&
        <a href={link} target="_blank">
          <img src={image} alt={title} class="card-image-small" />
        </a>
      }
      <div class="card-info">
        <div>
          <h3>{title}</h3>
          <p>{description}</p>
        </div>
        {contentType === 'book' && author &&
          <p class="book-author">{author}</p>
        }
        {link &&
          <Button text="View Details" link={link} variant="secondary" />
        }
      </div>
    </div>
  ) : (
    <>
      {type === 'project' && contentType === 'video' && videoSrc &&
        <a href={link} target="_blank">
          <img src={videoSrc} alt={title} class="card-image" />
        </a>
      }
      {type === 'project' && contentType === 'audio' && audioSrc &&
        <div class="audio-container">
          <audio controls src={audioSrc}></audio>
        </div>
      }
      <div class="card-info">
        <div>
          <h3>{title}</h3>
          <p>{description}</p>
        </div>
        {type === 'project' && link &&
          <Button text="View Details" link={link} variant="secondary" />
        }
      </div>
    </>
  )}

  {type === 'blog' &&
    <a href={link} class="blog-post-link">
      {image && <img src={image} alt={title} class="card-image" />}
      <div class="card-info">
        <h3>{title}</h3>
        <p class="blog-post-date">{date}</p>
        <p>{description}</p>
      </div>
    </a>
  }

  {type === 'review' &&
    <div class="review-card-content">
      {image && <img src={image} alt={title} class="card-image" />}
      <div class="card-info">
        <h3>{title}</h3>
        <p class="review-author">By: {author}</p>
        <p class="review-rating">Rating: {rating}/5</p>
        <p>{description}</p>
      </div>
    </div>
  }

  {type === 'newsletter' &&
    <div class="newsletter-card-content">
      <div class="card-info">
        <h2>{title}</h2>
        <p>{description}</p>
        <form class="newsletter-form">
          <input type="email" placeholder="Enter your email" required />
          <Button text="Subscribe" link="#" variant="primary" />
        </form>
      </div>
    </div>
  }
</div>

<style>
  .card {
    background-color: #1a1a1a; /* Dark background */
    border: 1px solid #333333; /* Darker border */
    overflow: hidden;
    color: #e0e0e0; /* Light text */
    transition: transform 0.3s ease;
    display: flex; /* Make card a flex container */
    flex-direction: column; /* Stack content vertically */
  }

  .card.project-card {
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  }

  .card.project-card:hover {
    transform: translateY(-5px);
  }

  .card.service-card {
    padding: 1.5rem;
    text-align: center;
  }

  .card-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .card-image-small {
    width: 100px; /* Smaller width for horizontal layout */
    height: auto;
    object-fit: cover;
    margin-right: 1rem;
    flex-shrink: 0; /* Prevent image from shrinking */
  }

  .card-info {
    padding: 1rem;
    flex-grow: 1; /* Allow info to take remaining space */
    display: flex; /* Make card-info a flex container */
    flex-direction: column; /* Stack content vertically */
    justify-content: space-between; /* Push button to bottom */
  }

  .card-info h3 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
    color: #00e676; /* Vibrant green for heading */
  }

  .card-info p {
    font-size: 0.9rem;
    color: #e0e0e0; /* Light text */
    margin-bottom: 0; /* Remove margin-bottom as flex handles spacing */
  }

  /* Specific styles for content types */
  .video-container,
  .audio-container {
    width: 100%;
    height: 200px;
    background-color: #000;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .video-container iframe,
  .audio-container audio {
    width: 100%;
    height: 100%;
  }

  .book-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1rem;
  }

  .book-cover {
    width: 120px;
    height: auto;
    margin-bottom: 0.5rem;
  }

  .book-author {
    font-size: 0.8rem;
    color: #00e676;
  }

  .card-content-horizontal {
    display: flex;
    align-items: flex-start; /* Align items to the start */
    padding: 1rem; /* Add padding to the container */
    flex-grow: 1; /* Allow horizontal content to take remaining space */
  }

  /* Blog and Review specific styles */
  .blog-card,
  .review-card {
    padding: 0; /* Remove padding from card itself */
  }

  .blog-post-link {
    text-decoration: none;
    color: inherit;
    display: block; /* Changed to block */
  }

  .blog-post-link .card-info {
    padding: 1rem; /* Add padding back to card-info */
  }

  .blog-post-date {
    font-size: 0.8rem;
    color: #e0e0e0;
    margin-bottom: 1rem;
  }

  .review-author,
  .review-rating {
    font-size: 0.85rem;
    color: #00e676;
    margin-bottom: 0.5rem;
  }

  .review-card-content {
    display: flex;
    flex-direction: column;
    height: 100%; /* Ensure it takes full height */
  }

  .review-card-content .card-info {
    padding: 1rem; /* Add padding back to card-info */
  }

  /* Newsletter Card Specific Styles */
  .newsletter-card {
    padding: 2rem;
    text-align: center;
  }

  .newsletter-card h2 {
    font-size: 1.5rem;
    color: #00e676; /* Vibrant green */
    margin-bottom: 1rem;
  }

  .newsletter-card p {
    font-size: 1rem;
    color: #e0e0e0; /* Light text */
    margin-bottom: 1.5rem;
  }

  .newsletter-card .newsletter-form {
    display: flex;
    flex-direction: column; /* Stack input and button vertically */
    gap: 1rem;
    align-items: center;
  }

  .newsletter-card .newsletter-form input[type="email"] {
    padding: 0.8rem 1rem;
    border: 1px solid #555555;
    background-color: #0a0a0a;
    color: #e0e0e0;
    border-radius: 4px;
    width: 100%; /* Full width input */
    max-width: 300px;
  }

  .newsletter-card .newsletter-form input[type="email"]::placeholder {
    color: #888888;
  }
</style>
