---
interface Props {
  text: string;
  href: string;
  variant?: 'primary' | 'secondary';
}

const { text, href, variant = 'primary' } = Astro.props;


const buttonClasses =
  variant === 'primary'
    ? 'inline-flex items-center justify-center w-full font-mono font-bold px-6 py-3 rounded-md border transition-colors duration-200 bg-orange-500 text-white border-orange-500 shadow hover:bg-orange-600 hover:border-orange-600'
    : 'inline-flex items-center justify-center w-full font-mono font-bold px-6 py-3 rounded-md border-2 border-orange-500 text-orange-500 bg-white shadow hover:bg-orange-50 hover:text-orange-600 hover:border-orange-600';

---
<a href={href} class={buttonClasses}>
  {text}
</a>

