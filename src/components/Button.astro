---
const { text, link, variant = 'primary', class: className } = Astro.props;

let buttonClass = 'button';
if (variant === 'primary') {
  buttonClass += ' primary';
} else if (variant === 'secondary') {
  buttonClass += ' secondary';
} else if (variant === 'full') {
  buttonClass += ' full';
}

if (className) {
  buttonClass += ` ${className}`;
}
---
<a href={link} class={buttonClass}>
  {text}
</a>

<style>
  .button {
    padding: 0.8rem 1.5rem;
    border: 1px solid; /* Solid border */
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.2s ease-in-out;
    text-decoration: none;
    display: inline-block;
    text-align: center;
    font-weight: normal;
    letter-spacing: 0;
    background-color: transparent; /* Transparent background by default */
  }

  .button.primary {
    border-color: #00e676; /* Vibrant green border */
    color: #00e676; /* Vibrant green text */
  }

  .button.primary:hover {
    background-color: #00e676; /* Fill with green on hover */
    color: #000000; /* Black text on hover */
  }

  .button.secondary {
    border-color: #e0e0e0; /* Light gray border */
    color: #e0e0e0; /* Light gray text */
  }

  .button.secondary:hover {
    background-color: #e0e0e0; /* Fill with light gray on hover */
    color: #000000; /* Black text on hover */
  }

  .button.full {
    width: 100%;
    display: block; /* Make it a block element to take full width */
  }
</style>
