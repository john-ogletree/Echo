---
const { text, link, variant = 'primary', class: className } = Astro.props;

let buttonClass = 'button';
if (variant === 'primary') {
  buttonClass += ' primary';
} else if (variant === 'secondary') {
  buttonClass += ' secondary';
} else if (variant === 'full') {
  buttonClass += ' full';
}

if (className) {
  buttonClass += ` ${className}`;
}
---
<a href={link} class={buttonClass}>
  {text}
</a>

<style>
  .button {
    padding: 0.8rem 1.5rem;
    border: 2px solid; /* Solid border */
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.3s ease-in-out;
    text-decoration: none;
    display: inline-block;
    text-align: center;
    font-weight: bold;
    position: relative;
    overflow: hidden;
    background-color: transparent;
  }

  .button::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 230, 118, 0.1); /* Subtle background fill */
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease-in-out;
    z-index: -1;
  }

  .button:hover::before {
    transform: scaleX(1);
  }

  .button.primary {
    border-color: #00e676; /* Vibrant green */
    color: #00e676; /* Vibrant green text */
    text-shadow: 0 0 5px #00e676; /* Subtle glow */
  }

  .button.primary:hover {
    color: #000000; /* Black text on hover */
    text-shadow: none;
  }

  .button.secondary {
    border-color: #00bcd4; /* Cyan */
    color: #00bcd4; /* Cyan text */
    text-shadow: 0 0 5px #00bcd4; /* Subtle glow */
  }

  .button.secondary:hover {
    background-color: #00bcd4; /* Fill with cyan on hover */
    color: #000000; /* Black text on hover */
    text-shadow: none;
  }

  .button.full {
    width: 100%;
    display: block;
  }
</style>