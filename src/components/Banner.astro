---
const { title, subtitle } = Astro.props;
---
<div class="banner">
  <h1>{title}</h1>
  <p>{subtitle}</p>
  <slot />
</div>

<style>
  .banner {
    background-color: #f0f0f0;
    padding: 2rem;
    text-align: center;
    border-radius: 8px;
    margin-bottom: 2rem;
  }

  .banner h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .banner p {
    font-size: 1.2rem;
    margin-bottom: 2rem;
  }
</style>
