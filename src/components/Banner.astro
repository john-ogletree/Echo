---
const { title, subtitle } = Astro.props;
---
<div class="banner">
  <h1>{title}</h1>
  <p>{subtitle}</p>
  <slot />
</div>

<style>
  .banner {
    padding: 2rem 0;
    text-align: center;
    border-bottom: 1px solid #333333; /* Darker border for AMOLED */
    margin-bottom: 2rem;
  }

  .banner h1 {
    font-size: 2rem;
    margin-bottom: 1rem;
    color: #00e676; /* Vibrant green for headings */
  }

  .banner p {
    font-size: 1rem;
    margin-bottom: 2rem;
    color: #e0e0e0; /* Light gray for text */
  }
</style>
