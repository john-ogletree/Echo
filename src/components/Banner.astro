---
---
<div class="banner">
  <div class="banner-grid">
    <div class="banner-column">
      <h1>Welcome to My Site</h1>
    </div>
    <div class="banner-column">
      <p>This is a simple banner created with Astro.</p>
    </div>
    <div class="banner-column">
      <a href="/about" class="static-button">Learn More</a>
    </div>
  </div>
</div>

<style>
  .banner {
    padding: 2rem 0;
    border-bottom: 1px solid #333333; /* Darker border for AMOLED */
    margin-bottom: 2rem;
  }

  .banner-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    align-items: center;
    text-align: center;
  }

  .banner-column {
    padding: 1rem;
  }

  .banner h1 {
    font-size: 2rem;
    margin-bottom: 0;
    color: #00e676; /* Vibrant green for headings */
  }

  .banner p {
    font-size: 1rem;
    margin-bottom: 0;
    color: #e0e0e0; /* Light gray for text */
  }

  .static-button {
    background-color: #00e676; /* Vibrant green */
    color: #000000; /* Black text for contrast */
    padding: 0.8rem 1.5rem;
    border: none;
    font-size: 1rem;
    cursor: pointer;
    transition: background-color 0.3s ease;
    text-decoration: none;
    display: inline-block;
    text-align: center;
    font-weight: bold;
  }

  .static-button:hover {
    background-color: #00c853; /* Slightly darker green on hover */
  }
</style>
