---
const { title = 'bash' } = Astro.props;
---
<div class="terminal">
  <div class="terminal-header">
    <div class="terminal-buttons">
      <span class="terminal-button red"></span>
      <span class="terminal-button yellow"></span>
      <span class="terminal-button green"></span>
    </div>
    <div class="terminal-title">{title}</div>
  </div>
  <div class="terminal-body">
    <slot />
  </div>
</div>

<style>
  .terminal {
    background-color: #0a0a0a; /* Even darker background */
    border: 1px solid #222222; /* Subtle border */
    border-radius: 6px; /* Slightly rounded corners */
    overflow: hidden;
    color: #e0e0e0; /* Light text */
    box-shadow: 0 4px 15px rgba(0, 230, 118, 0.2); /* Subtle glow */
  }

  .terminal-header {
    background-color: #1a1a1a; /* Darker header */
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    border-bottom: 1px solid #222222;
  }

  .terminal-buttons {
    display: flex;
    margin-right: auto;
  }

  .terminal-button {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    margin-right: 0.5rem;
    border: none; /* Remove border */
    opacity: 0.8;
    transition: opacity 0.2s ease;
  }

  .terminal-button:hover {
    opacity: 1;
  }

  .terminal-button.red {
    background-color: #ff5f56;
  }

  .terminal-button.yellow {
    background-color: #ffbd2e;
  }

  .terminal-button.green {
    background-color: #27c93f;
  }

  .terminal-title {
    font-family: monospace;
    color: #00e676; /* Vibrant green for title */
    font-weight: bold;
  }

  .terminal-body {
    padding: 1.5rem;
    font-family: monospace;
    line-height: 1.5;
  }
</style>
