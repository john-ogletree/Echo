---
const { title } = Astro.props;
---
<div class="services">
  <h2>{title}</h2>
  <div class="services-grid">
    <slot />
  </div>
  <div class="view-all-container">
    <button class="view-all-button">View All</button>
  </div>
</div>

<style>
  .services {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid #e1e4e8;
  }

  .services h2 {
    font-size: 1.5rem;
    text-align: center;
    margin-bottom: 2rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .view-all-container {
    text-align: center;
  }

  .view-all-button {
    background-color: #f6f8fa;
    color: #24292e;
    padding: 0.5rem 1rem;
    border: 1px solid #e1e4e8;
    font-size: 1rem;
    cursor: pointer;
  }

  .view-all-button:hover {
    background-color: #e1e4e8;
  }
</style>
