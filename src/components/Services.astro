---
const { title } = Astro.props;
---
<div class="services">
  <h2>{title}</h2>
  <div class="services-grid">
    <slot />
  </div>
</div>

<style>
  .services {
    margin-top: 2rem;
  }

  .services h2 {
    font-size: 2rem;
    text-align: center;
    margin-bottom: 2rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }
</style>
