---
const { title } = Astro.props;
---
<div class="services">
  <h2>{title}</h2>
  <div class="services-grid">
    <slot />
  </div>
  <div class="view-all-container">
    <button class="view-all-button">View All</button>
  </div>
</div>

<style>
  .services {
    margin-top: 2rem;
  }

  .services h2 {
    font-size: 2rem;
    text-align: center;
    margin-bottom: 2rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .view-all-container {
    text-align: center;
  }

  .view-all-button {
    background-color: #007bff;
    color: white;
    padding: 0.8rem 1.5rem;
    border: none;
    border-radius: 4px;
    font-size: 1rem;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .view-all-button:hover {
    background-color: #0056b3;
  }
</style>