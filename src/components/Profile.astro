---
const { name, bio, avatar, buttonLink, skillsData } = Astro.props;
import Button from '../components/Button.astro';
---
<div class="profile">
  <div class="profile-main">
    <img src={avatar} alt={name} class="profile-avatar" />
    <div class="profile-info">
      <h2 class="profile-name">{name}</h2>
      <p class="profile-bio">{bio}</p>
      <slot />
    </div>
  </div>
  <div class="profile-skills">
    <div class="skills-grid">
      {skillsData && skillsData.map(skill => (
        <div class="skill-card">
          <div class="skill-name">{skill.name}</div>
          <div class="progress-bar-container">
            <div class="progress-bar" style={`width: ${skill.percentage}%;`}></div>
          </div>
          <div class="skill-percentage">{skill.percentage}%</div>
        </div>
      ))}
    </div>
    <Button text="View More" link={buttonLink} variant="full" />
  </div>
</div>

<style>
  .profile {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 2rem 0;
    border-top: 1px solid #333333; /* Darker border */
    margin-top: 2rem;
  }

  .profile-main {
    display: flex;
    align-items: center;
    flex-basis: 50%;
  }

  .profile-avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    margin-right: 2rem;
  }

  .profile-name {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    color: #00e676; /* Vibrant green for name */
  }

  .profile-bio {
    font-size: 1rem;
    color: #e0e0e0; /* Light gray for text */
    margin-bottom: 1.5rem;
  }

  .profile-skills {
    display: flex;
    flex-direction: column; /* Reverted to column */
    align-items: center; /* Changed to center */
    flex-basis: 50%;
    width: 100%; /* Added width to center content */
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px; /* Changed from 1rem to 10px */
    margin-bottom: 1.5rem; /* Reverted margin-bottom */
    width: 100%; /* Reverted width */
  }

  .skill-card {
    background-color: #1a1a1a; /* Dark background */
    border: 1px solid #333333; /* Darker border */
    padding: 1rem;
    text-align: center;
    color: #e0e0e0; /* Light text */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .skill-name {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .progress-bar-container {
    width: 80%;
    height: 8px;
    background-color: #333333;
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 0.5rem;
  }

  .progress-bar {
    height: 100%;
    background-color: #00e676; /* Vibrant green */
    border-radius: 4px;
  }

  .skill-percentage {
    font-size: 0.8rem;
    color: #00e676;
  }
</style>
