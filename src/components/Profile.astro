---
const { name, bio, avatar } = Astro.props;
import Button from '../components/Button.astro';
---
<div class="profile">
  <div class="profile-main">
    <img src={avatar} alt={name} class="profile-avatar" />
    <div class="profile-info">
      <h2 class="profile-name">{name}</h2>
      <p class="profile-bio">{bio}</p>
      <slot />
    </div>
  </div>
  <div class="profile-skills">
    <div class="skills-grid">
      <div class="skill-card">JavaScript</div>
      <div class="skill-card">React</div>
      <div class="skill-card">Astro</div>
      <div class="skill-card">CSS</div>
    </div>
    <Button text="View More" link="#" variant="primary" />
  </div>
</div>

<style>
  .profile {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 2rem 0;
    border-top: 1px solid #333333; /* Darker border */
    margin-top: 2rem;
  }

  .profile-main {
    display: flex;
    align-items: center;
    flex-basis: 50%;
  }

  .profile-avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    margin-right: 2rem;
  }

  .profile-name {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    color: #00e676; /* Vibrant green for name */
  }

  .profile-bio {
    font-size: 1rem;
    color: #e0e0e0; /* Light gray for text */
    margin-bottom: 1.5rem;
  }

  .profile-skills {
    display: flex;
    flex-direction: column; /* Reverted to column */
    align-items: flex-end; /* Reverted to flex-end */
    flex-basis: 50%;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px; /* Changed from 1rem to 10px */
    margin-bottom: 1.5rem; /* Reverted margin-bottom */
    width: 100%; /* Reverted width */
  }

  .skill-card {
    background-color: #1a1a1a; /* Dark background */
    border: 1px solid #333333; /* Darker border */
    padding: 1rem;
    text-align: center;
    color: #e0e0e0; /* Light text */
  }
</style>