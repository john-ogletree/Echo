---
const { name, bio, avatar } = Astro.props;
---
<div class="profile">
  <img src={avatar} alt={name} class="profile-avatar" />
  <div class="profile-info">
    <h2 class="profile-name">{name}</h2>
    <p class="profile-bio">{bio}</p>
    <slot />
  </div>
</div>

<style>
  .profile {
    display: flex;
    align-items: center;
    background-color: #f9f9f9;
    padding: 2rem;
    border-radius: 8px;
    margin-top: 2rem;
  }

  .profile-avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    margin-right: 2rem;
  }

  .profile-name {
    font-size: 1.8rem;
    margin-bottom: 0.5rem;
  }

  .profile-bio {
    font-size: 1.1rem;
    color: #555;
  }
</style>
