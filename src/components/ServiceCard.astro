---
const { title, description } = Astro.props;
---
<div class="service-card">
  <h3>{title}</h3>
  <p>{description}</p>
</div>

<style>
  .service-card {
    background-color: #1a1a1a; /* Dark background */
    border: 1px solid #333333; /* Darker border */
    padding: 1.5rem;
    text-align: center;
    color: #e0e0e0; /* Light text */
  }

  .service-card h3 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
    color: #00e676; /* Vibrant green for heading */
  }

  .service-card p {
    font-size: 0.9rem;
    color: #e0e0e0; /* Light text */
  }
</style>
