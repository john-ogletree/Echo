---
const { title, description } = Astro.props;
---
<div class="service-card">
  <h3>{title}</h3>
  <p>{description}</p>
</div>

<style>
  .service-card {
    background-color: #f9f9f9;
    padding: 2rem;
    border-radius: 8px;
    text-align: center;
  }

  .service-card h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .service-card p {
    font-size: 1.1rem;
    color: #555;
  }
</style>
