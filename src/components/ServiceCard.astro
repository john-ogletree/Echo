---
const { title, description } = Astro.props;
---
<div class="service-card">
  <h3>{title}</h3>
  <p>{description}</p>
</div>

<style>
  .service-card {
    background-color: #f6f8fa;
    border: 1px solid #e1e4e8;
    padding: 1.5rem;
    text-align: center;
  }

  .service-card h3 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }

  .service-card p {
    font-size: 0.9rem;
    color: #586069;
  }
</style>