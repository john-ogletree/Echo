---
const { title, date, excerpt, link } = Astro.props;
---
<div class="blog-post-card">
  <a href={link} class="blog-post-link">
    <h3>{title}</h3>
    <p class="blog-post-date">{date}</p>
    <p>{excerpt}</p>
  </a>
</div>

<style>
  .blog-post-card {
    background-color: #1a1a1a; /* Dark background */
    border: 1px solid #333333; /* Darker border */
    overflow: hidden;
    color: #e0e0e0; /* Light text */
    transition: transform 0.3s ease;
  }

  .blog-post-card:hover {
    transform: translateY(-5px);
  }

  .blog-post-link {
    text-decoration: none;
    color: inherit;
    display: block;
    padding: 1.5rem;
  }

  .blog-post-card h3 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
    color: #00e676; /* Vibrant green for heading */
  }

  .blog-post-date {
    font-size: 0.8rem;
    color: #e0e0e0;
    margin-bottom: 1rem;
  }

  .blog-post-card p {
    font-size: 0.9rem;
    color: #e0e0e0; /* Light text */
  }
</style>
