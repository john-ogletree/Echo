<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
      const navToggle = document.getElementById('nav-toggle');
      const navDrawer = document.getElementById('nav-drawer-container');
      const navClose = document.querySelector('.nav-close');
      const body = document.body;
      function toggleMobileNav() {
          const isOpen = navDrawer.classList.contains('is-open');
          navDrawer.classList.toggle('is-open', !isOpen);
          navToggle.setAttribute('aria-expanded', !isOpen);
          body.classList.toggle('no-scroll', !isOpen);
      }

      if (navToggle && navDrawer) {
          navToggle.addEventListener('click', toggleMobileNav);
          navClose.addEventListener('click', toggleMobileNav);
      }

      const navLinks = document.querySelectorAll('.nav-links a');
      navLinks.forEach(link => {
          link.addEventListener('click', (event) => {
              // Close nav if a regular link is clicked inside the open drawer
              if (navDrawer.classList.contains('is-open')) {
                  toggleMobileNav();
              }
          });
      });
  });
</script>

<style>
    /* Using :root on a component level can be tricky. 
    It's better to define these in a global stylesheet if possible.
    For this self-contained component, they are included here. */
    :root {
        --color-bg: #F0EAD6;
        --color-surface: #D4C9A8;
        --color-text: #3B2F2A;
        --color-text-light: #5B4F48;
        --color-heading: #E07A5F;
        --color-accent: #3D87A6;
        --color-border: #A69E8C;
        --font-mono: 'IBM Plex Mono', Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        --padding-x: 2rem;
        --color-tag-bg: rgba(61, 135, 166, 0.15);
    }
    
    body.no-scroll {
        overflow: hidden;
    }
    /* Blur effect should apply to the main content, not the header.
       This will require a specific class on your main content area in the layout. */
    body.no-scroll .main-content-area {
        filter: blur(5px);
        pointer-events: none;
    }

    .readme-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1rem var(--padding-x);
        border-bottom: 1px solid var(--color-border);
        position: sticky;
        top: 0;
        z-index: 10;
        background-color: var(--color-surface);
    }

    .header-left, .header-right {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .repo-title {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 1.25rem;
    }
    
    .repo-title a {
      color: var(--color-text);
      font-weight: 700;
    }
    
    .repo-title a:hover {
      text-decoration: none;
      color: var(--color-accent);
    }

    .icon-repo {
        fill: var(--color-text-light);
    }

    .search-form { 
        position: relative;
    }

    .search-input {
        background-color: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: 6px;
        padding: 0.4rem 2rem 0.4rem 0.75rem;
        font-family: var(--font-mono);
        font-size: 0.9rem;
        color: var(--color-text);
        width: 180px;
    }

    .search-input:focus {
        outline: none;
        border-color: var(--color-accent);
        box-shadow: 0 0 0 3px rgba(61, 135, 166, 0.3);
    }

    .mobile-search { 
        display: block;
    }

    .nav-links {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        list-style: none;
        margin: 0;
        padding: 1.5rem;
        flex-grow: 1;
        overflow-y: auto;
    }

    .nav-links li {
        border-bottom: none;
    }

    .nav-links a {
        position: relative;
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 1rem;
        font-weight: 500;
        padding: 0.75rem 1rem;
        border-bottom: none;
        border-radius: 6px;
        color: var(--color-text);
        transition: color 0.2s ease, background-color 0.2s ease;
    }
    
    .nav-links a:hover {
        background-color: var(--color-bg);
        color: var(--color-accent);
        text-decoration: none;
    }
    
    .nav-links a.current-page {
        background-color: var(--color-tag-bg);
        color: var(--color-accent);
        font-weight: 700;
    }

    .nav-links a:active {
        transform: scale(0.98);
    }
    
    .nav-links a span {
        flex-grow: 1;
    }

    .nav-links a svg {
        flex-shrink: 0;
    }

    .nav-socials-container {
        list-style: none;
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--color-border);
    }

    .nav-toggle,
    .nav-close {
        background: none;
        border: none;
        color: var(--color-text);
        padding: 0.5rem;
        cursor: pointer;
        z-index: 100;
    }

    .nav-close {
        display: none;
    }

    .nav-drawer-container.is-open ~ .nav-toggle {
        display: none;
    }

    .nav-drawer-container .nav-close {
        display: none;
    }
    
    .nav-drawer-container.is-open .nav-close {
        display: block;
    }

    .nav-drawer-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 300px;
        height: 100vh;
        background-color: var(--color-surface);
        border-right: 1px solid var(--color-border);
        transform: translateX(-100%);
        transition: transform 0.3s ease-in-out;
        z-index: 99;
        box-shadow: 4px 0 16px rgba(0, 0, 0, 0.5);
    }

    .nav-drawer-container.is-open {
        transform: translateX(0);
    }
    
    .main-nav {
        display: flex;
        flex-direction: column;
        height: 100%;
        padding: 0;
    }

    .nav-header-mobile {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.5rem; /* Adjusted padding */
        border-bottom: 1px solid var(--color-border);
        flex-shrink: 0;
    }
    
    .nav-header-mobile .nav-close {
      margin-left: auto; /* Push the close button to the right */
    }

    .nav-header-mobile .mobile-search {
        flex-grow: 1;
    }

    .nav-socials {
        list-style: none;
        padding: 0;
        display: flex;
        justify-content: flex-start;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .nav-socials a {
        padding: 0.5rem;
        border-bottom: none;
        color: var(--color-text-light);
    }

    .nav-socials a:hover { 
        color: var(--color-accent); 
        background-color: transparent; 
    }

    .nav-socials svg { 
        width: 24px; 
        height: 24px;
    }
    
    /* Responsive */
    @media (max-width: 920px) {
        :root {
            --padding-x: 1.5rem;
        }
    }

    @media (max-width: 768px) {
        :root {
            --padding-x: 1rem;
        }
    }

    @media (max-width: 480px) {
        .repo-title .font-bold {
            display: none; /* Hides text on very small screens, leaves icon */
        }
    }
</style>