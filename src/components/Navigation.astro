    <div class="header-left">
        <div class="repo-title">
            <svg class="icon-repo" viewBox="0 0 16 16" version="1.1" width="16" height="16" aria-hidden="true"><path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 0 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Z"></path></svg>
            <a href="/" class="font-bold">john-ogletree/Echo</a>
        </div>
    </div>
</header>

<style>
    /* --- Header Search --- */
    .search-form { position: relative; }
    .search-input {
        background-color: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: 6px;
        padding: 0.4rem 2rem 0.4rem 0.75rem;
        font-family: var(--font-mono);
        font-size: 0.9rem;
        color: var(--color-text);
        width: 180px;
    }
    .search-input:focus {
        outline: none;
        border-color: var(--color-accent);
        box-shadow: 0 0 0 3px rgba(61, 135, 166, 0.3);
    }
    .mobile-search { display: block; }
    .desktop-search { display: none; }

    /* --- Header / Nav --- */
    .nav-links {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        list-style: none;
        margin: 0;
        padding: 2rem 1.5rem;
        flex-grow: 1;
        overflow-y: auto;
    }
    .nav-links a {
        position: relative;
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 1.1rem;
        font-weight: 500;
        padding: 0.5rem 0;
        border-bottom: 1px solid var(--color-border);
        color: var(--color-text);
        transition: color 0.2s ease, transform 0.2s ease;
    }
    .nav-links a:hover {
        color: var(--color-accent);
        text-decoration: none;
        transform: translateX(5px);
    }
    .nav-links a.current-page {
        color: var(--color-heading);
    }
    .nav-links a.current-page::before,
    .nav-links a:hover::before {
        content: '';
        position: absolute;
        left: -1rem;
        height: 100%;
        width: 4px;
        background-color: var(--color-accent);
        border-radius: 2px;
    }
    .nav-links a:active {
        transform: scale(0.98);
    }
    .nav-links a span { flex-grow: 1; }
    .nav-links a svg { flex-shrink: 0; }
    
    .nav-toggle,
    .nav-close {
        background: none;
        border: none;
        color: var(--color-text);
        padding: 0.5rem;
        cursor: pointer;
        z-index: 100;
    }
    
    .nav-close { display: none; }

    .nav-drawer-container.is-open ~ .nav-toggle { display: none; }
    .nav-drawer-container .nav-close { display: none; }
    .nav-drawer-container.is-open .nav-close { display: block; }
    .nav-drawer-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 300px;
        height: 100vh;
        background-color: var(--color-surface);
        border-right: 1px solid var(--color-border);
        transform: translateX(-100%);
        transition: transform 0.3s ease-in-out;
        z-index: 99;
        box-shadow: 4px 0 16px rgba(0, 0, 0, 0.5);
    }
    .nav-drawer-container.is-open { transform: translateX(0); }
    
    .main-nav {
        display: flex;
        flex-direction: column;
        height: 100%;
        padding: 0;
    }

    .nav-header-mobile {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.5rem 1.5rem 1rem 1.5rem;
        border-bottom: 1px solid var(--color-border);
        flex-shrink: 0;
    }
    .nav-header-mobile .mobile-search { flex-grow: 1; }
    .nav-socials {
        list-style: none;
        padding: 1.5rem;
        border-top: 1px solid var(--color-border);
        display: flex;
        justify-content: center;
        gap: 2rem;
        flex-shrink: 0;
    }
    .nav-socials a { color: var(--color-text-light); }
    .nav-socials a:hover { color: var(--color-accent); }
    .nav-socials svg { width: 24px; height: 24px; }
</style>