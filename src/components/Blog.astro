---
const { title, coverImage } = Astro.props;
import Button from './Button.astro';
---
<div class="blog">
  {coverImage && <img src={coverImage} alt="Blog Cover" class="blog-cover-image" />}
  <h2>{title}</h2>
  <div class="blog-posts-grid">
    <slot />
  </div>
  <div class="view-all-container">
    <Button text="View All Posts" link="/blog" variant="full" />
  </div>
</div>

<style>
  .blog {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid #333333; /* Darker border */
  }

  .blog-cover-image {
    width: 100%;
    height: 200px; /* Fixed height for cover image */
    object-fit: cover;
    margin-bottom: 2rem;
  }

  .blog h2 {
    font-size: 1.5rem;
    text-align: center;
    margin-bottom: 2rem;
    color: #00e676; /* Vibrant green for heading */
  }

  .blog-posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .view-all-container {
    text-align: center;
  }

  .view-all-button {
    background-color: #00e676; /* Vibrant green for button */
    color: #000000; /* Black text for contrast */
    padding: 0.5rem 1rem;
    border: none;
    font-size: 1rem;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .view-all-button:hover {
    background-color: #00c853; /* Slightly darker green on hover */
  }
</style>
